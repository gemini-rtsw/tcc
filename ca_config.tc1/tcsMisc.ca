#+
# tcsMisc.ca
#
# Channel access configuration file for miscellaneous tcs commands.
#
# D Terrett 6 June 2000
#
# Copyright CCLRC
#-

command wrap tcsApply Wrap flags
{
   azimuth tc1:azwrap.A Azimuth
   rotator tc1:rotwrap.A Rotator
}

command mcFollow tcsApply Mount following
{
   followState tc1:mcFollow.A State
}

command crFollow tcsApply Rotator following
{
   followState tc1:crFollow.A State
}

command p1Follow tcsApply PWFS1 probe following
{
   followState tc1:pwfs1Follow.A State
}

command p2Follow tcsApply PWFS2 probe following
{
   followState tc1:pwfs2Follow.A State
}

command oiFollow tcsApply OIWFS probe following
{
   followState tc1:oiwfsFollow.A State
}

command m2Follow tcsApply M2 following
{
   followState tc1:m2Follow.A State
}

command aoFollow tcsApply AOS probe following
{
   followState tc1:aoFollow.A State
}

command weather tcsApply Weather data
{
   source tc1:useWS.A Source
   temp tc1:temperature.A Temp (deg C)
   press tc1:pressure.A Pressure (mbar)
   humid tc1:humidity.A Humidity (%)
}

command airmassLimit tcsApply Airmass
{
   limit tc1:airmassLimit.A Limit
}

command pointLog tcsApply Log pointing data
{
   log      tc1:pointLog.A
}

command absorbGuide tcsApply Absorb guide adjustments
{
   dummy     tc1:absorbGuide.A
}

command zeroGuide tcsApply Zero guide adjustments
{
   dummy     tc1:zeroGuide.A
}

command absorbOffset tcsApply Absorb offsets
{
   vt       tc1:absorbOffset.A  Virtual telescope mask
   index    tc1:absorbOffset.B  Offset index
}

command clearOffset tcsApply Clear offsets
{
   vt       tc1:clearOffset.A  Virtual telescope mask
   index    tc1:clearOffset.B  Offset index
}

command incrOffset tcsApply Increment offsets
{
   theta1   tc1:incrOffset.A   RA/Az
   theta2   tc1:incrOffset.B   Dec/El
   vt       tc1:incrOffset.C   Virtual telescope mask
   type     tc1:incrOffset.D   Type
}

command absorbPoOffset tcsApply Absorb instrument origin offsets
{
   vt       tc1:absorbPoOffset.A  Virtual telescope mask
   index    tc1:absorbPoOffset.B  Offset index
}

command clearPoOffset tcsApply Clear instrument origin offsets
{
   vt       tc1:clearPoOffset.A  Virtual telescope mask
   index    tc1:clearPoOffset.B  Offset index
}

command pointParam tcsApply Pointing model parameter
{
   name     tc1:pointParam.A     Name
   level    tc1:pointParam.B     Model
   value    tc1:pointParam.C     Value
}

command timeParam tcsApply Time system parameter
{
   name     tc1:timeParam.A     Name
   value    tc1:timeParam.B     Value
}

command chopConfig tcsApply Chop configuration
{
   type      tc1:chopConfig.A    Type
   source    tc1:chopConfig.B    Sync source
   frequency tc1:chopConfig.C    Frequency
   dutycycle tc1:chopConfig.D    Duty cycle
}
