command hrwfs tcsApply Set HRWFS fold mirror
{
   hwfold tc1:hrwfs.A HRWFS fold position
}

command aoFold tcsApply Set AO fold mirror
{
   aofold tc1:aoFold.A AO fold position
}

command scienceFold tcsApply Set science fold position
{
   scfold tc1:scienceFold.A Science fold position
}

command scienceFoldPark tcsApply Park science fold mirror
{
   scfoldPark tc1:scienceFoldPark.A Park Science fold
}

command pwfs1Park tcsApply PWFS1 park
{
   dummy      tc1:pwfs1Park.A        Park
}

command pwfs1Flip tcsApply PWFS1 flip
{
   dummy      tc1:pwfs1Flip.A        Flip
}

command pwfs1Stop tcsApply PWFS1 stop
{
   dummy      tc1:pwfs1Stop.A        Stop
}

command pwfs1Unwrap tcsApply PWFS1 unwrap
{
   dummy      tc1:pwfs1Unwrap.A      Unwrap
}

command pwfs1SetOrient tcsApply Set PWFS1 orientation
{
   table      tc1:pwfs1SetOrient.A      Table angle
   arm        tc1:pwfs1SetOrient.B      Arm angle
}

command pwfs2Park tcsApply PWFS2 park
{
   dummy      tc1:pwfs2Park.A        Park
}

command pwfs2Flip tcsApply PWFS2 flip
{
   dummy      tc1:pwfs2Flip.A        Flip
}

command pwfs2Stop tcsApply PWFS2 stop
{
   dummy      tc1:pwfs2Stop.A        Stop
}

command pwfs2Unwrap tcsApply PWFS2 unwrap
{
   dummy      tc1:pwfs2Unwrap.A      Unwrap
}

command pwfs2SetOrient tcsApply Set PWFS2 orientation
{
   table      tc1:pwfs2SetOrient.A      Table angle
   arm        tc1:pwfs2SetOrient.B      Arm angle
}

command pwfs1Datum tcsApply Datum PWFS1
{
   dummy      tc1:pwfs1Datum.A          Dummy
}

command pwfs2Datum tcsApply Datum PWFS2
{
   dummy      tc1:pwfs2Datum.A          Dummy
}
