command scienceFold tcsApply Position science fold
{
   scfold tc1:scienceFold.A Position
}

command scienceFoldPark tcsApply Park science fold
{
   dummy tc1:scienceFoldPark.A
}

command scienceFoldDatum tcsApply Datum science fold
{
   dummy      tc1:scienceFoldDatum.A
}

command hrwfs tcsApply Position HRWFS fold
{
   hwfold tc1:hrwfs.A Position
}

command hrwfsPark tcsApply Park HRWFS fold
{
   dummy      tc1:hrwfsPark.A
}

command hrwfsDatum tcsApply Datum HRWFS fold
{
   dummy      tc1:hrwfsDatum.A
}

command aoFold tcsApply Position AO fold
{
   aofold tc1:aoFold.A Position
}

command aoFoldPark tcsApply Park AO fold
{
   dummy      tc1:aoFoldPark.A
}

command aoFoldDatum tcsApply Datum AO Fold
{
   dummy      tc1:aoFoldDatum.A
}

