command hrwfs tcsApply Optics configuration
{
   hwfold tc1:hrwfs.A HRWFS fold position
}

command aoFold tcsApply Optics configuration
{
   aofold tc1:aoFold.A AO fold position
}

command scienceFold tcsApply Optics configuration
{
   scfold tc1:scienceFold.A Science fold position
}

command scienceFoldPark tcsApply Optics configuration
{
   scfoldPark tc1:scienceFoldPark.A Park Science fold
}
