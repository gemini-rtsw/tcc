status agssad
{
   sfTilt              ag:sfTilt                  0 Science fold tilt
   sfRot               ag:sfRot                   0 Science fold rotation
   sfLin               ag:sfLin                   0 Science linear position
   aoName              tc1:ag:aoName              0 AO fold position
   hwName              tc1:ag:hwName              0 HRWFS fold position
   p1FollowS           tc1:ag:p1:followS          0 P1 follow mode
   p1InPosition        tc1:ag:p1:inPosition       0 P1 in position
   p1TableAngle        tc1:ag:p1:RT34Pos      0 P2 Rotary table angle
   p1ArmAngle          tc1:ag:p1:PA34Pos      0 P2 Probe arm angle
   p1X                 tc1:ag:p1:x                0 P1 x position
   p1Y                 tc1:ag:p1:y                0 P1 y position
   p1TableOffset       ag:p1:probeCalParm.B   0 P1 table angle offset
   p1RadiusRT          ag:p1:probeCalParm.G   0 P1 Rotary table radius
   p1ArmOffset         ag:p1:probeCalParm.D   0 P1 probe arm offset
   p1XTranslation      ag:p1:probeCalParm.H   0 P1 X translation
   p1YTranslation      ag:p1:probeCalParm.I   0 P1 Y translation
   p1RadiusPA          ag:p1:probeCalParm.U   0 P1 Probe arm length
   p2FollowS           tc1:ag:p2:followS      0 P2 follow mode
   p2InPosition        tc1:ag:p2:inPosition   0 P2 in position
   p2TableAngle        tc1:ag:p2:RT34Pos      0 P2 Rotary table angle
   p2ArmAngle          tc1:ag:p2:PA34Pos      0 P2 Probe arm angle
   p2X                 tc1:ag:p2:x            0 P2 x position
   p2Y                 tc1:ag:p2:y            0 P2 y position
   p2TableOffset       ag:p2:probeCalParm.B   0 P2 table angle offset
   p2RadiusRT          ag:p2:probeCalParm.G   0 P2 Rotary table radius
   p2ArmOffset         ag:p2:probeCalParm.D   0 P2 probe arm offset
   p2XTranslation      ag:p2:probeCalParm.H   0 P2 X translation
   p2YTranslation      ag:p2:probeCalParm.I   0 P2 Y translation
   p2RadiusPA          ag:p2:probeCalParm.U   0 P2 Probe arm length
   oiFollowS           tc1:ag:oi:followS          0 OIWFS follow mode
   p1guiding           tc1:pwfs1:dc:fgDiag1.VALB  0 P1 generating guide signal
   p2guiding           tc1:pwfs2:dc:fgDiag.VALL   0 P2 generating guide signal
}
