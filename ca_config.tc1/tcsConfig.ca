command wavelSourceA tcsApply Set source A effective wavelength
{
   wavel tc1:wavelSourceA.A Wavelength (mu)
}

command wavelSourceB tcsApply Set source B effective wavelength
{
   wavel tc1:wavelSourceB.A Wavelength (mu)
}

command wavelMount tcsApply Set Mount effective wavelength
{
   wavel tc1:wavelMount.A Wavelength (mu)
}

command wavelPwfs1 tcsApply Set pwfs1 effective wavelength
{
   wavel tc1:wavelPwfs1.A Wavelength (mu)
}

command wavelPwfs2 tcsApply Set pwfs2 effective wavelength
{
   wavel tc1:wavelPwfs2.A Wavelength (mu)
}

command wavelOiwfs tcsApply Set oiwfs effective wavelength
{
   wavel tc1:wavelOiwfs.A Wavelength (mu)
}

command difTrSourceA tcsApply Set source A differential track rates
{
   system tc1:difTrSourceA.A System
   equinox tc1:difTrSourceA.B Equinox
   epoch tc1:difTrSourceA.C Epoch (MJD TT)
   dtheta1 tc1:difTrSourceA.D Rate in RA or Azimuth
   dtheta2 tc1:difTrSourceA.E Rate in Dec or Elevation
}

