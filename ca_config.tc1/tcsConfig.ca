command mount tcsApply Set mount target
{
   objName tc1:mount.A Object name
   system tc1:mount.B System
   theta1 tc1:mount.C RA or Azimuth
   theta2 tc1:mount.D Dec or Elevation
   epoch tc1:mount.F Epoch
   equinox tc1:mount.E Equinox
   parallax tc1:mount.G Parallax
   dtheta1 tc1:mount.H Proper motion in RA
   dtheta2 tc1:mount.I Proper motion in Dec
   rv tc1:mount.J Radial velocity
}

command sourceA tcsApply Set source A target
{
   objName tc1:sourceA.A Object name
   system tc1:sourceA.B System
   theta1 tc1:sourceA.C RA or Azimuth
   theta2 tc1:sourceA.D Dec or Elevation
   epoch tc1:sourceA.F Epoch
   equinox tc1:sourceA.E Equinox
   parallax tc1:sourceA.G Parallax (arcsec)
   dtheta1 tc1:sourceA.H Proper motion in RA (sec/y)
   dtheta2 tc1:sourceA.I Proper motion in Dec (arcsec/y)
   rv tc1:sourceA.J Radial velocity (km/s)
   planet tc1:planet.A Solar system object
}

command sourceB tcsApply Set source B target
{
   objName tc1:sourceB.A Object name
   system tc1:sourceB.B System
   theta1 tc1:sourceB.C RA or Azimuth
   theta2 tc1:sourceB.D Dec or Elevation
   epoch tc1:sourceB.F Epoch
   equinox tc1:sourceB.E Equinox
   parallax tc1:sourceB.G Parallax
   dtheta1 tc1:sourceB.H Proper motion in RA
   dtheta2 tc1:sourceB.I Proper motion in Dec
   rv tc1:sourceB.J Radial velocity
}

