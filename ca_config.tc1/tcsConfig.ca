command pwfs1Guide tcsApply Set pwfs1 guide configuration
{
   nodachopa tc1:configPwfs1.A Noda A Chop A enable
   nodachopb tc1:configPwfs1.B Noda A Chop B enable
   nodachopc tc1:configPwfs1.C Noda A Chop C enable
   nodbchopa tc1:configPwfs1.D Noda B Chop A enable
   nodbchopb tc1:configPwfs1.E Noda B Chop B enable
   nodbchopc tc1:configPwfs1.F Noda B Chop C enable
   nodcchopa tc1:configPwfs1.G Noda A Chop A enable
   nodcchopb tc1:configPwfs1.H Noda A Chop B enable
   nodcchopc tc1:configPwfs1.I Noda A Chop C enable
}

command pwfs2Guide tcsApply Set pwfs2 guide configuration
{
   nodachopa tc1:configPwfs2.A Noda A Chop A enable
   nodachopb tc1:configPwfs2.B Noda A Chop B enable
   nodachopc tc1:configPwfs2.C Noda A Chop C enable
   nodbchopa tc1:configPwfs2.D Noda B Chop A enable
   nodbchopb tc1:configPwfs2.E Noda B Chop B enable
   nodbchopc tc1:configPwfs2.F Noda B Chop C enable
   nodcchopa tc1:configPwfs2.G Noda A Chop A enable
   nodcchopb tc1:configPwfs2.H Noda A Chop B enable
   nodcchopc tc1:configPwfs2.I Noda A Chop C enable
}

command oiwfsGuide tcsApply Set oiwfs guide configuration
{
   nodachopa tc1:configOiwfs.A Noda A Chop A enable
   nodachopb tc1:configOiwfs.B Noda A Chop B enable
   nodachopc tc1:configOiwfs.C Noda A Chop C enable
   nodbchopa tc1:configOiwfs.D Noda B Chop A enable
   nodbchopb tc1:configOiwfs.E Noda B Chop B enable
   nodbchopc tc1:configOiwfs.F Noda B Chop C enable
   nodcchopa tc1:configOiwfs.G Noda A Chop A enable
   nodcchopb tc1:configOiwfs.H Noda A Chop B enable
   nodcchopc tc1:configOiwfs.I Noda A Chop C enable
}

command poriginA tcsApply Set pointing origin A
{
   x tc1:poriginA.A X (mm)
   y tc1:poriginA.B Y (mm)
}

command poriginB tcsApply Set pointing origin B
{
   x tc1:poriginB.A X (mm)
   y tc1:poriginB.B Y (mm)
}

command poriginC tcsApply Set pointing origin B
{
   x tc1:poriginC.A X (mm)
   y tc1:poriginC.B Y (mm)
}

command poriginM tcsApply Set mount pointing origin
{
   x tc1:poriginM.A X (mm)
   y tc1:poriginM.B Y (mm)
}

command rotator tcsApply Set rotator configuration
{
   ipa tc1:rotator.A Position angle (deg)
   system tc1:rotator.B Reference frame
   equinox tc1:rotator.C Equinox of reference frame
   iaa tc1:rotator.D Alignment angle (deg)
}

command slew tcsApply Set slew options
{
   chopThrow tc1:slew.A Zero chop throw
   sourceOffset tc1:slew.B Zero source offsets
   sourceDifTr tc1:slew.C Zero source differential track rates
   mountOffset tc1:slew.D Zero mount offsets
   mountDifTr tc1:slew.E Zero mount differential track rates
   filter1 tc1:slew.F Short circuit target filters
   filter2 tc1:slew.G Short circuit mount filters
   pointing tc1:slew.H Reset local pointing model adjustments
   guiding tc1:slew.I Stop guiding
   mark tc1:slew.J Mark CAD
}

command orbit tcsApply Set orbital elements
{
   eltype tc1:orbit.A Orbital element type
   epochofel tc1:orbit.B Epoch of elements (TT)
   inclination tc1:orbit.C Orbital inclination (deg)
   longascnode tc1:orbit.D Longitude of ascending node (deg)
   longofper tc1:orbit.E Longitude of perihelion (deg)
   argofper tc1:orbit.E Argument of perihelion (deg)
   meandist tc1:orbit.F Mean distance (AU)
   perdist tc1:orbit.F Perihelion distance (AU)
   eccentricity tc1:orbit.G Eccentricity
   meanlong tc1:orbit.H Mean longitude (deg)
   meananom tc1:orbit.H Mean anomaly (deg)
   dailymot tc1:orbit.I Daily motion (deg)
   objName tc1:orbit.J Object name
}

command chopRelative tcsApply Set relative chopping
{
   throw tc1:chopRelative.A Chop throw
   angle tc1:chopRelative.B Position angle
   system tc1:chopRelative.C System
   equinox tc1:chopRelative.D Equinox
}
