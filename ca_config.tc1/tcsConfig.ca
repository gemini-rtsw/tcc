command mount tcsApply Mount target
{
   objName tc1:mount.A Name
   system tc1:mount.B System
   theta1 tc1:mount.C RA/Az
   theta2 tc1:mount.D Dec/El
   epoch tc1:mount.F Epoch
   equinox tc1:mount.E Equinox
   parallax tc1:mount.G Parallax
   dtheta1 tc1:mount.H Proper motion in RA
   dtheta2 tc1:mount.I Proper motion in Dec
   rv tc1:mount.J Radial velocity
}

command sourceA tcsApply Source A target
{
   objName tc1:sourceA.A Name
   system tc1:sourceA.B System
   theta1 tc1:sourceA.C RA/Az
   theta2 tc1:sourceA.D Dec/El
   epoch tc1:sourceA.F Epoch
   equinox tc1:sourceA.E Equinox
   parallax tc1:sourceA.G Parallax
   dtheta1 tc1:sourceA.H Proper motion in RA
   dtheta2 tc1:sourceA.I Proper motion in Dec
   rv tc1:sourceA.J Radial velocity
}

