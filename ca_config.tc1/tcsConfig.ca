command trackMount tcsApply Set mount tracking frame
{
   system tc1:trackMount.A System
   equinox tc1:trackMount.B Equinox
}

command trackSourceA tcsApply Set source A tracking frame
{
   system tc1:trackSourceA.A System
   equinox tc1:trackSourceA.B Equinox
}

command trackSourceB tcsApply Set source B tracking frame
{
   system tc1:trackSourceB.A System
   equinox tc1:trackSourceB.B Equinox
}

command trackSourceC tcsApply Set source C tracking frame
{
   system tc1:trackSourceC.A System
   equinox tc1:trackSourceC.B Equinox
}

command trackPwfs1 tcsApply Set pwfs1 tracking frame
{
