command offsetSourceA1 tcsApply Offset source A 1
{
   type     tc1:offsetSourceA1.A Offset type
   dtheta1  tc1:offsetSourceA1.B RA/Az
   dtheta2  tc1:offsetSourceA1.C Dec/El
}

command wavelMount tcsApply Mount wavelength
{
   wavel tc1:wavelMount.A Wavelength (mu)
}

