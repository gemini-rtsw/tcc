command pwfs1Guide tcsApply P1 guide configuration
{
   nodachopa tc1:configPwfs1.A Nod A Chop A
   nodachopb tc1:configPwfs1.B Nod A Chop B
   nodachopc tc1:configPwfs1.C Nod A Chop C
   nodbchopa tc1:configPwfs1.D Nod B Chop A
   nodbchopb tc1:configPwfs1.E Nod B Chop B
   nodbchopc tc1:configPwfs1.F Nod B Chop C
   nodcchopa tc1:configPwfs1.G Nod C Chop A
   nodcchopb tc1:configPwfs1.H Nod C Chop B
   nodcchopc tc1:configPwfs1.I Nod C Chop C
}

command pwfs2Guide tcsApply P2 guide configuration
{
   nodachopa tc1:configPwfs2.A Nod A Chop A
   nodachopb tc1:configPwfs2.B Nod A Chop B
   nodachopc tc1:configPwfs2.C Nod A Chop C
   nodbchopa tc1:configPwfs2.D Nod B Chop A
   nodbchopb tc1:configPwfs2.E Nod B Chop B
   nodbchopc tc1:configPwfs2.F Nod B Chop C
   nodcchopa tc1:configPwfs2.G Nod C Chop A
   nodcchopb tc1:configPwfs2.H Nod C Chop B
   nodcchopc tc1:configPwfs2.I Nod C Chop C
}

command oiwfsGuide tcsApply OIWFS guide configuration
{
   nodachopa tc1:configOiwfs.A Nod A Chop A
   nodachopb tc1:configOiwfs.B Nod A Chop B
   nodachopc tc1:configOiwfs.C Nod A Chop C
   nodbchopa tc1:configOiwfs.D Nod B Chop A
   nodbchopb tc1:configOiwfs.E Nod B Chop B
   nodbchopc tc1:configOiwfs.F Nod B Chop C
   nodcchopa tc1:configOiwfs.G Nod C Chop A
   nodcchopb tc1:configOiwfs.H Nod C Chop B
   nodcchopc tc1:configOiwfs.I Nod C Chop C
}

command poriginA tcsApply Instrument origin A
{
   x tc1:poriginA.A X (mm)
   y tc1:poriginA.B Y (mm)
}

command poriginB tcsApply Instrument origin B
{
   x tc1:poriginB.A X (mm)
   y tc1:poriginB.B Y (mm)
}

command poriginC tcsApply Instrument origin C
{
   x tc1:poriginC.A X (mm)
   y tc1:poriginC.B Y (mm)
}

command poriginM tcsApply Mount instrument origin
{
   x tc1:poriginM.A X (mm)
   y tc1:poriginM.B Y (mm)
}

command rotator tcsApply Rotator configuration
{
   ipa tc1:rotator.A Position angle
   system tc1:rotator.B Reference frame
   equinox tc1:rotator.C Equinox
   iaa tc1:rotator.D Alignment angle
}

command slew tcsApply Slew
{
   chopThrow tc1:slew.A Zero chop throw
   sourceOffset tc1:slew.B Zero source offsets
   sourceDifTr tc1:slew.C Zero source differential track rates
   mountOffset tc1:slew.D Zero mount offsets
   mountDifTr tc1:slew.E Zero mount differential track rates
   filter1 tc1:slew.F Short circuit target filters
   filter2 tc1:slew.G Short circuit mount filters
   pointing tc1:slew.H Reset local pointing model adjustments
   guiding tc1:slew.I Stop guiding
   guideOffset tc1:slew.J Zero guide star offsets
   dummy tc1:slew.K Mark CAD
}

command orbit tcsApply Orbital elements
{
   eltype tc1:orbit.A Orbital element type
   epochofel tc1:orbit.B Epoch of elements (TT)
   inclination tc1:orbit.C Orbital inclination (deg)
   longascnode tc1:orbit.D Longitude of ascending node (deg)
   longofper tc1:orbit.E Longitude of perihelion (deg)
   argofper tc1:orbit.E Argument of perihelion (deg)
   meandist tc1:orbit.F Mean distance (AU)
   perdist tc1:orbit.F Perihelion distance (AU)
   eccentricity tc1:orbit.G Eccentricity
   meanlong tc1:orbit.H Mean longitude (deg)
   meananom tc1:orbit.H Mean anomaly (deg)
   dailymot tc1:orbit.I Daily motion (deg)
   objName tc1:orbit.J Object name
}

command planet tcsApply Solar system
{
   object tc1:planet.A object
}

command chopRelative tcsApply Relative chop
{
   throw tc1:chopRelative.A Throw
   angle tc1:chopRelative.B Position angle
   system tc1:chopRelative.C System
   equinox tc1:chopRelative.D Equinox
}
