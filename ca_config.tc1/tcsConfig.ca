command difTrMount tcsApply Mount differential track rate
{
   system tc1:difTrMount.A System
   equinox tc1:difTrMount.B Equinox
   epoch tc1:difTrMount.C Epoch (MJD TT)
   dtheta1 tc1:difTrMount.D RA/Az
   dtheta2 tc1:difTrMount.E Dec/El
}

