command dtelFocus tcsApply Optics configuration
{
   focusOffset tc1:dtelFocus.A Focus offset (mm)
}

command m2Baffle tcsApply Optics configuration
{
   deployBaffle tc1:m2Baffle.A Deployable baffle position
   centralBaffle tc1:m2Baffle.B Central baffle position
}
