status pcssad
{
   apssMsg             m1:apss:ctrlStatusMsg  0 APSS status message
   aosMsg              m1:aos:ctrlStatusMsg   0 AOS status message
   aoMoving            m1:aoMoving            0 Number of actuators moving
   pssInPos            m1:pss:inPosBO         0 APSS in position
   pssOn               m1:pssOn               0 PSS on
}
