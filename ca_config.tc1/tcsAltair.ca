#+
# tcsAltair.ca
#
# Channel access configuration file for tcs ALTAIR related commands.
#
# D Terrett 16 December 2002
#
# Copyright CCLRC
#-

command aoDeployAdc tcsApply Deploy ALTAIR ADC
{
   position  tc1:aoDeployAdc.A position
}

command aoMoveAdc tcsApply Move ALTAIR ADC
{
   rotpos    tc1:aoMoveAdc.A Cass rotator position
   zd        tc1:aoMoveAdc.B Zenith distance
   wavel     tc1:aoMoveAdc.C Central wavelength
   adjust    tc1:aoMoveAdc.D Adjust
}

command aoPrepareCm tcsApply Prepare ALTAIR control matrix
{
   x         tc1:aoPrepareCm.A Guide star x position
   y         tc1:aoPrepareCm.B Guide star y position
   seeing    tc1:aoPrepareCm.C Seeing estimate
   gsmag     tc1:aoPrepareCm.D Guide star magnitude
   windspeed tc1:aoPrepareCm.E Windspeed
}

command aoFlatten tcsApply Flatten ALTAIR science path.
{
   dummy     tc1:aoFlatten.A 
}

command aoFollow tcsApply ALTAIR stage follow
{
   followState tc1:aoFollow.A Follow state
}

command aoCentreWfs tcsApply Centre ALTAIR Wfs
{
   retain     tc1:aoCentreWfs.A Retain offsets
}

command aoCorrect tcsApply ALTAIR Image correction
{
   correct    tc1:aoCorrect.A Correction On/OFF
   matrix     tc1:aoCorrect.B Matrix ID
   gains      tc1:aoCorrect.C Reuse gains
}

command aoEntShutter tcsApply ALTAIR Entrance shutter
{
   state     tc1:aoEntShutter.A Shutter state
}

command aoExitShutter tcsApply ALTAIR Exit shutter
{
   state     tc1:aoExitShutter.A Shutter state
}

command aoDatum tcsApply ALTAIR datum
{
   dummy     tc1:aoDatum.A
}

command aoPark tcsApply ALTAIR park
{
   dummy     tc1:aoPark.A
}

command aoOiwfsSource tcsApply ALTAIR OIWFS source
{
   state     tc1:aoOiwfsSource.A   State
   bandwidth tc1:aoOiwfsSource.B   Bandwidth
}

command aoGimOffsets tcsApply ALTAIR Gimbal Offsets
{
   xoff      ao:wfcs:xOffset.VAL   X Offset
   yoff      ao:wfcs:yOffset.VAL   Y Offset
   zoff      ao:wfcs:zOffset.VAL   Z Offset
}

command aoNDFilter tcsApply ALTAIR ND Filter Position
{
   pos       ao:cc:ndfiltAssembly.A      Demanded position
   mode      ao:cc:ndfiltAssembly.MODE   Mode
   dir       ao:cc:ndfiltAssembly.DIR    Directive
}
