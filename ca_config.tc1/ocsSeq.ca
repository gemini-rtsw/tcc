command park tcsApply Park
{
   mark tc1:park.A Dummy field to mark CAD
}

command datum tcsApply Datum
{
   mark tc1:datum.A Dummy field to mark CAD
}

command init tcsApply Initialize
{
   mark tc1:init.A Dummy field to mark CAD
}

command reboot tcsApply Reboot
{
   mark tc1:reboot.A Dummy field to mark CAD
}

command test tcsApply Self test
{
   mark tc1:test.A Dummy field to mark CAD
}
