# Define the NIRI apply record.

# Note that this file defines connections to the detector controller instead
# of the NIRI sequencer and should change when the detector controller can
# be commanded through the sequencer.

apply niriApply niri:dc:apply niri:dc:applyC Primary NIRI Apply Record

# NIRI observe command

command niriObserve niriApply Start exposure
{
   dummy        niri:dc:observe.A
   datalab      niri:dc:observeDetails.C
}

status niri
{
   observe   niri:dc:observeC.VAL   0  Observe progress
}

# this is used to estimate the timeout on observe action
status niriTiming
{
   numCoAdds   niri:dc:obsSetup.VALE  0  numCoAdds
   intTime     niri:dc:obsSetup.VALG  0  intTime
   minInt      niri:dc:minInt.VAL     0  minInt
}
