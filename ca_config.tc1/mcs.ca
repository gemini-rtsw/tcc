#-

command telstop tcsApply Stop
{
   stopAxis tc1:telstop.A Axis to stop
   azBrakes tc1:telstop.B Az brake
   elBrakes tc1:telstop.C El brake
}

command telpark	tcsApply Park mount
{
   dummy tc1:telpark.A Dummy field to mark CAD
}

command mountDatum tcsApply Datum
{
   datumAxis  tc1:mountDatum.A Axis to datum
   azDevice   tc1:mountDatum.B Az device
   elDevice   tc1:mountDatum.C El device
}

command elevation tcsApply Move elevation
{
   el tc1:elevation.A Elevation (deg)
}

command azimuth tcsApply Move azimuth
{
   az tc1:azimuth.A Azimuth (deg)
}

command azel tcsApply Move both
{
   az tc1:azel.A Azimuth (deg)
   el tc1:azel.B Elevation (deg)
}

command azConfig tcsApply Configure azimuth encoders
{
   azAlgorithm tc1:azConfig.A Algorithm
}

command elConfig tcsApply Configure elevation encoders
{
   elAlgorithm tc1:elConfig.A Algorithm
}

command mountLog tcsApply Control fast data logging
{
   sampFreq tc1:mountLog.B Sampling Frequency (Hz)
   switch tc1:mountLog.C Logging state
}

command mountTolerance tcsApply Set tolerances
{
   azPosError tc1:mountTolerance.A Azimuth position error (deg)
   azVelError tc1:mountTolerance.B Azimuth velocity error (deg/s)
   elPosError tc1:mountTolerance.C Elevation position error (deg)
   elVelError tc1:mountTolerance.D Elevation velocity error (deg/s)
}
