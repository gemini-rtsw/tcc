command m1Guide tcsApply Define primary guiding mode
{
   mode       tc1:m1GuideMode.A Guiding mode
   weighting  tc1:m1GuideConfig.A Weighting
   pwfs1      tc1:m1GuideConfig.B PWFS1 weighting
   pwfs2      tc1:m1GuideConfig.C PWFS2 weighting
   frames     tc1:m1GuideConfig.D Number of frames to average
}

command mountGuide tcsApply Define mount guiding mode
{
   mode       tc1:mountGuideMode.A Guiding mode
   source     tc1:mountGuideMode.B Guide Source
   p1weight   tc1:mountGuideMode.C PWFS1 weighting
   p2weight   tc1:mountGuideMode.D PWFS2 weighting
}
