#+
# tcsGuide.ca
#
# Channel access configuration file for tcs guiding and chopping related 
# commands.
#
# D Terrett 26 June 2003
#
# Copyright CCLRC
#-

command m1Guide tcsApply M1 guiding
{
   mode       tc1:m1GuideMode.A Mode
}

command m1GuideConfig tcsApply Define M1 guiding
{
   weighting  tc1:m1GuideConfig.A Weighting
   source     tc1:m1GuideConfig.B Signal source
   frames     tc1:m1GuideConfig.C Frames to average
   filename   tc1:m1GuideConfig.D Filename for HRWFS
}

command mountGuide tcsApply Define mount guiding
{
   mode       tc1:mountGuideMode.A Mode
   source     tc1:mountGuideMode.B Guide Source
   p1weight   tc1:mountGuideMode.C P1 weight
   p2weight   tc1:mountGuideMode.D P2 weight
}

command m2Guide tcsApply M2 Guiding
{
   state      tc1:m2GuideControl.A State
}

command m2GuideMode tcsApply M2 GuideMode
{
   coma      tc1:m2GuideMode.B Coma correction
}

command m2GuideConfig tcsApply Define M2 guiding
{
   source     tc1:m2GuideConfig.A Guiding source
   samplefreq tc1:m2GuideConfig.B Sample frequency
   filter     tc1:m2GuideConfig.C Filter type
   freq1      tc1:m2GuideConfig.D Frequency 1
   freq2      tc1:m2GuideConfig.E Frequency 2
   beam       tc1:m2GuideConfig.F Beam
   reset      tc1:m2GuideConfig.G reset
}

command wfsGuideMode tcsApply WFS Guide Mode
{
   state      tc1:wfsGuideMode.A State
   probe      tc1:wfsGuideMode.B Probe
}

command pwfs1Observe tcsApply Start P1
{
   noexp      tc1:pwfs1Observe.A      Exposures
   int        tc1:pwfs1Observe.B      interval
   outopt     tc1:pwfs1Observe.C      Output options
   label      tc1:pwfs1Observe.D      DHS label
   output     tc1:pwfs1Observe.E      DHS output
   path       tc1:pwfs1Observe.F      Path
   name       tc1:pwfs1Observe.G      Filename
}

command pwfs1StopObserve tcsApply Stop P1
{
   dummy      tc1:pwfs1StopObserve.A
}

command pwfs2Observe tcsApply Start P2
{
   noexp      tc1:pwfs2Observe.A      Exposures
   int        tc1:pwfs2Observe.B      Interval
   outopt     tc1:pwfs2Observe.C      Output options
   label      tc1:pwfs2Observe.D      DHS label
   output     tc1:pwfs2Observe.E      DHS output
   path       tc1:pwfs2Observe.F      Path
   name       tc1:pwfs2Observe.G      Filename
}

command pwfs2StopObserve tcsApply Stop P2
{
   dummy      tc1:pwfs2StopObserve.A
}

command oiwfsObserve tcsApply Start OIWFS
{
   noexp      tc1:oiwfsObserve.A      Exposures
   int        tc1:oiwfsObserve.B      Interval
   outopt     tc1:oiwfsObserve.C      Output options
   label      tc1:oiwfsObserve.D      DHS label
   output     tc1:oiwfsObserve.E      DHS output
   path       tc1:oiwfsObserve.F      Path
   name       tc1:oiwfsObserve.G      Filename
}

command oiwfsStopObserve tcsApply Stop OIWFS
{
   dummy      tc1:oiwfsStopObserve.A
}

status guideConfig
{
   p1state    tc1:drives:p1Integrating.VAL  0   P1 integrating
   p2state    tc1:drives:p2Integrating.VAL  0   P2 integrating
   oistate    tc1:drives:oiIntegrating.VAL  0   OI integrating
   aostate    tc1:ao:wfcs:loopRunning       0   AO integrating
   m2state    tc1:om:m2GuideState.VAL       0   M2 guiding
   absorbtilt tc1:absorbTipTiltFlag.VAL     0   Absorb tilt errors
   m1state    tc1:im:m1GuideOn.VAL          0   M1 guiding
   m1source   tc1:m1GuideConfig.VALB        0   M1 guide source
   p1guide    tc1:ak:wfsguide:p1weight.VAL  0   WFS guiding
   p2guide    tc1:ak:wfsguide:p2weight.VAL  0   WFS guiding
   p1mweight  tc1:mountGuideMode.VALC       0   Mount p1 wieght
   p2mweight  tc1:mountGuideMode.VALD       0   Mount p1 wieght
   m2p1guide  tc1:drives:p1GuideConfig      0   M2 P1 guide config
   m2p2guide  tc1:drives:p2GuideConfig      0   M2 P2 guide config
   m2oiguide  tc1:drives:oiGuideConfig      0   M2 OI guide config
   m2aoguide  tc1:drives:aoGuideConfig      0   M2 AO guide config
   coma       tc1:im:m2gm:comaCorrectFlag.VAL 0 Coma correction
}

command m2beam tcsApply M2 beam
{
   m2Beam     tc1:m2Beam.A           Beam
}

command chop tcsApply Chop
{
   chop       tc1:chop.A             State
   decs       tc1:chop.B             DECS
}

command nod tcsApply Nod
{
   nod        tc1:nod.A              State
}

status pwfs1Guide
{
   nodachopa tc1:configPwfs1.VALA 0 Nod A Chop A
   nodachopb tc1:configPwfs1.VALB 0 Nod A Chop B
   nodachopc tc1:configPwfs1.VALC 0 Nod A Chop C
   nodbchopa tc1:configPwfs1.VALD 0 Nod B Chop A
   nodbchopb tc1:configPwfs1.VALE 0 Nod B Chop B
   nodbchopc tc1:configPwfs1.VALF 0 Nod B Chop C
   nodcchopa tc1:configPwfs1.VALG 0 Nod C Chop A
   nodcchopb tc1:configPwfs1.VALH 0 Nod C Chop B
   nodcchopc tc1:configPwfs1.VALI 0 Nod C Chop C
}

status pwfs2Guide
{
   nodachopa tc1:configPwfs2.VALA 0 Nod A Chop A
   nodachopb tc1:configPwfs2.VALB 0 Nod A Chop B
   nodachopc tc1:configPwfs2.VALC 0 Nod A Chop C
   nodbchopa tc1:configPwfs2.VALD 0 Nod B Chop A
   nodbchopb tc1:configPwfs2.VALE 0 Nod B Chop B
   nodbchopc tc1:configPwfs2.VALF 0 Nod B Chop C
   nodcchopa tc1:configPwfs2.VALG 0 Nod C Chop A
   nodcchopb tc1:configPwfs2.VALH 0 Nod C Chop B
   nodcchopc tc1:configPwfs2.VALI 0 Nod C Chop C
}

status oiwfsGuide
{
   nodachopa tc1:configOiwfs.VALA 0 Nod A Chop A
   nodachopb tc1:configOiwfs.VALB 0 Nod A Chop B
   nodachopc tc1:configOiwfs.VALC 0 Nod A Chop C
   nodbchopa tc1:configOiwfs.VALD 0 Nod B Chop A
   nodbchopb tc1:configOiwfs.VALE 0 Nod B Chop B
   nodbchopc tc1:configOiwfs.VALF 0 Nod B Chop C
   nodcchopa tc1:configOiwfs.VALG 0 Nod C Chop A
   nodcchopb tc1:configOiwfs.VALH 0 Nod C Chop B
   nodcchopc tc1:configOiwfs.VALI 0 Nod C Chop C
}
