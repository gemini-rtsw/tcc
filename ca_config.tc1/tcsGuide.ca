command m1Guide tcsApply Define primary guiding mode
{
   mode       tc1:m1GuideMode.A Guiding mode
   weighting  tc1:m1GuideConfig.A Weighting
   pwfs1      tc1:m1GuideConfig.B PWFS1 weighting
   pwfs2      tc1:m1GuideConfig.C PWFS2 weighting
   frames     tc1:m1GuideConfig.D Number of frames to average
}

command mountGuide tcsApply Define mount guiding mode
{
   mode       tc1:mountGuideMode.A Guiding mode
   source     tc1:mountGuideMode.B Guide Source
   p1weight   tc1:mountGuideMode.C PWFS1 weighting
   p2weight   tc1:mountGuideMode.D PWFS2 weighting
}

command m2Guide tcsApply M2 Guide Control
{
   state      tc1:m2GuideControl.A Guiding state
}

command pwfs1Observe tcsApply Start PWFS1
{
   noexp      tc1:pwfs1Observe.A      Number of exposures
   int        tc1:pwfs1Observe.B      Exposure interval
   outopt     tc1:pwfs1Observe.C      Output options
   label      tc1:pwfs1Observe.D      DHS label
   output     tc1:pwfs1Observe.E      DHS output
   path       tc1:pwfs1Observe.F      Path
   name       tc1:pwfs1Observe.G      File name
}

command pwfs1StopObserve tcsApply Stop PWFS1
{
   dummy      tc1:pwfs1StopObserve.A  Stop observation
}

command pwfs2Observe tcsApply Start PWFS2
{
   noexp      tc1:pwfs2Observe.A      Number of exposures
   int        tc1:pwfs2Observe.B      Exposure interval
   outopt     tc1:pwfs2Observe.C      Output options
   label      tc1:pwfs2Observe.D      DHS label
   output     tc1:pwfs2Observe.E      DHS output
   path       tc1:pwfs2Observe.F      Path
   name       tc1:pwfs2Observe.G      File name
}

command pwfs2StopObserve tcsApply Stop PWFS2
{
   dummy      tc1:pwfs2StopObserve.A  Stop observation
}

command oiwfsObserve tcsApply Start OIWFs
{
   noexp      tc1:oiwfsObserve.A      Number of exposures
   int        tc1:oiwfsObserve.B      Exposure interval
   outopt     tc1:oiwfsObserve.C      Output options
   label      tc1:oiwfsObserve.D      DHS label
   output     tc1:oiwfsObserve.E      DHS output
   path       tc1:oiwfsObserve.F      Path
   name       tc1:oiwfsObserve.G      File name
}

command oiwfsStopObserve tcsApply Stop OIWFS
{
   dummy      tc1:oiwfsStopObserve.A  Stop observation
}

status guideConfig
{
   p1state    tc1:drives:p1Integrating.VAL  0   P1 integrating
   p2state    tc1:drives:p2Integrating.VAL  0   P2 integrating
   oistate    tc1:drives:oiIntegrating.VAL  0   OI integrating
   m2state    tc1:om:m2GuideState.VAL       0   M2 guiding
   absorbtilt tc1:absorbTipTiltFlag.VAL     0   Absorb tilt errors
   m1state    tc1:im:m1GuideOn.VAL          0   M1 guiding
}
