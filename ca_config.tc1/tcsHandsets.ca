command tarHandConfig tcsApply Target offset handset configuration
{
   step       tc1:tarHandConfig.A Step size
   tel        tc1:tarHandConfig.B Telescope set
   inctype    tc1:tarHandConfig.C Increment type
}

command tarHandset tcsApply Target offset handset
{
   direction  tc1:tarHandset.A    Step offsets in specified direction
}

command poHandConfig tcsApply pointign origin handset configuration
{
   step       tc1:poHandConfig.A Step size
   tel        tc1:poHandConfig.B Telescope set
}

command poHandset tcsApply pointign origin handset
{
   direction  tc1:poHandset.A    Step offsets in specified direction
}

command guideHandConfig tcsApply guide handset configuration
{
   step       tc1:guideHandConfig.A Step size
}

command guideHandset tcsApply guide handset
{
   direction  tc1:guideHandset.A    Step offsets in specified direction
}
