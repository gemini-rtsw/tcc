command tarHandConfig tcsApply Configure target handset
{
   step       tc1:tarHandConfig.A Step size
   tel        tc1:tarHandConfig.B Telescope set
   inctype    tc1:tarHandConfig.C Increment type
}

command tarHandset tcsApply Target handset
{
   direction  tc1:tarHandset.A    Direction
}

command poHandConfig tcsApply Configure instrument origin handset
{
   step       tc1:poHandConfig.A Step size
   tel        tc1:poHandConfig.B Telescope set
}

command poHandset tcsApply Instrument origin handset
{
   direction  tc1:poHandset.A    Direction
}

command guideHandConfig tcsApply Configure guide handset
{
   step       tc1:guideHandConfig.A Step size
}

command guideHandset tcsApply Guide handset
{
   direction  tc1:guideHandset.A    Direction
}
