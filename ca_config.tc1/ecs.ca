#+
# ecs.ca
#
# Channel access configuration file for the ecs subsystem commands.
#
# D Terrett 6 June 2000
#
# Copyright CCLRC
#-

command encThermal tcsApply Set enclosure thermal control
{
   mode tc1:encThermal.A Mode
}

command carousel tcsApply Set enclosure mode
{
   domemode tc1:carouselMode.A Dome mode
   shuttermode tc1:carouselMode.B Shutter mode
   slit tc1:carouselMode.C Slit height
   dome tc1:carouselMode.D Dome enable
   shutter tc1:carouselMode.E Shutter enable
}

command enclosureStop tcsApply Stop enclosure
{
   dummy tc1:enclosureStop.A
}

command enclosurePark	tcsApply Park enclosure
{
   dummy tc1:enclosurePark.A
}

command enclosureDatum tcsApply Datum enclosure
{
   dummy tc1:enclosureDatum.A
}

command carouselStop tcsApply Stop carousel
{
   dummy tc1:carouselStop.A
}

command carouselPark	tcsApply Park carousel
{
   parkpos tc1:carouselPark.A Park position
   azimuth tc1:carouselPark.B Azimuth
}

command carouselMove tcsApply Move carousel
{
   azimuth tc1:carousel.A Azimuth
}

command shutterStop tcsApply Stop shutters
{
   dummy tc1:shutterStop.A
}

command shutterPark	tcsApply Park shutters
{
   dummy tc1:shutterPark.A
}

command shutterDatum tcsApply Datum shutters
{
   dummy tc1:shutterDatum.A
}

command shutters tcsApply Move shutters
{
   top tc1:shutter.A Top position
   bottom tc1:shutter.B Bottom position
}

command ventgatesStop tcsApply Stop vent gates
{
   dummy tc1:ventGatesStop.A
}

command ventgatesPark	tcsApply Park vent gates
{
   dummy tc1:ventGatesPark.A
}

command ventgates tcsApply Move vent gates
{
   east tc1:ventgates.A East gate opening
   west tc1:ventgates.B West gate opening
}

command enclosureInit tcsApply Init enclosure
{
   dummy tc1:enclosureInit.A
}
