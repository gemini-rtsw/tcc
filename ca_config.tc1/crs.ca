command rotStop tcsApply Stop rotator
{
   dummy tc1:rotStop.A
}

command rotPark	tcsApply Park rotator
{
   dummy tc1:rotPark.A
}

command rotDatum tcsApply Datum rotator
{
   dummy tc1:rotDatum.A
}

command rotMove tcsApply Move rotator
{
   rma tc1:rotMove.A Mechanical angle
}

command rotConfig tcsApply Configure rotator encoders
{
   algorithm tc1:rotConfig.A Algorithm
   headid    tc1:rotConfig.B Head ID
}

command rotTolerance tcsApply Set rotator tolerances
{
   posError tc1:rotTolerance.A Position error
   velError tc1:rotTolerance.B Velocity error
}
