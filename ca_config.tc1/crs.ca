command rotstop tcsApply Stop
{
   dummy tc1:rotStop.A Dummy field to mark CAD
}

command rotpark	tcsApply Park
{
   dummy tc1:rotPark.A Dummy field to mark CAD
}

command rotdatum tcsApply Datum
{
   dummy tc1:rotDatum.A Dummy field to mark CAD
}

command rotmove tcsApply Move
{
   rma tc1:rotMove.A Mechanical angle
}

command rotconfig tcsApply Configure encoders
{
   algorithm tc1:rotConfig.A Algorithm
   headid    tc1:rotConfig.B Head ID
}

command rotTolerance tcsApply Set tolerances
{
   posError tc1:rotTolerance.A Position error (deg)
   velError tc1:rotTolerance.B Velocity error (deg/s)
}
