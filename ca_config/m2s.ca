command dtelFocus tcsApply Optics configuration
{
   focusOffset tcs:dtelFocus.A Focus offset (mm)
}

command m2Baffle tcsApply Optics configuration
{
   deployBaffle tcs:m2Baffle.A Deployable baffle position
   centralBaffle tcs:m2Baffle.B Central baffle position
}

command m2Park tcsApply Park
{
   dummy tcs:m2Park.A Dummy field to mark CAD
}

command m2Init tcsApply Init
{
   dummy tcs:m2Init.A Dummy field to mark CAD
}
