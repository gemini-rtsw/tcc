#+
# tcs.ca
#
# Channel access configuration file for miscellaneous tcs commands.
#
# D Terrett 12 October 1998
#
# Copyright CCLRC
#-

command azwrap tcsApply Set azimuth wrap flag
{
   flag tcs:azwrap.A Azimuth wrap flag
}

command rotwrap tcsApply Set rotator wrap flag
{
   flag tcs:rotwrap.A Rotator wrap flag
}

command follow tcsApply Follow
{
   mcs tcs:follow.A MCS
   crs tcs:follow.B CRS
   ecs tcs:follow.C ECS
   ag1 tcs:follow.D PWFS1
   ag2 tcs:follow.E PWFS2
   ago tcs:follow.F OIWFS
   scs tcs:follow.G SCS
   aos tcs:follow.H AOS
}

command weather tcsApply Weather data
{
   source tcs:useWS.A Source
   temp tcs:temperature.A Temp (deg C)
   press tcs:pressure.A Pressure (mbar)
   humid tcs:humidity.A Humidity (%)
}

command airmassLimit tcsApply Set airmass limit
{
   limit tcs:airmassLimit.A Limit
}

command pointLog tcsApply log pointing
{
   log      tcs:pointLog.A Dummy field to mark CAD
}

command absorbGuide tcsApply Absorb guide adjustments
{
   mark     tcs:absorbGuide.A Dummy field to mark CAD
}

command zeroGuide tcsApply Zero guide adjustments
{
   mark     tcs:zeroGuide.A Dummy field to mark CAD
}

command absorbOffset tcsApply Absorb offsets
{
   vt       tcs:absorbOffset.A  Virtual telescope mask
   index    tcs:absorbOffset.B  Offset index
}

command clearOffset tcsApply Clear offsets
{
   vt       tcs:clearOffset.A  Virtual telescope mask
   index    tcs:clearOffset.B  Offset index
}

command incrOffset tcsApply Increment offsets
{
   theta1   tcs:incrOffset.A   Offset in RA/Az
   theta2   tcs:incrOffset.B   Offset in Dec/El
   vt       tcs:incrOffset.C   Virtual telescope mask
   type     tcs:incrOffset.D   Tangent Plane or RA/Dec
}

command absorbPoOffset tcsApply Absorb pointing origin offsets
{
   vt       tcs:absorbPoOffset.A  Virtual telescope mask
   index    tcs:absorbPoOffset.B  Offset index
}

command clearPoOffset tcsApply Clear pointing origin offsets
{
   vt       tcs:clearPoOffset.A  Virtual telescope mask
   index    tcs:clearPoOffset.B  Offset index
}

command pointParam tcsApply Set pointing model parameter
{
   name     tcs:pointParam.A     Name
   level    tcs:pointParam.B     Level
   value    tcs:pointParam.C     Value
}

command timeParam tcsApply Set time system parameter
{
   name     tcs:timeParam.A     Name
   value    tcs:timeParam.B     Value
}
