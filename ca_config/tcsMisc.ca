#+
# tcsMisc.ca
#
# Channel access configuration file for miscellaneous tcs commands.
#
# D Terrett 4 October 2000
#
# Copyright CCLRC
#-

command wrap tcsApply Wrap flags
{
   azimuth tcs:azwrap.A Azimuth
   rotator tcs:rotwrap.A Rotator
}

command mcFollow tcsApply Mount following
{
   followState tcs:mcFollow.A State
}

command crFollow tcsApply Rotator following
{
   followState tcs:crFollow.A State
}

command p1Follow tcsApply PWFS1 probe following
{
   followState tcs:pwfs1Follow.A State
}

command p2Follow tcsApply PWFS2 probe following
{
   followState tcs:pwfs2Follow.A State
}

command oiFollow tcsApply OIWFS probe following
{
   followState tcs:oiwfsFollow.A State
}

command m2Follow tcsApply M2 following
{
   followState tcs:m2Follow.A State
}

command aoFollow tcsApply AOS probe following
{
   followState tcs:aoFollow.A State
}

command weather tcsApply Weather data
{
   source tcs:useWS.A Source
   temp tcs:temperature.A Temp (deg C)
   press tcs:pressure.A Pressure (mbar)
   humid tcs:humidity.A Humidity (%)
}

command airmassLimit tcsApply Airmass
{
   limit tcs:airmassLimit.A Limit
}

command pointLog tcsApply Log pointing data
{
   log      tcs:pointLog.A
}

command absorbGuide tcsApply Absorb guide adjustments
{
   dummy     tcs:absorbGuide.A
}

command zeroGuide tcsApply Zero guide adjustments
{
   dummy     tcs:zeroGuide.A
}

command absorbOffset tcsApply Absorb offsets
{
   vt       tcs:absorbOffset.A  Virtual telescope mask
   index    tcs:absorbOffset.B  Offset index
}

command clearOffset tcsApply Clear offsets
{
   vt       tcs:clearOffset.A  Virtual telescope mask
   index    tcs:clearOffset.B  Offset index
}

command incrOffset tcsApply Increment offsets
{
   theta1   tcs:incrOffset.A   RA/Az
   theta2   tcs:incrOffset.B   Dec/El
   vt       tcs:incrOffset.C   Virtual telescope mask
   type     tcs:incrOffset.D   Type
   ind      tcs:incrOffset.E   Index
}

command absorbPoOffset tcsApply Absorb instrument origin offsets
{
   vt       tcs:absorbPoOffset.A  Virtual telescope mask
   index    tcs:absorbPoOffset.B  Offset index
}

command clearPoOffset tcsApply Clear instrument origin offsets
{
   vt       tcs:clearPoOffset.A  Virtual telescope mask
   index    tcs:clearPoOffset.B  Offset index
}

command pointParam tcsApply Pointing model parameter
{
   name     tcs:pointParam.A     Name
   level    tcs:pointParam.B     Model
   value    tcs:pointParam.C     Value
}

command timeParam tcsApply Time system parameter
{
   name     tcs:timeParam.A     Name
   value    tcs:timeParam.B     Value
}

command chopConfig tcsApply Chop configuration
{
   type      tcs:chopConfig.A    Type
   source    tcs:chopConfig.B    Sync source
   frequency tcs:chopConfig.C    Frequency
   dutycycle tcs:chopConfig.D    Duty cycle
}

command offsetPoA1 tcsApply Offset pointing origin A1
{
   x tcs:offsetPoA1.A 0 X
   y tcs:offsetPoA1.B 0 Y
}

command offsetPoB1 tcsApply Offset pointing origin B1
{
   x tcs:offsetPoB1.A 0 X
   y tcs:offsetPoB1.B 0 Y
}

command offsetPoC1 tcsApply Offset pointing origin C1
{
   x tcs:offsetPoC1.A 0 X
   y tcs:offsetPoC1.B 0 Y
}
