{
   system tcs:trackSourceB.A System
   equinox tcs:trackSourceB.B Equinox
}

command trackSourceC tcsApply Set source C tracking frame
{
   system tcs:trackSourceC.A System
   equinox tcs:trackSourceC.B Equinox
}

command trackPwfs1 tcsApply Set pwfs1 tracking frame
{
