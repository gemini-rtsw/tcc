{
   wavel tcs:wavelPwfs2.A Wavelength (mu)
}

command wavelOiwfs tcsApply Set oiwfs effective wavelength
{
   wavel tcs:wavelOiwfs.A Wavelength (mu)
}

command difTrSourceA tcsApply Set source A differential track rates
{
   system tcs:difTrSourceA.A System
   equinox tcs:difTrSourceA.B Equinox
   epoch tcs:difTrSourceA.C Epoch (MJD TT)
   dtheta1 tcs:difTrSourceA.D Rate in RA or Azimuth
   dtheta2 tcs:difTrSourceA.E Rate in Dec or Elevation
}

command difTrSourceB tcsApply Set source B differential track rates
{
   system tcs:difTrSourceB.A System
   equinox tcs:difTrSourceB.B Equinox
