command pwfs1Guide tcsApply P1 guide configuration
{
   nodachopa tcs:configPwfs1.A Nod A Chop A
   nodachopb tcs:configPwfs1.B Nod A Chop B
   nodachopc tcs:configPwfs1.C Nod A Chop C
   nodbchopa tcs:configPwfs1.D Nod B Chop A
   nodbchopb tcs:configPwfs1.E Nod B Chop B
   nodbchopc tcs:configPwfs1.F Nod B Chop C
   nodcchopa tcs:configPwfs1.G Nod C Chop A
   nodcchopb tcs:configPwfs1.H Nod C Chop B
   nodcchopc tcs:configPwfs1.I Nod C Chop C
}

command pwfs2Guide tcsApply P2 guide configuration
{
   nodachopa tcs:configPwfs2.A Nod A Chop A
   nodachopb tcs:configPwfs2.B Nod A Chop B
   nodachopc tcs:configPwfs2.C Nod A Chop C
   nodbchopa tcs:configPwfs2.D Nod B Chop A
   nodbchopb tcs:configPwfs2.E Nod B Chop B
   nodbchopc tcs:configPwfs2.F Nod B Chop C
   nodcchopa tcs:configPwfs2.G Nod C Chop A
   nodcchopb tcs:configPwfs2.H Nod C Chop B
   nodcchopc tcs:configPwfs2.I Nod C Chop C
}

command oiwfsGuide tcsApply OIWFS guide configuration
{
   nodachopa tcs:configOiwfs.A Nod A Chop A
   nodachopb tcs:configOiwfs.B Nod A Chop B
   nodachopc tcs:configOiwfs.C Nod A Chop C
   nodbchopa tcs:configOiwfs.D Nod B Chop A
   nodbchopb tcs:configOiwfs.E Nod B Chop B
   nodbchopc tcs:configOiwfs.F Nod B Chop C
   nodcchopa tcs:configOiwfs.G Nod C Chop A
   nodcchopb tcs:configOiwfs.H Nod C Chop B
   nodcchopc tcs:configOiwfs.I Nod C Chop C
}

command poriginA tcsApply Instrument origin A
{
   x tcs:poriginA.A X (mm)
   y tcs:poriginA.B Y (mm)
}

command poriginB tcsApply Instrument origin B
{
   x tcs:poriginB.A X (mm)
   y tcs:poriginB.B Y (mm)
}

command poriginC tcsApply Instrument origin C
{
   x tcs:poriginC.A X (mm)
   y tcs:poriginC.B Y (mm)
}

command poriginM tcsApply Mount instrument origin
{
   x tcs:poriginM.A X (mm)
   y tcs:poriginM.B Y (mm)
}

command rotator tcsApply Rotator configuration
{
   ipa tcs:rotator.A Position angle
   system tcs:rotator.B Reference frame
   equinox tcs:rotator.C Equinox
   iaa tcs:rotator.D Alignment angle
}

command slew tcsApply Slew
{
   chopThrow tcs:slew.A Zero chop throw
   sourceOffset tcs:slew.B Zero source offsets
   sourceDifTr tcs:slew.C Zero source differential track rates
   mountOffset tcs:slew.D Zero mount offsets
   mountDifTr tcs:slew.E Zero mount differential track rates
   filter1 tcs:slew.F Short circuit target filters
   filter2 tcs:slew.G Short circuit mount filters
   pointing tcs:slew.H Reset local pointing model adjustments
   guiding tcs:slew.I Stop guiding
   guideOffset tcs:slew.J Zero guide star offsets
   instrOffset tcs:slew.K Zero instrument offsets
   dummy tcs:slew.L Mark CAD
}

command orbit tcsApply Orbital elements
{
   eltype tcs:orbit.A Orbital element type
   epoch tcs:orbit.B Epoch of elements (TT)
   inclination tcs:orbit.C Orbital inclination (deg)
   anode tcs:orbit.D Longitude of ascending node (deg)
   perihelion tcs:orbit.E Longitude or argument of perihelion (deg)
   aorq tcs:orbit.F Mean or perihelion distance (AU)
   e tcs:orbit.G Eccentricity
   LorM tcs:orbit.H Mean longitude or anomaly (deg)
   n tcs:orbit.I Daily motion (deg)
   objName tcs:orbit.J Object name
}

command planet tcsApply Solar system
{
   object tcs:planet.A object
}

command chopRelative tcsApply Relative chop
{
   throw tcs:chopRelative.A Throw
   angle tcs:chopRelative.B Position angle
   system tcs:chopRelative.C System
   equinox tcs:chopRelative.D Equinox
}
