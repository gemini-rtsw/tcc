command pwfs1Guide tcsApply Set pwfs1 guide configuration
{
   nodachopa tcs:configPwfs1.A Nod A Chop A enable
   nodachopb tcs:configPwfs1.B Nod A Chop B enable
   nodachopc tcs:configPwfs1.C Nod A Chop C enable
   nodbchopa tcs:configPwfs1.D Nod B Chop A enable
   nodbchopb tcs:configPwfs1.E Nod B Chop B enable
   nodbchopc tcs:configPwfs1.F Nod B Chop C enable
   nodcchopa tcs:configPwfs1.G Nod C Chop A enable
   nodcchopb tcs:configPwfs1.H Nod C Chop B enable
   nodcchopc tcs:configPwfs1.I Nod C Chop C enable
}

command pwfs2Guide tcsApply Set pwfs2 guide configuration
{
   nodachopa tcs:configPwfs2.A Nod A Chop A enable
   nodachopb tcs:configPwfs2.B Nod A Chop B enable
   nodachopc tcs:configPwfs2.C Nod A Chop C enable
   nodbchopa tcs:configPwfs2.D Nod B Chop A enable
   nodbchopb tcs:configPwfs2.E Nod B Chop B enable
   nodbchopc tcs:configPwfs2.F Nod B Chop C enable
   nodcchopa tcs:configPwfs2.G Nod C Chop A enable
   nodcchopb tcs:configPwfs2.H Nod C Chop B enable
   nodcchopc tcs:configPwfs2.I Nod C Chop C enable
}

command oiwfsGuide tcsApply Set oiwfs guide configuration
{
   nodachopa tcs:configOiwfs.A Nod A Chop A enable
   nodachopb tcs:configOiwfs.B Nod A Chop B enable
   nodachopc tcs:configOiwfs.C Nod A Chop C enable
   nodbchopa tcs:configOiwfs.D Nod B Chop A enable
   nodbchopb tcs:configOiwfs.E Nod B Chop B enable
   nodbchopc tcs:configOiwfs.F Nod B Chop C enable
   nodcchopa tcs:configOiwfs.G Nod C Chop A enable
   nodcchopb tcs:configOiwfs.H Nod C Chop B enable
   nodcchopc tcs:configOiwfs.I Nod C Chop C enable
}

command poriginA tcsApply Set pointing origin A
{
   x tcs:poriginA.A X (mm)
   y tcs:poriginA.B Y (mm)
}

command poriginB tcsApply Set pointing origin B
{
   x tcs:poriginB.A X (mm)
   y tcs:poriginB.B Y (mm)
}

command poriginC tcsApply Set pointing origin B
{
   x tcs:poriginC.A X (mm)
   y tcs:poriginC.B Y (mm)
}

command poriginM tcsApply Set mount pointing origin
{
   x tcs:poriginM.A X (mm)
   y tcs:poriginM.B Y (mm)
}

command rotator tcsApply Set rotator configuration
{
   ipa tcs:rotator.A Position angle (deg)
   system tcs:rotator.B Reference frame
   equinox tcs:rotator.C Equinox of reference frame
   iaa tcs:rotator.D Alignment angle (deg)
}

command slew tcsApply Set slew options
{
   chopThrow tcs:slew.A Zero chop throw
   sourceOffset tcs:slew.B Zero source offsets
   sourceDifTr tcs:slew.C Zero source differential track rates
   mountOffset tcs:slew.D Zero mount offsets
   mountDifTr tcs:slew.E Zero mount differential track rates
   filter1 tcs:slew.F Short circuit target filters
   filter2 tcs:slew.G Short circuit mount filters
   pointing tcs:slew.H Reset local pointing model adjustments
   guiding tcs:slew.I Stop guiding
   mark tcs:slew.J Mark CAD
}

command orbit tcsApply Set orbital elements
{
   eltype tcs:orbit.A Orbital element type
   epochofel tcs:orbit.B Epoch of elements (TT)
   inclination tcs:orbit.C Orbital inclination (deg)
   longascnode tcs:orbit.D Longitude of ascending node (deg)
   longofper tcs:orbit.E Longitude of perihelion (deg)
   argofper tcs:orbit.E Argument of perihelion (deg)
   meandist tcs:orbit.F Mean distance (AU)
   perdist tcs:orbit.F Perihelion distance (AU)
   eccentricity tcs:orbit.G Eccentricity
   meanlong tcs:orbit.H Mean longitude (deg)
   meananom tcs:orbit.H Mean anomaly (deg)
   dailymot tcs:orbit.I Daily motion (deg)
   objName tcs:orbit.J Object name
}

command chopRelative tcsApply Set relative chopping
{
   throw tcs:chopRelative.A Chop throw
   angle tcs:chopRelative.B Position angle
   system tcs:chopRelative.C System
   equinox tcs:chopRelative.D Equinox
}
