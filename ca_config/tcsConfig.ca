command offsetSourceA1 tcsApply Offset source A 1
{
   type     tcs:offsetSourceA1.A type
   dtheta1  tcs:offsetSourceA1.B RA/Az
   dtheta2  tcs:offsetSourceA1.C Dec/El
}

