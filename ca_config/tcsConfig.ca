command mount tcsApply Set mount target
{
   objName tcs:mount.A Object name
   system tcs:mount.B System
   theta1 tcs:mount.C RA or Azimuth
   theta2 tcs:mount.D Dec or Elevation
   epoch tcs:mount.F Epoch
   equinox tcs:mount.E Equinox
   parallax tcs:mount.G Parallax
   dtheta1 tcs:mount.H Proper motion in RA
   dtheta2 tcs:mount.I Proper motion in Dec
   rv tcs:mount.J Radial velocity
}

command sourceA tcsApply Set source A target
{
   objName tcs:sourceA.A Object name
   system tcs:sourceA.B System
   theta1 tcs:sourceA.C RA or Azimuth
   theta2 tcs:sourceA.D Dec or Elevation
   epoch tcs:sourceA.F Epoch
   equinox tcs:sourceA.E Equinox
   parallax tcs:sourceA.G Parallax (arcsec)
   dtheta1 tcs:sourceA.H Proper motion in RA (sec/y)
   dtheta2 tcs:sourceA.I Proper motion in Dec (arcsec/y)
   rv tcs:sourceA.J Radial velocity (km/s)
   planet tcs:planet.A Solar system object
}

command sourceB tcsApply Set source B target
{
   objName tcs:sourceB.A Object name
   system tcs:sourceB.B System
   theta1 tcs:sourceB.C RA or Azimuth
   theta2 tcs:sourceB.D Dec or Elevation
   epoch tcs:sourceB.F Epoch
   equinox tcs:sourceB.E Equinox
   parallax tcs:sourceB.G Parallax
   dtheta1 tcs:sourceB.H Proper motion in RA
   dtheta2 tcs:sourceB.I Proper motion in Dec
   rv tcs:sourceB.J Radial velocity
}

