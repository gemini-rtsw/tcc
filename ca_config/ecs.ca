#+
# ecs.ca
#
# Channel access configuration file for the ecs subsystem commands.
#
# D Terrett 1 June 2000
#
# Copyright CCLRC
#-

command encThermal tcsApply Enclosure thermal control
{
   mode tcs:encThermal.A Mode
}

command carousel tcsApply Enclosure mode
{
   domemode tcs:carouselMode.A Dome mode
   shuttermode tcs:carouselMode.B Shutter mode
   slit tcs:carouselMode.C Slit height (mm)
   dome tcs:carouselMode.D Dome enable
   shutter tcs:carouselMode.E Shutter enable
}

command enclosureStop tcsApply Stop enclosure
{
   dummy tcs:enclosureStop.A Dummy field to mark CAD
}

command enclosurePark	tcsApply Park enclosure
{
   dummy tcs:enclosurePark.A Dummy field to mark CAD
}

command enclosureDatum tcsApply Datum enclosure
{
   dummy tcs:enclosureDatum.A Dummy field to mark CAD
}

command carouselStop tcsApply Stop carousel
{
   dummy tcs:carouselStop.A Dummy field to mark CAD
}

command carouselPark	tcsApply Park carousel
{
   parkpos tcs:carouselPark.A park position
   azimuth tcs:carouselPark.B Azimuth (deg)
}

command carouselMove tcsApply Move carousel
{
   azimuth tcs:carousel.A Azimuth (deg)
}

command shutterStop tcsApply Stop shutters
{
   dummy tcs:shutterStop.A Dummy field to mark CAD
}

command shutterPark	tcsApply Park shutters
{
   dummy tcs:shutterPark.A Dummy field to mark CAD
}

command shutterDatum tcsApply Datum shutters
{
   dummy tcs:shutterDatum.A Dummy field to mark CAD
}

command shutters tcsApply Move shutters
{
   top tcs:shutter.A Top position (deg)
   bottom tcs:shutter.B Bottom position (deg)
}

command ventgatesStop tcsApply Stop vent gates
{
   dummy tcs:ventGatesStop.A Dummy field to mark CAD
}

command ventgatesPark	tcsApply Park gates
{
   dummy tcs:ventGatesPark.A Dummy field to mark CAD
}

command ventgates tcsApply Move vent gates
{
   east tcs:ventgates.A E gate opening
   west tcs:ventgates.B W gate opening
}

command domeClose	tcsApply Close Shutters & Gates
{
   dummy tcs:shutterPark.A Dummy field to mark CAD
   dummy1 tcs:ventGatesPark.A Dummy field to mark CAD
}

command enclosureInit tcsApply Init enclosure
{
   dummy tcs:enclosureInit.A Dummy field to mark CAD
}
