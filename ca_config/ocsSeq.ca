command park tcsApply Park
{
   mark tcs:park.A Dummy field to mark CAD
}

command datum tcsApply Datum
{
   mark tcs:datum.A Dummy field to mark CAD
}

command init tcsApply Initialize
{
   mark tcs:init.A Dummy field to mark CAD
}

command reboot tcsApply Reboot
{
   mark tcs:reboot.A Dummy field to mark CAD
}

command test tcsApply Self test
{
   mark tcs:test.A Dummy field to mark CAD
}
