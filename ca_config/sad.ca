status tcssad
{
   state               tcs:sad:state              0 TCS state
   health              tcs:sad:health             0 TCS health
   heartbeat           tcs:sad:heartbeat          0 TCS heartbeat
   programID           tcs:sad:programID          0 Program ID
   airMassLimit        tcs:sad:airMassLimit       0 Airmass limit
   airMassLimitEl      tcs:sad:airMassLimitEl     0 Airmass limit elevation
   currentTimeToSet    tcs:sad:currentTimeToSet   0 Time to elevation limit
   timeToAmSet         tcs:sad:timeToAmSet        0 Time to Airmass limit
   timeToRotlim        tcs:sad:timeToRotlim       0 Time to rotator wrap limit
   timeToAzlim         tcs:sad:timeToAzlim        0 Time to azimuth wrap limit
   timeToBlindSpot     tcs:sad:timeToBlindSpot    0 Time to zenith blind spot
   sourceAObjectName   tcs:sad:sourceAObjectName  0 Object name
   sourceARA           tcs:sad:sourceARA          0 RA or Azimuth
   sourceADec          tcs:sad:sourceADec         0 Dec or Elevation
   sourceAInputFrame   tcs:sad:sourceAInputFrame  0 Coordinate system
   sourceAEquinox      tcs:sad:sourceAEquinox     0 Equinox
   sourceATrackFrame   tcs:sad:sourceATrackFrame  0 Tracking frame
   sourceAWavelength   tcs:sad:sourceAWavelength  0 Wavelength
   sourceATrackEq      tcs:sad:sourceATrackEq     0 Tracking equinox
   sourceADiffRA       tcs:sad:sourceADiffRA      0 Track Rate RA
   sourceADiffDec      tcs:sad:sourceADiffDec     0 Track Rate Dec
   sourceBObjectName   tcs:sad:sourceBObjectName  0 Object name
   sourceBRA           tcs:sad:sourceBRA          0 RA or Azimuth
   sourceBDec          tcs:sad:sourceBDec         0 Dec or Elevation
   sourceBInputFrame   tcs:sad:sourceBInputFrame  0 Coordinate system
   sourceBEquinox      tcs:sad:sourceBEquinox     0 Equinox
   sourceBTrackFrame   tcs:sad:sourceBTrackFrame  0 Tracking frame
   sourceBWavelength   tcs:sad:sourceBWavelength  0 Wavelength
   sourceBTrackEq      tcs:sad:sourceBTrackEq     0 Tracking equinox
   sourceCObjectName   tcs:sad:sourceCObjectName  0 Object name
   sourceCRA           tcs:sad:sourceCRA          0 RA or Azimuth
   sourceCDec          tcs:sad:sourceCDec         0 Dec or Elevation
   sourceCInputFrame   tcs:sad:sourceCInputFrame  0 Coordinate system
   sourceCEquinox      tcs:sad:sourceCEquinox     0 Equinox
   sourceCTrackFrame   tcs:sad:sourceCTrackFrame  0 Tracking frame
   sourceCWavelength   tcs:sad:sourceCWavelength  0 Wavelength
   sourceCTrackEq      tcs:sad:sourceCTrackEq     0 Tracking equinox
   pwfs1ObjectName     tcs:sad:pwfs1ObjectName    0 Object name
   pwfs1RA             tcs:sad:pwfs1RA            0 RA or Azimuth
   pwfs1Dec            tcs:sad:pwfs1Dec           0 Dec or Elevation
   pwfs1InputFrame     tcs:sad:pwfs1InputFrame    0 Coordinate system
   pwfs1Equinox        tcs:sad:pwfs1Equinox       0 Equinox
   pwfs1TrackFrame     tcs:sad:pwfs1TrackFrame    0 Tracking frame
   pwfs1Wavelength     tcs:sad:pwfs1Wavelength    0 Wavelength
   pwfs1TrackEq        tcs:sad:pwfs1TrackEq       0 Tracking equinox
   pwfs2ObjectName     tcs:sad:pwfs2ObjectName    0 Object name
   pwfs2RA             tcs:sad:pwfs2RA            0 RA or Azimuth
   pwfs2Dec            tcs:sad:pwfs2Dec           0 Dec or Elevation
   pwfs2InputFrame     tcs:sad:pwfs2InputFrame    0 Coordinate system
   pwfs2Equinox        tcs:sad:pwfs2Equinox       0 Equinox
   pwfs2TrackFrame     tcs:sad:pwfs2TrackFrame    0 Tracking frame
   pwfs2Wavelength     tcs:sad:pwfs2Wavelength    0 Wavelength
   pwfs2TrackEq        tcs:sad:pwfs2TrackEq       0 Tracking equinox
   oiwfsObjectName     tcs:sad:oiwfsObjectName    0 Object name
   oiwfsRA             tcs:sad:oiwfsRA            0 RA or Azimuth
   oiwfsDec            tcs:sad:oiwfsDec           0 Dec or Elevation
   oiwfsInputFrame     tcs:sad:oiwfsInputFrame    0 Coordinate system
   oiwfsEquinox        tcs:sad:oiwfsEquinox       0 Equinox
   oiwfsTrackFrame     tcs:sad:oiwfsTrackFrame    0 Tracking frame
   oiwfsWavelength     tcs:sad:oiwfsWavelength    0 Wavelength
   oiwfsTrackEq        tcs:sad:oiwfsTrackEq       0 Tracking equinox
   mountObjectName     tcs:sad:mountObjectName    0 Object name
   mountRA             tcs:sad:mountRA            0 RA or Azimuth
   mountDec            tcs:sad:mountDec           0 Dec or Elevation
   mountInputFrame     tcs:sad:mountInputFrame    0 Coordinate system
   mountEquinox        tcs:sad:mountEquinox       0 Equinox
   mountTrackFrame     tcs:sad:mountTrackFrame    0 Tracking frame
   mountWavelength     tcs:sad:mountWavelength    0 Wavelength
   mountTrackEq        tcs:sad:mountTrackEq       0 Tracking equinox
   demandAz            tcs:sad:demandAz           0 Demand Azimuth
   demandEl            tcs:sad:demandEl           0 Demand Elevation
   demandRma           tcs:sad:demandRma          0 Rotator mechanical angle
   demandRA            tcs:sad:demandRA           0 RA/Az of demand
   demandDec           tcs:sad:demandDec          0 Dec/El of demand
   currentRA           tcs:sad:currentRA          0 RA/Az of mount
   currentDec          tcs:sad:currentDec         0 Dec/El of mount
   rotTrackFrame       tcs:sad:rotTrackFrame      0 Mount tracking frame
   domeVignette        tcs:sad:domeVignette       0 Dome vignette fraction
   UTC                 tcs:sad:UTC                0 UTC
   LST                 tcs:sad:LST                0 LST
   ttmtai              tcs:sad:ttmtai             0 TT-TAI
   djmls               tcs:sad:djmls              0 MJD following next leap sec
   delat               tcs:sad:delat              0 TAI-UTC
   delut               tcs:sad:delut              0 UT1-UTC
   astCtx              tcs:sad:astCtx             0 Ast context
   tlatm               tcs:sad:tlatm              0 Telescope mean latitude
   tlongm              tcs:sad:tlongm             0 Telescope mean longitude
   height              tcs:sad:height             0 Telescope height above msl
   xpm                 tcs:sad:xpm                0 X component of polar motion
   ypm                 tcs:sad:ypm                0 Y component of polar motion
   tlr                 tcs:sad:tlr                0 Tropospheric lapse rate
   currentExternalTemp tcs:sad:currentExternalTemp 0 Air temperature (deg C)
   currentAirPressure  tcs:sad:currentAirPressure 0 Pressure (mbar)
   currentRH           tcs:sad:currentRH          0 Relative humidity
   focalLength         tcs:sad:focalLength        0 Focal length (mm)
   azTiltNorth         tcs:sad:azTiltNorth        0 Azimuth tilt North
   azTiltWest          tcs:sad:azTiltWest         0 Azimuth tilt West
   nonPerp             tcs:sad:nonPerp            0 Non-perpendicularity
   collErrAz           tcs:sad:collErrAz          0 Collimation error in az
   collErrEl           tcs:sad:collErrEl          0 Collimation error in el
   pwfs1Rmax           tcs:sad:pwfs1Rmax          0 PWFS1 max radius
   pwfs1Rmin           tcs:sad:pwfs1Rmin          0 PWFS1 min radius
   pwfs2Rmax           tcs:sad:pwfs2Rmax          0 PWFS2 max radius
   pwfs2Rmin           tcs:sad:pwfs2Rmin          0 PWFS2 min radius
   oiwfsRmax           tcs:sad:oiwfsRmax          0 OIWFS max radius
   oiwfsRmin           tcs:sad:oiwfsRmin          0 OIWFS min radius
   oiwfsXmax           tcs:sad:oiwfsXmax          0 OIWFS X max
   oiwfsXmin           tcs:sad:oiwfsXmin          0 OIWFS X min
   oiwfsYmax           tcs:sad:oiwfsYmax          0 OIWFS Y max
   oiwfsYmin           tcs:sad:oiwfsYmin          0 OIWFS Y min
   oiwfsLimitType      tcs:sad:oiwfsLimitType     0 OIWFS limit type
   pointObs            tcs:sad:pointObs           0 Pointing observation SIR
   inPosition          tcs:sad:inPosition         0 TCS in position
   targetA             tcs:sad:targetA            0 Target A
   targetB             tcs:sad:targetB            0 Target B
   targetC             tcs:sad:targetC            0 Target C
   targetPwfs1         tcs:sad:targetPwfs1        0 Target Pwfs1
   targetPwfs2         tcs:sad:targetPwfs2        0 Target Pwfs2
   targetOiwfs         tcs:sad:targetOiwfs        0 Target Oiwfs
   currentAz           tcs:sad:currentAz          0 Current Azimuth
   currentEl           tcs:sad:currentEl          0 Current Elevation
   pwfs1XDemand        tcs:sad:pwfs1XDemand       0 PWFS1 X demand
   pwfs1YDemand        tcs:sad:pwfs1YDemand       0 PWFS1 Y demand
   pwfs2XDemand        tcs:sad:pwfs2XDemand       0 PWFS2 X demand
   pwfs2YDemand        tcs:sad:pwfs2YDemand       0 PWFS2 Y demand
   elError             tcs:sad:elError            0 Elevation error
   azError             tcs:sad:azError            0 Azimuth error
   rmaError            tcs:sad:rmaError           0 Rotator angle error
   calocal             tcs:sad:calocal            0 Local CA adjustment
   celocal             tcs:sad:celocal            0 Local CE adjustment
   caguide             tcs:sad:caguide            0 Guiding CA adjustment
   ceguide             tcs:sad:ceguide            0 Guiding CE adjustment
   nodState            tcs:sad:nodState           0 Nod state
   chopState           tcs:sad:chopState          0 Chop state
   chopBeam            tcs:sad:chopBeam           0 Chop beam
   autoMoveDome        tcs:autoMoveDome           0 Dome under tcs control
   autoMoveShtrs       tcs:autoMoveShtrs          0 Shutters under tcs control
   instrAA             tcs:sad:instrAA            0 Instrument alignment angle
   xoffsetPoA1         tcs:offsetPoA1.VALA        0 X offset
   yoffsetPoA1         tcs:offsetPoA1.VALB        0 Y offset
   currentWindDir      tcs:sad:currentWindDir     0 Wind direction
   currentWindSpeed    tcs:sad:currentWindSpeed   0 Wind speed
   name                tcs:sad:name               0 Telescope name
   ellimit             tcs:ellimit                0 Elevation limit
   azlolimit           tcs:azlolimit              0 Azimuth low limit
   azhilimit           tcs:azhilimit              0 Azimuth high limit
   rotlolimit          tcs:rotlolimit             0 Rotator low limit
   rothilimit          tcs:rothilimit             0 Rotator high limit
   zlimit              tcs:zlimit                 0 Zenith avoidance limit
   m1FigUpdatesFlag    tcs:im:m1FigUpdatesFlag    0 M1 figure updates flag
   aoDemandx           tcs:drives:driveAOS.VALC   0 AO x demand
   aoDemandy           tcs:drives:driveAOS.VALB   0 AO y demand
   minSlitHeight       tcs:def:minSlitHeight      0 Min enclosure slit height
   instrPA             tcs:sad:instrPA            0 Instrument position angle
   aoXoffset           tcs:drives:aoXoffset       0 AO zero point X
   aoYoffset           tcs:drives:aoYoffset       0 AO zero point Y
}

#include <m2ssad.ca>
#include <agssad.ca>
#include <mcssad.ca>
#include <crssad.ca>
