command aoDeployAdc tcsApply Deploy ALTAIR ADC
{
   position  tcs:aoDeployAdc.A position
}

command aoMoveAdc tcsApply Move ALTAIR ADC
{
   rotpos    tcs:aoMoveAdc.A Cass rotator position
   zd        tcs:aoMoveAdc.B Zenith distance
   wavel     tcs:aoMoveAdc.C Central wavelength
   adjust    tcs:aoMoveAdc.D Adjust
}

command aoPrepareCm tcsApply Prepare ALTAIR control matrix
{
   x         tcs:aoPrepareCm.A Guide star x position
   y         tcs:aoPrepareCm.B Guide star y position
   seeing    tcs:aoPrepareCm.C Seeing estimate
   gsmag     tcs:aoPrepareCm.D Guide star magnitude
   windspeed tcs:aoPrepareCm.E Windspeed
}

command aoFlatten tcsApply Flatten ALTAIR science path.
{
   dummy     tcs:aoFlatten1.A 
}

command aoFollow tcsApply ALTAIR stage follow
{
   followState tcs:aoFollow.A 
}

command aoCentreWfs tcsApply Centre ALTAIR Wfs
{
   retain     tcs:aoCentre.A Retain offsets
}

command aoCorrect tcsApply ALTAIR Image correction
{
   correct    tcs:aoCorrect.A Correction On/OFF
   matrix     tcs:aoCorrect.B Matrix ID
   gains      tcs:aoCorrect.C Reuse gains
}

command aoEntShutter tcsApply ALTAIR Entrance shutter
{
   state     tcs:aoEntShutter.A Shutter state
}

command aoExitShutter tcsApply ALTAIR Exit shutter
{
   state     tcs:aoExitShutter.A Shutter state
}
