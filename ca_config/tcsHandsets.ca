command tarHandConfig tcsApply Target offset handset configuration
{
   step       tcs:tarHandConfig.A Step size
   tel        tcs:tarHandConfig.B Telescope set
   inctype    tcs:tarHandConfig.C Increment type
}

command tarHandset tcsApply Target offset handset
{
   direction  tcs:tarHandset.A    Step offsets in specified direction
}

command poHandConfig tcsApply pointign origin handset configuration
{
   step       tcs:poHandConfig.A Step size
   tel        tcs:poHandConfig.B Telescope set
}

command poHandset tcsApply pointign origin handset
{
   direction  tcs:poHandset.A    Step offsets in specified direction
}

command guideHandConfig tcsApply guide handset configuration
{
   step       tcs:guideHandConfig.A Step size
}

command guideHandset tcsApply guide handset
{
   direction  tcs:guideHandset.A    Step offsets in specified direction
}
