command tarHandConfig tcsApply Configure target handset
{
   step       tcs:tarHandConfig.A Step size
   tel        tcs:tarHandConfig.B Telescope set
   inctype    tcs:tarHandConfig.C Increment type
}

command tarHandset tcsApply Target handset
{
   direction  tcs:tarHandset.A    Direction
}

command poHandConfig tcsApply Configure instrument origin handset
{
   step       tcs:poHandConfig.A Step size
   tel        tcs:poHandConfig.B Telescope set
}

command poHandset tcsApply Instrument origin handset
{
   direction  tcs:poHandset.A    Direction
}

command guideHandConfig tcsApply Configure guide handset
{
   step       tcs:guideHandConfig.A Step size
}

command guideHandset tcsApply Guide handset
{
   direction  tcs:guideHandset.A    Direction
}
