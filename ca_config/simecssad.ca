status ecssad
{
   domePos             tcs:ec:sad:domePos         0 Current dome azimuth
   topShtrPos          tcs:ec:sad:topShtrPos      0 Current top shutter el
   botShtrPos          tcs:ec:sad:botShtrPos      0 Current bottom shutter el
   eastVentGatePos     tcs:ec:sad:eastVentGatePos 0 East vent gate position
   westVentGatePos     tcs:ec:sad:westVentGatePos 0 West vent gate position
   domeInPos           tcs:ec:domeInPos           0 Dome in position
   topShtrInPos        tcs:ec:topShtrInPos        0 Top shutter in position
   botShtrInPos        tcs:ec:botShtrInPos        0 Bottom shutter in position
}
