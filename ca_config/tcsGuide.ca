#+
# tcsGuide.ca
#
# Channel access configuration file for tcs guiding and chopping related 
# commands.
#
# D Terrett 13 November 2002
#
# Copyright CCLRC
#-

command m1Guide tcsApply M1 guiding
{
   mode       tcs:m1GuideMode.A Mode
}

command m1GuideConfig tcsApply Define M1 guiding
{
   weighting  tcs:m1GuideConfig.A Weighting
   source     tcs:m1GuideConfig.B Signal source
   frames     tcs:m1GuideConfig.C Frames to average
   filename   tcs:m1GuideConfig.D Filename for HRWFS
}

command mountGuide tcsApply Define mount guiding
{
   mode       tcs:mountGuideMode.A Mode
   source     tcs:mountGuideMode.B Guide Source
   p1weight   tcs:mountGuideMode.C P1 weight
   p2weight   tcs:mountGuideMode.D P2 weight
}

command m2Guide tcsApply M2 Guiding
{
   state      tcs:m2GuideControl.A State
}

command m2GuideMode tcsApply M2 GuideMode
{
   coma      tcs:m2GuideMode.B Coma correction
}

command m2GuideConfig tcsApply Define M2 guiding
{
   source     tcs:m2GuideConfig.A Guiding source
   samplefreq tcs:m2GuideConfig.B Sample frequency
   filter     tcs:m2GuideConfig.C Filter type
   freq1      tcs:m2GuideConfig.D Frequency 1
   freq2      tcs:m2GuideConfig.E Frequency 2
   beam       tcs:m2GuideConfig.F Beam
   reset      tcs:m2GuideConfig.G reset
}

command wfsGuideMode tcsApply WFS Guide Mode
{
   state      tcs:wfsGuideMode.A State
   probe      tcs:wfsGuideMode.B Probe
}

command pwfs1Observe tcsApply Start P1
{
   noexp      tcs:pwfs1Observe.A      Exposures
   int        tcs:pwfs1Observe.B      interval
   outopt     tcs:pwfs1Observe.C      Output options
   label      tcs:pwfs1Observe.D      DHS label
   output     tcs:pwfs1Observe.E      DHS output
   path       tcs:pwfs1Observe.F      Path
   name       tcs:pwfs1Observe.G      Filename
}

command pwfs1StopObserve tcsApply Stop P1
{
   dummy      tcs:pwfs1StopObserve.A
}

command pwfs2Observe tcsApply Start P2
{
   noexp      tcs:pwfs2Observe.A      Exposures
   int        tcs:pwfs2Observe.B      Interval
   outopt     tcs:pwfs2Observe.C      Output options
   label      tcs:pwfs2Observe.D      DHS label
   output     tcs:pwfs2Observe.E      DHS output
   path       tcs:pwfs2Observe.F      Path
   name       tcs:pwfs2Observe.G      Filename
}

command pwfs2StopObserve tcsApply Stop P2
{
   dummy      tcs:pwfs2StopObserve.A
}

command oiwfsObserve tcsApply Start OIWFS
{
   noexp      tcs:oiwfsObserve.A      Exposures
   int        tcs:oiwfsObserve.B      Interval
   outopt     tcs:oiwfsObserve.C      Output options
   label      tcs:oiwfsObserve.D      DHS label
   output     tcs:oiwfsObserve.E      DHS output
   path       tcs:oiwfsObserve.F      Path
   name       tcs:oiwfsObserve.G      Filename
}

command oiwfsStopObserve tcsApply Stop OIWFS
{
   dummy      tcs:oiwfsStopObserve.A
}

status guideConfig
{
   p1state    tcs:drives:p1Integrating.VAL  0   P1 integrating
   p2state    tcs:drives:p2Integrating.VAL  0   P2 integrating
   oistate    tcs:drives:oiIntegrating.VAL  0   OI integrating
   m2state    tcs:om:m2GuideState.VAL       0   M2 guiding
   absorbtilt tcs:absorbTipTiltFlag.VAL     0   Absorb tilt errors
   m1state    tcs:im:m1GuideOn.VAL          0   M1 guiding
   m1source   tcs:m1GuideConfig.VALB        0   M1 guide source
   p1guide    tcs:ak:wfsguide:p1weight.VAL  0   WFS guiding
   p2guide    tcs:ak:wfsguide:p2weight.VAL  0   WFS guiding
   p1mweight  tcs:mountGuideMode.VALC       0   Mount p1 wieght
   p2mweight  tcs:mountGuideMode.VALD       0   Mount p1 wieght
   m2p1guide  tcs:drives:p1GuideConfig      0   M2 P1 guide config
   m2p2guide  tcs:drives:p2GuideConfig      0   M2 P2 guide config
   m2oiguide  tcs:drives:oiGuideConfig      0   M2 OI guide config
   m2aoguide  tcs:drives:aoGuideConfig      0   M2 AO guide config
   coma       tcs:im:m2gm:comaCorrectFlag.VAL 0 Coma correction
}

command m2beam tcsApply M2 beam
{
   m2Beam     tcs:m2Beam.A           Beam
}

command chop tcsApply Chop
{
   chop       tcs:chop.A             State
}

command nod tcsApply Nod
{
   nod        tcs:nod.A              State
}

status pwfs1Guide
{
   nodachopa tcs:configPwfs1.VALA 0 Nod A Chop A
   nodachopb tcs:configPwfs1.VALB 0 Nod A Chop B
   nodachopc tcs:configPwfs1.VALC 0 Nod A Chop C
   nodbchopa tcs:configPwfs1.VALD 0 Nod B Chop A
   nodbchopb tcs:configPwfs1.VALE 0 Nod B Chop B
   nodbchopc tcs:configPwfs1.VALF 0 Nod B Chop C
   nodcchopa tcs:configPwfs1.VALG 0 Nod C Chop A
   nodcchopb tcs:configPwfs1.VALH 0 Nod C Chop B
   nodcchopc tcs:configPwfs1.VALI 0 Nod C Chop C
}

status pwfs2Guide
{
   nodachopa tcs:configPwfs2.VALA 0 Nod A Chop A
   nodachopb tcs:configPwfs2.VALB 0 Nod A Chop B
   nodachopc tcs:configPwfs2.VALC 0 Nod A Chop C
   nodbchopa tcs:configPwfs2.VALD 0 Nod B Chop A
   nodbchopb tcs:configPwfs2.VALE 0 Nod B Chop B
   nodbchopc tcs:configPwfs2.VALF 0 Nod B Chop C
   nodcchopa tcs:configPwfs2.VALG 0 Nod C Chop A
   nodcchopb tcs:configPwfs2.VALH 0 Nod C Chop B
   nodcchopc tcs:configPwfs2.VALI 0 Nod C Chop C
}

status oiwfsGuide
{
   nodachopa tcs:configOiwfs.VALA 0 Nod A Chop A
   nodachopb tcs:configOiwfs.VALB 0 Nod A Chop B
   nodachopc tcs:configOiwfs.VALC 0 Nod A Chop C
   nodbchopa tcs:configOiwfs.VALD 0 Nod B Chop A
   nodbchopb tcs:configOiwfs.VALE 0 Nod B Chop B
   nodbchopc tcs:configOiwfs.VALF 0 Nod B Chop C
   nodcchopa tcs:configOiwfs.VALG 0 Nod C Chop A
   nodcchopb tcs:configOiwfs.VALH 0 Nod C Chop B
   nodcchopc tcs:configOiwfs.VALI 0 Nod C Chop C
}
