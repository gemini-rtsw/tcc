command m1Guide tcsApply Define primary guiding mode
{
   mode       tcs:m1GuideMode.A Guiding mode
   weighting  tcs:m1GuideConfig.A Weighting
   pwfs1      tcs:m1GuideConfig.B PWFS1 weighting
   pwfs2      tcs:m1GuideConfig.C PWFS2 weighting
   update     tcs:m1GuideConfig.D update interval (sec)
}

command mountGuide tcsApply Define mount guiding mode
{
   mode       tcs:mountGuideMode.A Guiding mode
   source     tcs:mountGuideMode.B Guide Source
   p1weight   tcs:mountGuideMode.C PWFS1 weighting
   p2weight   tcs:mountGuideMode.D PWFS2 weighting
}
