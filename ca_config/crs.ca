command rotStop tcsApply Stop rotator
{
   dummy tcs:rotStop.A
   brakes tcs:rotStop.B
}

command rotPark	tcsApply Park rotator
{
   dummy tcs:rotPark.A
}

command rotDatum tcsApply Datum rotator
{
   dummy tcs:rotDatum.A
   device tcs:rotDatum.B
}

command rotMove tcsApply Move rotator
{
   rma tcs:rotMove.A Mechanical angle
}

command rotConfig tcsApply Configure rotator encoders
{
   algorithm tcs:rotConfig.A Algorithm
   headid    tcs:rotConfig.B Head ID
}

command rotTolerance tcsApply Set rotator tolerances
{
   posError tcs:rotTolerance.A Position error
   velError tcs:rotTolerance.B Velocity error
}

command rotCentre tcsApply Center rotator wrap
{
   dummy tcs:rotCentre.A
}
