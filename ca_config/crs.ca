command rotstop tcsApply Stop
{
   dummy tcs:rotStop.A Dummy field to mark CAD
}

command rotpark	tcsApply Park
{
   dummy tcs:rotPark.A Dummy field to mark CAD
}

command rotdatum tcsApply Datum
{
   dummy tcs:rotDatum.A Dummy field to mark CAD
}

command rotmove tcsApply Move
{
   rma tcs:rotMove.A Mechanical angle
}

command rotconfig tcsApply Configure encoders
{
   algorithm tcs:rotConfig.A Algorithm
   headid    tcs:rotConfig.B Head ID
}

command rotTolerance tcsApply Set tolerances
{
   posError tcs:rotTolerance.A Position error (deg)
   velError tcs:rotTolerance.B Velocity error (deg/s)
}
