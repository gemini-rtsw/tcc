#+
# nici.ca
#
# Channel access configuration file for direct access to NICI 
#
# A Ebbers July 2007
#
#-

status nici
{
   ndfilt            nici:ao:nd:positionV         0 ND Filter Name
}

command niciNdFilt tcsApply
{
   target            nici:ao:nd:move.A
   dir               nici:ao:nd:move.DIR
}

command niciMag tcsApply
{
   mag               nici:mag2filter.A
   dir               nici:mag2filter.DIR
}
