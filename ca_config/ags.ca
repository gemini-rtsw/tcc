   dummy      tcs:pwfs2Stop.A        Stop
}

command pwfs2Unwrap tcsApply PWFS2 unwrap
{
   dummy      tcs:pwfs2Unwrap.A      Unwrap
}

command pwfs2SetOrient tcsApply Set PWFS2 orientation
{
   table      tcs:pwfs2SetOrient.A      Table angle
   arm        tcs:pwfs2SetOrient.B      Arm angle
}

command pwfs1Datum tcsApply Datum PWFS1
{
   dummy      tcs:pwfs1Datum.A          Dummy
}

command pwfs2Datum tcsApply Datum PWFS2
{
   dummy      tcs:pwfs2Datum.A          Dummy
}

command scienceFoldDatum tcsApply Datum Science Fold
{
   dummy      tcs:scienceFoldDatum.A          Dummy
}

command hrwfsDatum tcsApply Datum HRWFS pickoff arm
{
   dummy      tcs:hrwfsDatum.A          Dummy
}

command aoFoldDatum tcsApply Datum AO Fold
{
   dummy      tcs:aoFoldDatum.A          Dummy
}

command pwfs1FilterDatum tcsApply Datum PWFS1 filter
