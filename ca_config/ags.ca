command hrwfs tcsApply Set HRWFS fold mirror
{
   hwfold tcs:hrwfs.A HRWFS fold position
}

command aoFold tcsApply Set AO fold mirror
{
   aofold tcs:aoFold.A AO fold position
}

command scienceFold tcsApply Set science fold position
{
   scfold tcs:scienceFold.A Science fold position
}

command scienceFoldPark tcsApply Park science fold mirror
{
   scfoldPark tcs:scienceFoldPark.A Park Science fold
}

command pwfs1Park tcsApply PWFS1 park
{
   dummy      tcs:pwfs1Park.A        Park
}

command pwfs1Flip tcsApply PWFS1 flip
{
   dummy      tcs:pwfs1Flip.A        Flip
}

command pwfs1Stop tcsApply PWFS1 stop
{
   dummy      tcs:pwfs1Stop.A        Stop
}

command pwfs1Unwrap tcsApply PWFS1 unwrap
{
   dummy      tcs:pwfs1Unwrap.A      Unwrap
}

command pwfs1SetOrient tcsApply Set PWFS1 orientation
{
   table      tcs:pwfs1SetOrient.A      Table angle
   arm        tcs:pwfs1SetOrient.B      Arm angle
}

command pwfs2Park tcsApply PWFS2 park
{
   dummy      tcs:pwfs2Park.A        Park
}

command pwfs2Flip tcsApply PWFS2 flip
{
   dummy      tcs:pwfs2Flip.A        Flip
}

command pwfs2Stop tcsApply PWFS2 stop
{
   dummy      tcs:pwfs2Stop.A        Stop
}

command pwfs2Unwrap tcsApply PWFS2 unwrap
{
   dummy      tcs:pwfs2Unwrap.A      Unwrap
}

command pwfs2SetOrient tcsApply Set PWFS2 orientation
{
   table      tcs:pwfs2SetOrient.A      Table angle
   arm        tcs:pwfs2SetOrient.B      Arm angle
}
