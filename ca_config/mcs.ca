#-

command telstop tcsApply Stop
{
   stopAxis tcs:telstop.A Axis to stop
   azBrakes tcs:telstop.B Az brake
   elBrakes tcs:telstop.C El brake
}

command telpark	tcsApply Park mount
{
   dummy tcs:telpark.A Dummy field to mark CAD
}

command mountDatum tcsApply Datum
{
   datumAxis  tcs:mountDatum.A Axis to datum
   azDevice   tcs:mountDatum.B Az device
   elDevice   tcs:mountDatum.C El device
}

command elevation tcsApply Move elevation
{
   el tcs:elevation.A Elevation (deg)
}

command azimuth tcsApply Move azimuth
{
   az tcs:azimuth.A Azimuth (deg)
}

command azel tcsApply Move both
{
   az tcs:azel.A Azimuth (deg)
   el tcs:azel.B Elevation (deg)
}

command azConfig tcsApply Configure azimuth encoders
{
   azAlgorithm tcs:azConfig.A Algorithm
}

command elConfig tcsApply Configure elevation encoders
{
   elAlgorithm tcs:elConfig.A Algorithm
}

command mountLog tcsApply Control fast data logging
{
   sampFreq tcs:mountLog.B Sampling Frequency (Hz)
   switch tcs:mountLog.C Logging state
}

command mountTolerance tcsApply Set tolerances
{
   azPosError tcs:mountTolerance.A Azimuth position error (deg)
   azVelError tcs:mountTolerance.B Azimuth velocity error (deg/s)
   elPosError tcs:mountTolerance.C Elevation position error (deg)
   elVelError tcs:mountTolerance.D Elevation velocity error (deg/s)
}
