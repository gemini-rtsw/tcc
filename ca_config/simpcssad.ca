status pcssad
{
   apssMsg             m1:apss:ctrlStatusMsg  0 APSS status message
   aosMsg              m1:aos:ctrlStatusMsg   0 AOS status message
   aoMoving            tcs:m1:aoMoving        0 Number of actuators moving
