#+
#  SciTarget <- Target
#
#  Implements the SciTarget class. A SciTarget object stores all
#  the parameters needed to specify a science target.
#
#  Options:
#              -airmassLimit  The airmass limit to apply when using the
#                             instrument.
#
#              -programid     Gemini Program ID
#
#           The following options apply when -type is planet.
#
#              -planet        The planet name.
#
#           The following options apply when -type is orbit.
#
#              -eltype        Type of elements
#
#              -epochofel     Epoch of elements.
#
#              -inclination   Inclination.
#
#              -longascnode   Longitude of ascending node.
#
#              -longofper     Longitude of perihelion.
#
#              -argofper      Argument of perihelion.
#
#              -meandist      Mean distance.
#
#              -perdist       Perihelion distance.
#
#              -eccentricity  Eccentricity.
#
#              -meanlong      Mean longitude.
#
#              -meananom      Mean anomoly.
#
#              -dailymot      Daily motion.
#
#  Methods:
#           apply vt      Applies the target definition to the TCS by 
#                         setting the values of the command parameters
#                         for virtual telescope "vt".
#
#           grab vt       Grabs the current science target from the tcs.
#
#           init          Sets the science target to its initial state.
#
#           preview item  Sets the preview target for "item".
#
#           save file     Writes the values of the target options to the
#                         channel identifier "file".
#
#  Procs:
#           subcomponents Returns a list of the target classes subcomponents.
#
#  D Terrett 4 September 2001
#
#  Copyright CCLRC
#+

itcl::class SciTarget {
   inherit Target
   public proc subcomponents {} {return [Target::subcomponents]}
   public {
      method apply {vt}
      method grab {vt}
      method init {}
      method preview {vt}
      method save {file}
      variable programid {}
      variable airmassLimit {}

# Type "planet"
      variable planet {} {if { ! [string equal $planet ""] } {set type planet}}

# Type "orbit"
      variable eltype {} {if { ! [string equal $eltype ""] } {set type orbit}}
      variable epochofel {}
      variable inclination {}
      variable longascnode {}
      variable longofper {}
      variable argofper {}
      variable meandist {}
      variable perdist {}
      variable eccentricity {}
      variable meanlong {}
      variable meananom {}
      variable dailymot {}
   }
}

itcl::body SciTarget::apply vt {

   $this Target::apply $vt

   global env
   ss $env(TCC_TCSNAME):sad:programID set value $programid
   ss $env(TCC_TCSNAME):sad:programID post

   if { ![string is space $airmassLimit] } {
      cs airmassLimit set limit $airmassLimit
      logger command airmassLimit
   }

   switch $type {
      planet {
         cs planet set object $planet
         logger command planet
      }
      orbit {
         cs orbit set objName [list $objName]
         cs orbit set eltype [list $eltype]
         cs orbit set epochofel [list $epochofel]
         cs orbit set inclination [list $inclination]
         cs orbit set longascnode [list $longascnode]
         if { $eltype == 1 } {
            cs orbit set longofper [list $longofper]
         } else {
            cs orbit set argofper [list $argofper]
         }
         if { $eltype == 3 } {
            cs orbit set perdist [list $perdist]
         } else {
            cs orbit set meandist [list $meandist]
         }
         cs orbit set eccentricity [list $eccentricity]
         if { $eltype == 1 } {
            cs orbit set meanlong [list $meanlong]
         } elseif { $eltype == 2 } {
            cs orbit set meananom [list $meananom]
         } else {
            cs orbit set meananom ""
         }
         if { $eltype == 1 } {
            cs orbit set dailymot [list $dailymot]
         } else {
            cs orbit set dailymot ""
         }
         logger command orbit
      }
   }
}

itcl::body SciTarget::init {} {
   $this Target::init
   set programid ""
   set airmassLimit ""
   set planet {}
   set eltype {}
   set epochofel {}
   set inclination {}
   set longascnode {}
   set longofper {}
   set argofper {}
   set meandist {}
   set perdist {}
   set eccentricity {}
   set meanlong {}
   set meananom {}
   set dailymot {}
}

itcl::body SciTarget::preview vt {

   $this Target::preview $vt
   switch $type {
      planet {
         tccPreview set planet $planet
      }
      orbit {
         switch $eltype {
            1 {
               tccPreview set orbit 1 $epochofel $inclination $longascnode \
                     $longofper $meandist $eccentricity $meanlong $dailymot
            }
            2 {
               tccPreview set orbit 2 $epochofel $inclination $longascnode \
                     $argofper $meandist $eccentricity $meananom
            }
            3 {
               tccPreview set orbit 3 $epochofel $inclination $longascnode \
                     $argofper $perdist $eccentricity
            }
         }
      }
   }
}

itcl::body SciTarget::save file {
   $this Target::save $file
   puts $file "[list $this] configure \\"
   puts $file "   -programid [list $programid] \\"
   switch $type {
      planet {
         puts $file "   -planet [list $planet] \\"
      }
      orbit {
         puts $file "   -eltype [list $eltype] \\"
         puts $file "   -epochofel [list $epochofel] \\"
         puts $file "   -inclination [list $inclination] \\"
         puts $file "   -longascnode [list $longascnode] \\"
         if { $eltype == 1 } {
            puts $file "   -longofper [list $longofper] \\"
         } else {
            puts $file "   -argofper [list $argofper] \\"
         }
         puts $file "   -meandist [list $meandist] \\"
         puts $file "   -perdist [list $perdist] \\"
         puts $file "   -eccentricity [list $eccentricity] \\"
         puts $file "   -meanlong [list $meanlong] \\"
         if { $eltype == 1 || $eltype == 2 } {
            puts $file "   -meananom [list $meananom] \\"
         }
         if { $eltype == 1 } {
            puts $file "   -dailymot [list $dailymot] \\"
         }
      }
   }
   puts $file "   -airmassLimit [list $airmassLimit]"
}

itcl::body SciTarget::grab vt {
   Target::grab $vt
   set airmassLimit [sa tcssad get airMassLimit]
   set programid [sa tcssad get programID]
}
