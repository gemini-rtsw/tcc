#+
#  SciTarget.itcl
#
#  Implements the SciTarget class. A SciTarget object is just a Target
#  object with a different name.
#
#  D Terrett 11 November 1999
#
#  Copyright CCLRC
#+

itcl::class SciTarget {
   inherit Target

   constructor args {}

   public proc subcomponents
}

itcl::body SciTarget::constructor args {

   eval configure $args
}

itcl::body SciTarget::subcomponents {} {
   return [Target::subcomponents]
}
