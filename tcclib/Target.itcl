#+
#  Target
#
#  Implements the Target class. A Target object stores all
#  the parameters needed to specify a target.
#
#  Options:
#           -objName       The object name
#
#           -type          The type of the coordinate (radec, or azel).
#
#           -wavelength_name
#
#           -wavelength_value
#
#           The following options apply when -type is radec.
#
#              -cosys         The target coordinate system.
#
#              -epoch         The epoch of the position.
#
#              -parallax      The parallax.
#
#              -radec         Right ascension and declination.
#
#              -rv            Radial velocity.
#
#           The following options apply when -type is radec.
#
#              -azel          Azimuth and elevation.
#
#  Methods:
#           apply vt      Applies the target definition to the TCS by 
#                         setting the values of the command parameters
#                         for virtual telescope "vt".
#
#           grab vt       Grabs the current tracking position of the
#                         virtual telescope vt.
#
#           init          Returns the rotator object to its initial state.
#
#           preview item  Sets the preview target for "item".
#
#           save file     Writes the values of the target options to the
#                         channel identifier "file".
#
#  Procs:
#           subcomponents Returns a list of the target classes subcomponents.
#
#  Notes:
#        The grab method only supports the mount and source virtual
#        telescopes.
#
#  D Terrett 26 September 2000
#
#  Copyright CCLRC
#+

itcl::class Target {

   constructor args {}
   destructor {$this init}

   public proc subcomponents {}

   public method apply vt
   public method copy createproc
   public method grab vt
   public method init
   public method preview vt
   public method save file

   public variable type {}
   public variable objName {}

# Type "radec"
   public variable radec {} {if {$radec != ""} {set type radec}}
   public variable cosys {}
   public variable epoch {}
   public variable parallax 0
   public variable pm {}
   public variable rv 0

# Type "azel"
   public variable azel {} {if {$azel != ""} {set type azel}}

   public variable wavelength_name {}
   public variable wavelength_value {} {
      set wavelength_value [valWavelength $wavelength_value]
   }
   public variable trackrate {}

   protected common Wavelength ""

   private variable current_cosys {}
   private variable current_wavelength_name {}
   private variable current_trackrate {}
}

itcl::body Target::subcomponents {} {
   return { \
      {cosys Cosys CosysNames CosysList {Coordinate System} {}} \
      {wavelength Wavelength WavelengthNames WavelengthList {Wavelength} {}} \
      {trackrate TrackRate TrackRateNames TrackRateList {Differential Track Rate} {}} \
   }
}

itcl::body Target::constructor args {

# Create the scratch wavelength object if it doesn't already exist.
   if { [info commands $Wavelength] == "" } {
      set Wavelength [Wavelength #auto]
   }
   eval configure $args
}

itcl::body Target::apply vt {

   switch $type {
      radec {
         cs $vt set objName \"$objName\"
         if { $cosys == "" } {
            cs $vt set system FK5
            cs $vt set equinox J2000
         } else {
            CosysNames::$cosys apply $vt
         }
         cs $vt set theta1 \"[lindex $radec 0]\"
         cs $vt set theta2 \"[lindex $radec 1]\"
         cs $vt set epoch \"$epoch\"
         cs $vt set parallax \"$parallax\"
         if { $pm != "" } {
            cs $vt set dtheta1 \"[lindex $pm 0]\"
            cs $vt set dtheta2 \"[lindex $pm 1]\"
         } else {
            cs $vt set dtheta1 \"\"
            cs $vt set dtheta2 \"\"
         }
         cs $vt set rv \"$rv\"
      }
      azel {
         cs $vt set objName \"$objName\"
         cs $vt set system \"AZEL_TOPO\"
         cs $vt set equinox \"\"
         cs $vt set theta1 \"[lindex $azel 0]\"
         cs $vt set theta2 \"[lindex $azel 1]\"
         cs $vt set epoch \"\"
         cs $vt set parallax \"\"
         cs $vt set dtheta1 \"\"
         cs $vt set dtheta2 \"\"
         cs $vt set rv \"\"
      }
   }
   logger command $vt
   if { $wavelength_name != "" } {
      if { $wavelength_name != "" } {
         ::WavelengthNames::$wavelength_name apply $vt
      }
   } else {
      if { $wavelength_value != "" } {
         $Wavelength configure -wavel $wavelength_value
         $Wavelength apply $vt
      }
   }
   if { $trackrate != "" } {
      ::TrackRateNames::$trackrate apply $vt
   }
}

itcl::body Target::init {} {

   set type {}
   set objName {}
   set radec {}
   $this configure -cosys {}
   set epoch {}
   set parallax 0
   set pm {}
   set rv 0
   set azel {}
   $this configure -wavelength_name {}
   set wavelength_value {}
   $this configure -trackrate {}
}

itcl::body Target::preview vt {

   if { $cosys == "" } {
      set system FK5
      set equinox J2000
   } else {
      set system [CosysNames::$cosys cget -frame]
      set equinox [CosysNames::$cosys cget -equinox]
   }
   switch $type {
      radec {
         tccPreview set $vt $system [lindex $radec 0] [lindex $radec 1] \
               $equinox $epoch
      }
      azel {
         tccPreview set $vt AZEL [lindex $azel 0] [lindex $azel 1]
      }
   }
      
   if { $wavelength_name != "" } {
      ::WavelengthNames::$wavelength_name preview $vt
   } else {
      if { $wavelength_value != "" } {
         $Wavelength configure -wavel $wavelength_value
         $Wavelength preview $vt
      }
   }
   if { $trackrate != "" } {
      ::TrackRateNames::$trackrate preview $vt
   }
}

itcl::body Target::save file {
   puts $file "   -objName \"$objName\" \\"
   puts $file "   -cosys \"$cosys\" \\"
   puts $file "   -radec \"$radec\" \\"
   puts $file "   -epoch \"$epoch\" \\"
   puts $file "   -parallax \"$parallax\" \\"
   puts $file "   -pm \"$pm\" \\"
   puts $file "   -rv \"$rv\" \\"
   puts $file "   -azel \"$azel\" \\"
   puts $file "   -wavelength_name \"$wavelength_name\" \\"
   puts $file "   -wavelength_value \"$wavelength_value\" \\"
   puts $file "   -trackrate \"$trackrate\""
}

body Target::grab vt {

# Update the ast context.
   ast update

# Select the pointing origin.
   switch $vt {
      sourceA {set po A}
      sourceB {set po B}
      sourceC {set po C}
      mount {set po M}
   }

# Get the wavelength.
   set wavelength_name ""
   set wavelength_value [expr [sadVal tcssad ${vt}Wavelength 5000.0] / 10000.0]

# And frame.
   if { $cosys == "" } {
      set cosys FK5/J2000
   }
   set frame [::CosysNames::$cosys cget -frame]
   set equinox [::CosysNames::$cosys cget -equinox]

# Get the target position.
   set target [ast target $po A $wavelength_value $frame $equinox]

# Store the RA/Dec.
   set type radec
   set radec [lrange $target 0 1]
}

itcl::configbody Target::cosys {
   if { $current_cosys != "" } {
      CosysNames::$current_cosys refdec
   }
   set current_cosys ""
   if { $cosys != "" } {
      if { [catch {CosysNames::$cosys refinc}] } {
         error "Coordinate frame \"$cosys\" does not exist"
      } else {
         set current_cosys $cosys
      }
   }
}

itcl::configbody Target::wavelength_name {
   if { $current_wavelength_name != "" } {
      WavelengthNames::$current_wavelength_name refdec
   }
   set current_wavelength_name ""
   if { $wavelength_name != "" } {
      if { [catch {WavelengthNames::$wavelength_name refinc}] } {
         error "Wavelength \"$wavelength_name\" does not exist"
      } else {
         set current_wavelength_name $wavelength_name
      }
   }
}

itcl::configbody Target::trackrate {
   if { $current_trackrate != "" } {
      TrackRateNames::$current_trackrate refdec
   }
   set current_trackrate ""
   if { $trackrate != "" } {
      if { [catch {TrackRateNames::$trackrate refinc}] } {
         error "Differential track rate \"$trackrate\" does not exist"
      } else {
         set current_trackrate $trackrate
      }
   }
}

itcl::body Target::copy createproc {
   $createproc [namespace tail $this] \
      -objName $objName \
      -cosys $cosys \
      -radec $radec \
      -epoch $epoch \
      -parallax $parallax \
      -pm $pm \
      -rv $rv \
      -azel $azel \
      -wavelength_name $wavelength_name \
      -wavelength_value $wavelength_value \
      -trackrate $trackrate
}
