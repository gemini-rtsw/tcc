#+
#  GuideControl <- ComponentControl
#
#  A GuideControl is a ComponentControl widget with widgets for the target 
#  name and chop and node states for each of the wavefront sensors.
#
#  Options:
#
#  D Terrett 4 November 2002
#
#  Copyright CCLRC
#+

itcl::class GuideControl {
   inherit ComponentControl
   constructor {args} {}
   itk_option define -component component Component {}
   public {
      method load {name}
      method reset {}
      method save {name}
   }
   private {
      method filter {wfs}
      variable defaultwavels
   }
}

itk::usual GuideControl {
   keep -borderwidth -cursor -font -highlightthickness -insertborderwidth \
         -insertofftime -insertontime -insertwidth -labelfont -popupcursor \
         -selectborderwidth -textfont -title
}

itcl::body GuideControl::constructor {args} {

# Create 3 panels, one for each of the wave front sensors.
   set w $itk_interior
   foreach wfs {pwfs1 pwfs2 oiwfs} {
      itk_component add $wfs {
         frame $w.$wfs -bd 2 -relief sunken
      }
   }
   pack $itk_component(pwfs1) $itk_component(pwfs2) $itk_component(oiwfs)

   foreach wfs {pwfs1 pwfs2 oiwfs} label {PWFS1 P2/AO OIWFS} {
      set w $itk_component($wfs)

# Chop state
      itk_component add ${wfs}chop {
         iwidgets::optionmenu $w.chop \
               -labeltext "$label probe follows star" \
               -labelpos nw
      }
      [$itk_component(${wfs}chop) component menuBtn] configure -anchor w
      $itk_component(${wfs}chop) insert end \
            "when in chop beam A" \
            "when in chop beam B" \
            "when chop beam matches nod" \
            "when chop beam doesn't match nod" \
            "never"

# Nod setting
      itk_component add ${wfs}nod {
         iwidgets::optionmenu $w.nod -labeltext "and in"
      }
      [$itk_component(${wfs}nod) component menuBtn] configure -anchor w
      $itk_component(${wfs}nod) insert end \
            "nod state A only" "nod state B only" "both nod states"
      pack $itk_component(${wfs}chop) $itk_component(${wfs}nod) \
            -padx 5 -pady 2 -anchor w

# Effective wavelength.
      if { $wfs == "oiwfs" } {

# A subcomponent selector for the OIWFS.
         itk_component add oiwfsfilter {
            WavelengthSelector $w.oiwfsfilter -labeltext "with filter" \
                  -labelpos w
         }
         pack $itk_component(${wfs}filter) -anchor w -padx 3 -pady 3
      } else {

# An option menus and an entry field for the PWFSs.
         itk_component add ${wfs}filter {
            iwidgets::optionmenu $w.${wfs}filter -labeltext "with filter" \
                  -command [itcl::code $this filter $wfs]
         }
         $itk_component(${wfs}filter) insert end neutral Blue Green Red Red04 \
               Red1 ""
         if { $wfs == "pwfs2" } {
            $itk_component(${wfs}filter) insert Red1 "ALTAIR"
         }
         itk_component add ${wfs}wavel {
            iwidgets::entryfield $w.${wfs}wavel -labeltext "Wavelength (um)" \
                  -width 8
         }
         pack $itk_component(${wfs}filter) $itk_component(${wfs}wavel) \
               -anchor w -padx 3 -pady 3
      }
   }

# Define the object description.
   set description "guide configuration"

# Define the default wavelengths for the peripheral wave-front filters.
   array set defaultwavels {neutral 0.65 Blue 0.45 Green 0.55 Red 0.60 \
         Red04 0.64 Red1 0.70 ALTAIR 0.70}

   eval itk_initialize $args
}

itcl::body GuideControl::save {name} {
#+
# Updates the named guide object.
#-
   foreach wfs {pwfs1 pwfs2 oiwfs} {
      switch [$itk_component(${wfs}nod) index \
            [$itk_component(${wfs}nod) get]] {
         0 {set nod A}
         1 {set nod B}
         2 {set nod AB}
      }
      switch [$itk_component(${wfs}chop) index \
            [$itk_component(${wfs}chop) get]] {
         0 {set chop A}
         1 {set chop B}
         2 {set chop Nod}
         3 {set chop antiNod}
         4 {set chop never}
      }
      $name configure -${wfs}Active $chop -${wfs}NodState $nod
      if { $wfs == "oiwfs" } {
         $name configure -oiwfsWavelength [$itk_component(oiwfsfilter) get name]
      } else {
         $name configure -${wfs}Filter [$itk_component(${wfs}filter) get] \
               -${wfs}Wavel [$itk_component(${wfs}wavel) get]
      }
   }
}

itcl::body GuideControl::load {name} {

# Copy the contents of the guide object selected in the combobox
# into the edit control.
   foreach wfs {pwfs1 pwfs2 oiwfs} {
      switch [$name cget -${wfs}Active] {
         A {$itk_component(${wfs}chop) select 0}
         B {$itk_component(${wfs}chop) select 1}
         Nod {$itk_component(${wfs}chop) select 2}
         antiNod {$itk_component(${wfs}chop) select 3}
         default {$itk_component(${wfs}chop) select 4}
      }
      switch [$name cget -${wfs}NodState] {
         A {$itk_component(${wfs}nod) select 0}
         B {$itk_component(${wfs}nod) select 1}
         AB {$itk_component(${wfs}nod) select 2}
      }
      if { $wfs != "oiwfs" } {
         $itk_component(${wfs}filter) select [$name cget -${wfs}Filter]
         set wavel [$name cget -${wfs}Wavel]
         if { $wavel != "" } {
            $itk_component(${wfs}wavel) clear
            $itk_component(${wfs}wavel) insert end $wavel
         }
      } else {
         set ::Config($itk_option(-component).oiwfswavelength,value) \
               [$name cget -oiwfsWavelength]
      }
   }
}

itcl::body GuideControl::reset {} {
   $itk_component(pwfs1wavel) clear
   $itk_component(pwfs2wavel) clear
   $itk_component(pwfs1filter) select ""
   $itk_component(pwfs2filter) select ""
}

itcl::configbody GuideControl::component {
   if { $itk_option(-component) != "" } {
      $itk_component(oiwfsfilter) configure \
            -component $itk_option(-component).oiwfswavelength
   }
}

itcl::body GuideControl::filter {wfs} {
   set filt [$itk_component(${wfs}filter) get]
   if { $filt != "" } {
      $itk_component(${wfs}wavel) clear
      $itk_component(${wfs}wavel) insert end $defaultwavels($filt)
   }
}
