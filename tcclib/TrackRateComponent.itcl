#+
#  TrackRateComponent <- TrackRate, tcclib::Component
#
#  A TrackRateComponent object is a TrackRate object that is stored in a 
#  configuration list.
#
#
#  Options:
#           none
#
#  Methods:
#           constructor list  Creates the TrackRate object and puts it onto
#                           "list".
#
#  D Terrett 19 September 2001
#
#  Copyright CCLRC
#+

itcl::class TrackRateComponent {
   inherit tcclib::Component TrackRate
   constructor {list args} {
      tcclib::Component::constructor $list
   } {
      eval configure $args
   }
}
