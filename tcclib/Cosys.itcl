#+
#  Cosys
#
#  A Cosys object stores a frame and an equinox.
#
#  Options:
#           -frame          The coordinate frame 
#
#           -equinox        The equinox of the frame
#
#  Methods:
#           apply cs        Sets the system and equinox paramters of the
#                           command sender "cs".
#
#           init            Returns the cosys object to its initial state.
#
#           save file       Writes the values of the options to the file
#                           descriptor "file".
#
#  Procs:
#           subcomponents   Returns a list of the subcomponents of the 
#                           Cosys objects (an empty list).
#
#  D Terrett 20 March 2001
#
#  Copyright CCLRC
#+

itcl::class Cosys {
   public proc subcomponents {} {return {}}
   public {
      method apply {cs}
      method init {}
      method save {file}
      variable frame {}
      variable equinox {}
      variable isazel {}
   }
}

itcl::body Cosys::apply cs {
   cs $cs set system [list $frame]
   cs $cs set equinox [list $equinox]
   logger command $cs
}

itcl::body Cosys::init {} {
   set system ""
   set equinox ""
}

itcl::body Cosys::save file {
   puts $file "   -frame [list $frame] \\"
   puts $file "   -equinox [list $equinox]"
}

itcl::configbody Cosys::frame {
   set isazel [string equal -nocase $frame AzEl]
}
