#+
#  GuideLoop <- itk::Widget
#
#  A GuideLoop is a diagram of the various guiding loops with control
#  for setting them up and enabling them
#
#  Options:
#           none
#
#  Methods:
#           none
#
#  D Terrett  30 April 2001
#
#  Copyright CCLRC
#+

itcl::class GuideLoop {
   inherit itk::Widget
   constructor args {}
   destructor {}
   private {
      method m1mode {state}
      method mtmode {state}
      method m2mode {state}
      method prmode {state}
      method wfsmode {wfs state}
      method recolour {args}
      variable m1Weight
   }
}

itk::usual GuideLoop {
   keep -cursor -foreground -background
}

itcl::body GuideLoop::constructor args {

# Create canvas.
   itk_component add canv {
      canvas $itk_interior.canv -width 630 -height 455 -borderwidth 2 \
            -relief sunken
   }
   pack $itk_component(canv)
   set w $itk_component(canv)

# WFS boxes
   foreach sys {pwfs1 pwfs2 oiwfs} {
      itk_component add $sys {
         SelectButton $w.$sys -command [code $this wfsmode $sys] \
               -orient vertical
      } {
         usual
         rename -offbackground -background background Background
      }
      $w create window 32 34 -width 60 -window $w.$sys -tags $sys
      $itk_component($sys) add ON -pady 0
      $itk_component($sys) add OFF -pady 0
      $itk_component($sys) add Q/L -pady 0
      itk_component add ${sys}_label {
         label $w.${sys}_label -text [string toupper $sys]
      }
      $w create rectangle 0 0 132 67 -fill white -tags "active ${sys} ${sys}_bg"

# WFS controls.
      itk_component add ${sys}_ex {
         iwidgets::combobox $w.${sys}_ex -arrowrelief flat -width 5 \
               -validate real -labeltext "exp(s)"
      }
      $w create window 60 80 -window $w.${sys}_ex -tag $sys
      $w.${sys}_ex insert list end 1.0 0.5 0.1 0.05 0.01 0.005
      $w.${sys}_ex insert entry end 0.05
      [$w.${sys}_ex component list] configure -hscrollmode none \
            -vscrollmode none
   }

# Find the name of the font used for the buttons and use it for all text.
   set font [$w.oiwfs cget -font]

   foreach sys {pwfs1 pwfs2 oiwfs} label {PWFS1 PWFS2 OIWFS} {
      $w create text 92 35 -text $label -tags $sys -font $font
   }

# M1, M2 and Mount boxes.
   $w create rectangle 0 0 132 89 -fill white -tags "active m2 m2_bg"
   $w create text 92 45 -text M2 -tags m2 -font $font
   $w create rectangle 0 0 132 47 -fill white -tags "active m1 m1_bg"
   $w create text 92 25 -text "M1 FIG" -tags m1 -font $font
   $w create rectangle 0 0 132 89 -fill white -tags "active mount mount_bg"
   $w create text 92 44 -text MOUNT -tags mount -font $font

# Controls for M1.
   itk_component add m1 {
      SelectButton $w.m1 -command [code $this m1mode] -orient vertical
   } {
      usual
      rename -offbackground -background background Background
   }
   $w create window 32 24 -width 60 -window $w.m1 -tags m1
   $itk_component(m1) add ON -pady 0
   $itk_component(m1) add OFF -pady 0

# Controls for M2
   itk_component add m2 {
      SelectButton $w.m2 -command [code $this m2mode] -orient vertical
   } {
      usual
      rename -offbackground -background background Background
   }
   $w create window 32 45 -width 60 -window $itk_component(m2) -tags m2
   $itk_component(m2) add P1 -pady 0
   $itk_component(m2) add P2 -pady 0
   $itk_component(m2) add OIWFS -pady 0
   $itk_component(m2) add OFF -pady 0

# Controls for Mount.
   itk_component add mt {
      SelectButton $w.mt -command [code $this mtmode] -orient vertical
   } {
      usual
      rename -offbackground -background background Background
   }
   $w create window 32 45 -width 60 -window $itk_component(mt) -tags mount
   $itk_component(mt) add M2 -pady 0
   $itk_component(mt) add P1 -pady 0
   $itk_component(mt) add P2 -pady 0
   $itk_component(mt) add OFF -pady 0

# Box for WFS probes.
   $w create rectangle 0 0 132 67 -fill white -tags "active probes probes_bg"
   $w create text 92 35 -text PROBES -tags probes -font $font

# Controls for probes.
   itk_component add pr {
      SelectButton $w.pr -command [code $this prmode] -orient vertical
   } {
      usual
      rename -offbackground -background background Background
   }
   $w create window 32 34 -width 60 -window $w.pr -tags probes
   $itk_component(pr) add P1 -pady 0
   $itk_component(pr) add P2 -pady 0
   $itk_component(pr) add OFF -pady 0

# Move boxes into position.
   $w move m2 250 10
   $w move m1 250 115
   $w move pwfs1 50 180
   $w move oiwfs 250 180
   $w move pwfs2 450 180
   $w move probes 250 280
   $w move mount 250 360

# PWFS1 to M1
   $w create line 150 182 150 130 252 130 -width 3 -fill white \
         -tags {active pwfs1_m1} -arrow last -arrowshape {20 20 7}

# WFS to M2
   $w create line 100 182 100  60 252  60 -width 3 -fill white \
         -tags {active pwfs1_m2} -arrow last -arrowshape {20 20 7}
   $w create line 379 210 410 210 410  60 379  60 -width 3 -fill white \
         -tags {active oiwfs_m2} -arrow last -arrowshape {20 20 7}
   $w create line 580 190 610 190 610  40 379  40 -width 3 -fill white \
         -tags {active pwfs2_m2} -arrow last -arrowshape {20 20 7}

# WFS to Probes
   $w create line 180 200 220 200 220 310 251 310 -width 3 -fill white \
         -tags {active pwfs1_pr} -arrow last -arrowshape {20 20 7}
   $w create line 580 230 590 230 590 310 379 310 -width 3 -fill white \
         -tags {active pwfs2_pr} -arrow last -arrowshape {20 20 7}

# PWFS to mount
   $w create line 180 220 200 220 200 380 251 380 -width 3 -fill white \
         -tags {active pwfs1_mt} -arrow last -arrowshape {20 20 7}
   $w create line 580 210 610 210 610 380 379 380 -width 3 -fill white \
         -tags {active pwfs2_mt} -arrow last -arrowshape {20 20 7}

# M2 to mount
   $w create line 252  40  20  40  20 400 251 400 -width 3 -fill white \
         -tags {active m2_mt} -arrow last -arrowshape {20 20 7}

# Create the command senders required by this screen.
   if { [catch {cs m1Guide info}] } {
      epics cs m1Guide
   }
   if { [catch {cs m1GuideConfig info}] } {
      epics cs m1GuideConfig
   }
   if { [catch {cs mountGuide info}] } {
      epics cs mountGuide
   }
   if { [catch {cs m2Guide info}] } {
      epics cs m2Guide
   }
   if { [catch {cs m2GuideConfig info}] } {
      epics cs m2GuideConfig
   }
   if { [catch {cs wfsGuideMode info}] } {
      epics cs wfsGuideMode
   }
   if { [catch {cs pwfs1Observe info}] } {
      epics cs pwfs1Observe
   }
   if { [catch {cs pwfs1StopObserve info}] } {
      epics cs pwfs1StopObserve
   }
   if { [catch {cs pwfs2Observe info}] } {
      epics cs pwfs2Observe
   }
   if { [catch {cs pwfs2StopObserve info}] } {
      epics cs pwfs2StopObserve
   }
   if { [catch {cs oiwfsObserve info}] } {
      epics cs oiwfsObserve
   }
   if { [catch {cs oiwfsStopObserve info}] } {
      epics cs oiwfsStopObserve
   }

# Create status acceptor for guide state
   if { [catch {sa guideConfig info}] } {
      epics sa guideConfig
   }

# Monitor the guide states
   foreach rec {p1state p2state oistate m2state absorbtilt m1state \
         wfsstate wfsprobe} {
      sa guideConfig proc $rec [code $this recolour]
   }

   eval itk_initialize $args
}

itcl::body GuideLoop::destructor {} {
   foreach rec {p1state p2state oistate m2state absorbtilt m1state \
         wfsstate wfsprobe} {
      sa guideConfig unproc $rec [code $this recolour]
   }
}

body GuideLoop::recolour args {

   set w $itk_component(canv)

# Set state variables according to the values in the guideConfig status
# acceptor.
   switch [sa guideConfig get p1state value] {
      Yes {
         set pwfs1 1
      }
      No -
      default {
         set pwfs1 0
      }
   }
   switch [sa guideConfig get p2state value] {
      Yes {
         set pwfs2 1
      }
      No -
      default {
         set pwfs2 0
      }
   }
   switch [sa guideConfig get oistate value] {
      Yes {
         set oiwfs 1
      }
      No -
      default {
         set oiwfs 0
      }
   }
   switch [sa guideConfig get m1state value] {
      On {
         set m1_sw 1
      }
      Off -
      default {
         set m1_sw 0
      }
   }
   switch [sa guideConfig get m2state value] {
      On {
         set m2_sw 1
      }
      Off -
      default {
         set m2_sw 0
      }
   }
   switch [sa guideConfig get absorbtilt value] {
      3 {
         set mt_sw 1
      }
      4 {
         set mt_sw -1
      }
      0 -
      default {
         set mt_sw 0
      }
   }
   switch [string tolower [sa guideConfig get wfsstate value]] {
      on {
         switch [string tolower [sa guideConfig get wfsprobe value]] {
            pwfs1 {
               set wfs_sw 1
            }
            pwfs2 {
               set wfs_sw 2
            }
            default {
               set wfs_sw 0
            }
         }
      }
      off -
      default {
         set wfs_sw 0
      }
   }

   set m2 0
   set m1 0

# Set everything to white.
   $w itemconfigure active -fill white

   if { $pwfs1 } {
      set pwfs 1
      $w itemconfigure pwfs1_bg -fill green
      $w itemconfigure pwfs1_m1 -fill green
      $w itemconfigure pwfs1_m2 -fill green
      $w itemconfigure pwfs1_pr -fill green
      $w itemconfigure pwfs1_mt -fill green
      if { $m1_sw } {
         $w itemconfigure m1_bg -fill green
      }
   }
   if { $pwfs2 } {
      set pwfs 1
      $w itemconfigure pwfs2_bg -fill green
      $w itemconfigure pwfs2_m2 -fill green
      $w itemconfigure pwfs2_pr -fill green
      $w itemconfigure pwfs2_mt -fill green
   }
   if { $oiwfs } {
      set wfs 1
      $w itemconfigure oiwfs_bg -fill green
      $w itemconfigure oiwfs_m2 -fill green
   }
   if { $m2_sw } {
      set p [$itk_component(m2) get]
      if { ( $oiwfs && [string equal $p OIWFS] ) || 
            ( $pwfs1 && [string equal $p P1] ) || 
            ( $pwfs2 && [string equal $p P2] ) } {
         $w itemconfigure m2_bg -fill green
         $w itemconfigure m2_mt -fill green
         set m2 1
      } else {
         $w itemconfigure m2_bg -fill yellow
         $w itemconfigure m2_mt -fill yellow
      }
   }
   if { $mt_sw == 1 } {
      if { $m2 } {
         $w itemconfigure mount_bg -fill green
      } else {
         $w itemconfigure mount_bg -fill yellow
      }
   } elseif { $mt_sw == -1 } {
      set p [$itk_component(mt) get]
      if { ( $pwfs1 && [string equal $p P1] ) || 
            ( $pwfs2 && [string equal $p P2] ) } {
         $w itemconfigure mount_bg -fill green
      } else {
         $w itemconfigure mount_bg -fill yellow
      }
   }
   if { $m1_sw } {
      if { $pwfs1} {
         $w itemconfigure m1_bg -fill green
         set m2 1
      } else {
         $w itemconfigure m1_bg -fill yellow
      }
   }
   if { $wfs_sw } {
      if { ($wfs_sw == 1 && $pwfs1) || ($wfs_sw == 2 && $pwfs2) } {
         $w itemconfigure probes_bg -fill green
      } else {
         $w itemconfigure probes_bg -fill yellow
      }
   }
}

body GuideLoop::m1mode state {

   switch $state {
      ON {
         cs m1Guide set mode On
      }
      OFF {
         cs m1Guide set mode Off
      }
   }
   logger command m1Guide

   if { [catch {cs tcsApply post} msg] } {
      tk_messageBox -icon error -parent $itk_interior -message \
            "Error posting m1Guide command: TCS reports \
            \"$msg\""
   }
}

body GuideLoop::mtmode state {

   switch $state {
      OFF {
          cs mountGuide set mode Off
      }
      M2 {
          cs mountGuide set mode On
          cs mountGuide set source SCS 
      }
      P1 {
          cs mountGuide set mode On
          cs mountGuide set source AG 
          cs mountGuide set p1weight 1.0
          cs mountGuide set p2weight 0.0
      }
      P2 {
          cs mountGuide set mode On
          cs mountGuide set source AG 
          cs mountGuide set p1weight 0.0
          cs mountGuide set p2weight 1.0
      }
   }
   logger command mountGuide

   if { [catch {cs mountGuide post} msg] } {
      tk_messageBox -icon error -parent $itk_interior -message \
            "Error posting mountGuide command: TCS reports \
            \"$msg\""
   }
   recolour
}

body GuideLoop::m2mode state {

# Turn guiding off.
   cs m2Guide set state Off
   logger command m2Guide
   if { [catch {cs m2Guide post} msg] } {
      tk_messageBox -icon error -parent $itk_interior -message \
            "Error posting m2Guide command: TCS reports \
            \"$msg\""
   }

   if { ![string equal OFF $state] } {

# Set up M2 guide parameters.
      cs m2GuideConfig set samplefreq 200
      cs m2GuideConfig set filter raw
      cs m2GuideConfig set freq1 ""
      cs m2GuideConfig set freq2 ""
      cs m2GuideConfig set beam A
      cs m2GuideConfig set reset On
      switch $state {
         P1 {
            cs m2GuideConfig set source PWFS1
         }
         P2 {
            cs m2GuideConfig set source PWFS2
         }
         OIWFS {
            cs m2GuideConfig set source OIWFS
         }
      }
      logger command m2GuideConfig
      if { [catch {cs m2GuideConfig post} msg] } {
         tk_messageBox -icon error -parent $itk_interior -message \
               "Error posting m2GuideConfig command: TCS reports \
               \"$msg\""
      }

      cs m2GuideConfig set reset Off
      logger command m2GuideConfig
      if { [catch {cs m2GuideConfig post} msg] } {
         tk_messageBox -icon error -parent $itk_interior -message \
               "Error posting m2GuideConfig command: TCS reports \
               \"$msg\""
      }

# Turn guiding on.
      cs m2Guide set state On
      logger command m2Guide
      if { [catch {cs m2Guide post} msg] } {
         tk_messageBox -icon error -parent $itk_interior -message \
               "Error posting m2Guide command: TCS reports \
               \"$msg\""
      }
   }
   recolour
}

body GuideLoop::prmode state {

   switch $state {
      OFF {
         cs wfsGuideMode set state Off
      }
      P1 {
         cs wfsGuideMode set state On
         cs wfsGuideMode set probe PWFS1
      }
      P2 {
         cs wfsGuideMode set state On
         cs wfsGuideMode set probe PWFS2
      }
   }
   logger command wfsGuideMode

   if { [catch {cs wfsGuideMode post} msg] } {
      tk_messageBox -icon error -parent $itk_interior -message \
            "Error posting wfsGuideMode command: TCS reports \
            \"$msg\""
   }
   recolour
}

body GuideLoop::wfsmode {wfs state} {

   switch $state {
      ON -
      Q/L {
         cs ${wfs}Observe set noexp -1
         cs ${wfs}Observe set int [$itk_component(${wfs}_ex) get]
         if { [string equal $state Q/L] } {
            cs ${wfs}Observe set outopt DHS
            cs ${wfs}Observe set output QL
         } else {
            cs ${wfs}Observe set outopt NONE
            cs ${wfs}Observe set output ""
         }
         logger command ${wfs}Observe
      }
      OFF {
         cs ${wfs}StopObserve set dummy MARK
         logger command ${wfs}StopObserve
      }
   }

   if { [catch {cs ${wfs}Observe post} msg] } {
      tk_messageBox -icon error -parent $itk_interior -message \
            "Error posting ${wfs} command: TCS reports \"$msg\""
   }
}
