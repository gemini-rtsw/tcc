#+
#  TargetControl <- ComponentControl
#
#  A Target control is a ComponentControl widget with widgets for
#  the target position etc. It is intended to be inherited by widgets
#  for specific target types (science & wfs).
#
#  Options:
#           -component      The component that the control edits
#
#  Methods:
#
#  D Terrett 9 May 2002
#
#  Copyright CCLRC
#+

itcl::class TargetControl {
   inherit ComponentControl
   constructor args {}
   destructor {}
   itk_option define -component component Component ""
   public {
      method load {name}
      method reset {}
      method save {name}
      method copy {createproc prompt component}
   }
   private {
      method checkcosys {}
      method grab {}
      method newlist {n1 n2 op}
      method newtrlist {n1 n2 op}
      variable comp ""
   }
}

itk::usual TargetControl {
   keep -borderwidth -cursor -font -highlightthickness -insertborderwidth \
         -insertofftime -insertontime -insertwidth -labelfont -popupcursor \
         -selectborderwidth -textfont -title
}

itcl::body TargetControl::constructor {args} {

# Expand component selector.
   $itk_component(selector) configure -width 43

   itk_component add frame {
      frame $itk_interior.frame -borderwidth 2 -relief ridge
   }
   pack $itk_component(frame) -fill x -expand y
   set w $itk_component(frame)

# Frame to highlight the position entry window.
   itk_component add highlight {
      frame $w.highlight
   } {
      usual
      ignore -background
   }
   pack $itk_component(highlight) -fill x -expand y
   set w $itk_component(highlight)

# Create tabnotebook for the target position.
   itk_component add notebook {
      iwidgets::tabnotebook $w.notebook -height 250 -width 450 
   }
   pack $itk_component(notebook)

# Page for RA/Dec
   set w [$itk_component(notebook) add -label "RA/Dec"]
   
# Frame for position.
   itk_component add pos {
      frame $w.pos
   }
   pack $itk_component(pos) -side left -expand yes -fill y

# RA and Dec.
   set w $itk_component(pos)
   itk_component add ra {
      iwidgets::entryfield $w.ra -width 12 -labeltext RA:
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add dec {
      iwidgets::entryfield $w.dec -width 12 -labeltext Dec:
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
#   pack $itk_component(ra) $itk_component(dec) -side left -expand y -pady 10
#   set w [winfo parent $w]

#  Coordinate frame.
   itk_component add cosys {
      SubComponentSelector $w.cosys -labeltext "Coordinate system" \
            -labelpos nw -selectioncommand [itcl::code $this checkcosys]
   }
   pack $itk_component(ra) $itk_component(dec) $itk_component(cosys) \
         -expand y -pady 10
   set w [winfo parent $w]

# Frame for space motions.
   itk_component add space {
      iwidgets::labeledframe $w.space -labeltext "Proper motions" \
            -labelpos nw
   }
   pack $itk_component(space) -expand y -fill y
   set w [$itk_component(space) childsite]

# Epoch.
   itk_component add epoch {
      iwidgets::entryfield $w.epoch -width 11 \
            -labeltext [lindex [cs sourceA info epoch] 2]
   }

# Proper motions.
   itk_component add pm1 {
      iwidgets::entryfield $w.pm1 -width 11 \
            -labeltext "RA (s/yr)"
   }
   itk_component add pm2 {
      iwidgets::entryfield $w.pm2 -width 11 \
            -labeltext "Dec (arcsec/yr)"
   }

# Parallax
   itk_component add parallax {
      iwidgets::entryfield $w.parallax -width 11 \
            -labeltext [lindex [cs sourceA info parallax] 2]
   }

# Radial velocity.
   itk_component add rv {
      iwidgets::entryfield $w.rv -width 11 \
            -labeltext [lindex [cs sourceA info rv] 2]
   }
   pack $itk_component(epoch) $itk_component(pm1) $itk_component(pm2) \
         $itk_component(parallax) $itk_component(rv) -padx 3 -pady 3 \
         -anchor e -expand yes

# Page for Az/El
   set w [$itk_component(notebook) add -label "Az/El"]
   
# Az and El.
   itk_component add az {
      iwidgets::entryfield $w.az -width 12 -labeltext Az:
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add el {
      iwidgets::entryfield $w.el -width 12 -labeltext El:
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   pack $itk_component(az) $itk_component(el) -side left -expand y -pady 40 \
      -anchor n

   set w $itk_component(frame)
   itk_component add trw {
      frame $w.trw
   }
   pack $itk_component(trw) -side left -fill x -expand yes

# Display of brightness.
   set w $itk_component(trw)
   itk_component add brightness {
      iwidgets::entryfield $w.brightness -labeltext Brightness -labelpos w
   }
   pack $itk_component(brightness) -side top -anchor w -padx 20 -pady 3 \
         -fill x -expand y

# Control for selecting a differential track rate.
   itk_component add trackrate {
      SubComponentSelector $w.trackrate -labeltext "Track rate" -labelpos w
   }
   pack $itk_component(trackrate) -side top -anchor w -padx 20 -pady 3

# Select the RA/Dec page.
  $itk_component(notebook) select RA/Dec

# Add a grab button to the storeapply window.
   itk_component add grab {
      button $itk_component(bottom).grab -text Grab \
            -command [itcl::code $this grab]
   }
   pack $itk_component(grab) -side left -pady 4 -expand y

   eval itk_initialize $args
}

itcl::body TargetControl::destructor {} {
   trace vdelete ::Config($comp,list) w [itcl::code $this newlist]
   trace vdelete ::Config($comp.trackrate,list) w [itcl::code $this newtrlist]
}

itcl::body TargetControl::reset {} {
   $itk_component(ra) clear
   $itk_component(dec) clear
   $itk_component(epoch) clear
   $itk_component(pm1) clear
   $itk_component(pm2) clear
   $itk_component(parallax) clear
   $itk_component(rv) clear
   $itk_component(az) clear
   $itk_component(el) clear
   $itk_component(brightness) clear
}

itcl::body TargetControl::load {name} {
   switch [$name cget -type] {
      hmsdegTarget {
         $itk_component(notebook) select RA/Dec
         set cosys [$name cget -cosys]
         if { [string is space $cosys] } {
               set ::Config($itk_option(-component).cosys,value) FK5/J2000
         } else {
            set ::Config($itk_option(-component).cosys,value) $cosys
         }
         $itk_component(ra) insert end [$name cget -c1]
         $itk_component(dec) insert end [$name cget -c2]
         $itk_component(epoch) insert end [$name cget -epoch]
         $itk_component(pm1) insert end [$name cget -pm1]
         $itk_component(pm2) insert end [$name cget -pm2]
         $itk_component(parallax) insert end [$name cget -parallax]
         $itk_component(rv) insert end [$name cget -rv]
      }
      degdegTarget {
         $itk_component(notebook) select Az/El
         $itk_component(az) insert end [$name cget -c1]
         $itk_component(el) insert end [$name cget -c2]
      }
   }
   $itk_component(brightness) insert end [$name cget -brightness]
   set ::Config($itk_option(-component).trackrate,value) [$name cget -trackrate]
}

itcl::body TargetControl::save {name} {
   set page [lindex [$itk_component(notebook) pageconfigure \
         [$itk_component(notebook) select select] -label] 4]
   switch $page {
      RA/Dec {
         $name configure \
               -type hmsdegTarget \
               -objname [$itk_component(selector) get] \
               -cosys [$itk_component(cosys) get] \
               -c1 [$itk_component(ra) get] \
               -c2 [$itk_component(dec) get] \
               -epoch [$itk_component(epoch) get] \
               -pm1 [$itk_component(pm1) get] \
               -pm2 [$itk_component(pm2) get] \
               -parallax [$itk_component(parallax) get] \
               -rv [$itk_component(rv) get] 
      }
      Az/El {
         $name configure \
               -type degdegTarget \
               -c1 [$itk_component(az) get] \
               -c2 [$itk_component(el) get]
      }
   }
   $name configure -brightness [$itk_component(brightness) get] \
         -trackrate [$itk_component(trackrate) get]
}

itcl::configbody TargetControl::component {

# remove any existing trace.
   trace vdelete ::Config($comp,list) w [itcl::code $this newlist]
   trace vdelete ::Config($comp.trackrate,list) w [itcl::code $this newtrlist]
   set comp ""

   if { $itk_option(-component) != "" } {

# Record current component name.
      set comp $itk_option(-component)

      $itk_component(cosys) configure -component ${comp}.cosys
      $itk_component(trackrate) configure -component ${comp}.trackrate

# The list of targets changes when a new field is selected so we must
# monitor the list name element of the config array.
      trace variable ::Config($comp,list) w [itcl::code $this newlist]
      trace variable ::Config($comp.trackrate,list) w \
           [itcl::code $this newtrlist]

# Initialise with the current list name.
      after idle [itcl::code $this newlist "" "" ""]
      after idle [itcl::code $this newtrlist "" "" ""]
   }
}

itcl::body TargetControl::checkcosys {} {
   set cosys [$itk_component(cosys) get]
   if { ! [string equal $cosys ""] } {
      if { [CosysNames::$cosys cget -isazel] } {
         $itk_component(notebook) select Az/El
         set ::Config($itk_option(-component).cosys,value) ""
      } else {
         $itk_component(notebook) select RA/Dec
      }
   }
}

body TargetControl::grab {} {

# Grab the current position from the telescope into the scratch target.
   $::Config($comp,anon) grab $comp

# Load the object into the controls
   $this reset
   $this load $::Config($comp,anon)
}

itcl::body TargetControl::newlist {n1 n2 op} {

# Re-configure the control.
  $itk_component(selector) configure -componentlist $::Config($comp,list)

# Select the current component.
  $itk_component(selector) select $::Config($comp,value)
}

itcl::body TargetControl::newtrlist {n1 n2 op} {

# Re-configure the control.
  $itk_component(trackrate) configure -componentlist \
       $::Config($comp.trackrate,list)

# Select the current component.
  [$itk_component(trackrate) component selector] \
        select $::Config($comp.trackrate,value)
}
