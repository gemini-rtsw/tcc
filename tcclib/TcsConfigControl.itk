#+
#  TcsConfigControl <- tcclib::ComponentControl
#
#  Implements the TcsConfigControl widget.
#
#  D Terrett 29 March 2001
#
#  Copyright CCLRC
#+

itcl::class TcsConfigControl {
   inherit tcclib::ComponentControl
   constructor args {}
   itk_option define -shadow shadow Shadow {}
   public {
      method preview {}
      method selectobj {name}
      method updateobj {name}
   }
   private {
      method apply {}
      method wrap {par}
      variable components {
         scienceTarget guide pointOrig slewOptions rotator chop trackFrame \
               instrument
      }
      variable options {
         -scienceTarget -guide -pointOrig -slewOptions -rotator -chop \
               -trackFrame -instrument
      }
      variable lists {
         ScienceTargetList GuideList PointOrigList ChopList SlewOptionsList \
               RotatorList TrackFrameList InstrumentList
      }
   }
}

itk::usual TcsConfigControl {
   keep -borderwidth -cursor -font -highlightthickness -insertborderwidth \
         -insertofftime -insertontime -insertwidth -labelfont -popupcursor \
         -selectborderwidth -textfont -title -applyarg -namespace -componentlist
}

itcl::body TcsConfigControl::constructor args {

# Divide the window into 3 vertically.
   itk_component add row1 {
      frame $itk_interior.row1 -relief ridge -bd 2
   }
   itk_component add row2 {
      frame $itk_interior.row2 -relief ridge -bd 2
   }
   itk_component add row3 {
      frame $itk_interior.row3
   }
   pack $itk_component(row1) $itk_component(row2) $itk_component(row3) \
         -expand y -fill x

# Configuration component selectors.
   set w $itk_component(row1)
   itk_component add scienceTarget {
      ComponentSelector $w.scienceTarget -labeltext "Science Target" \
            -componentlist ScienceTargetList \
            -editcontrol tcsconfigscienceTarget \
            -active 1 -component scienceTarget
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add guide {
      ComponentSelector $w.guide -labeltext "Guide Configuration" \
            -componentlist GuideList \
            -editcontrol tcsconfigguide \
            -active 1 -component guide
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add rotator {
      ComponentSelector $w.rotator -labeltext "Field Orientation" \
            -componentlist RotatorList \
            -editcontrol tcsconfigrotator \
            -active 1 -component rotator
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add pointOrig {
      ComponentSelector $w.pointOrig -labeltext "Instrument Origin" \
            -componentlist PointOrigList \
            -editcontrol tcsconfigpointOrig \
            -active 1 -component pointOrig
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add chop {
      ComponentSelector $w.chop -labeltext "Chop Configuration" \
            -componentlist ChopList \
            -editcontrol tcsconfigchop \
            -active 1 -component chop
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add slewOptions {
      ComponentSelector $w.slewOptions -labeltext "Slew Options" \
            -componentlist SlewOptionsList \
            -editcontrol tcsconfigslewOptions \
            -active 1 -component slewOptions
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add trackFrame {
      ComponentSelector $w.trackFrame -labeltext "Tracking Frames" \
            -componentlist TrackFrameList \
            -editcontrol tcsconfigtrackFrame \
            -active 1 -component trackFrame
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }
   itk_component add instrument {
      ComponentSelector $w.instrument -labeltext "Instrument" \
            -componentlist InstrumentList \
            -editcontrol tcsconfiginstrument \
            -active 1 -component instrument
   } {
      usual
      rename -textfont -majorfont majorFont Font
      rename -labelfont -majorfont majorFont Font
   }

   pack $itk_component(scienceTarget) $itk_component(guide) \
         $itk_component(rotator) $itk_component(pointOrig) \
         $itk_component(chop) $itk_component(slewOptions) \
         $itk_component(trackFrame) $itk_component(instrument) \
         -fill x -pady 1

# Wrap control
   set w $itk_component(row2)
   itk_component add wraptitle {
      label $w.wraptitle -text "Wrap Control: "
   }
   itk_component add azwrap {
      iwidgets::optionmenu $w.azwrap -labeltext Azimuth
   }
   $itk_component(azwrap) insert end + "" -
   itk_component add rotwrap {
      iwidgets::optionmenu $w.rotwrap -labeltext Rotator
   }
   $itk_component(rotwrap) insert end + "" -
   itk_component add wrapapply {
      tcclib::ApplyButton $w.wrapapply -command wrap -text Apply \
            -parcommand [code $this wrap]
   }

   pack $itk_component(wrapapply) $itk_component(rotwrap) \
      $itk_component(azwrap) $itk_component(wraptitle) -side right -pady 3

# Replace the apply and store buttons with Slew/Set, Store and Preview buttons.
   pack forget $itk_component(storeapply)

   set w $itk_component(row3)
   itk_component add apply {
      tcclib::LiveButton $w.apply -text "Set/Slew" -command [code $this apply] \
            -width 8
   }
   itk_component add store {
      tcclib::StoreButton $w.store -text Store -width 8 \
            -combobox $itk_component(selector)
   } {
      usual
      keep -shadow
   }
   itk_component add preview {
      button $w.preview -text Preview -text Preview \
            -command [code $this preview] -width 8
   }
   pack $itk_component(apply) $itk_component(store) $itk_component(preview) \
         -side left -expand y -pady 4

# Create the config object used by apply.
   set scratchobj [namespace which -command [TcsConfig #auto]]

# Set the object class
   set objclass ConfigComponent
   set description configuration

# Select the default configuration. This has to be postponed until after
# the widget creation is complete in order that options crucial to the
# operation of the widget have been set.
   after idle [code $this selectobj TcsConfigNames::default]
   after idle $itk_component(selector) select default

   eval itk_initialize $args
}

itcl::body TcsConfigControl::apply {} {
#+
# Called when the apply button is pressed.
#-

# Process the wrap controls
   switch -- [$itk_component(azwrap) get] {
      + {cs wrap set azimuth 1}
      "" {cs wrap set azimuth 0}
      - {cs wrap set azimuth -1}
   }
   switch -- [$itk_component(rotwrap) get] {
      + {cs wrap set rotator 1}
      "" {cs wrap set rotator 0}
      - {cs wrap set rotator -1}
   }
   logger command wrap

# Call the normal apply function.
   $this ComponentControl::apply
}

itcl::body TcsConfigControl::updateobj name {
#+
#  Updates the named configuration with the active components.
#-
   foreach component $components option $options {
      if { [$itk_component($component) cget -active] } {
         $name configure \
                $option [[$itk_component($component) component selector] get]
      } else {
         $name configure $option ""
      }
   }
}

itcl::body TcsConfigControl::preview {} {
#+
#  Maps the preview window by calling the preview method for the
#  config object followed by the update method of the previewControl.
#-

# Create or map the preview panel.
   previewPanel map

# Store the values in the temporary config object.
   $itk_option(-shadow) storefromcontrol ""

# Initialise the preview system.
   tccPreview begin

# Load the preview system with the configuration.
   $scratchobj preview

# Call the preview panel's update method to generate and display the preview.
   [[previewPanel cget -name] component control] update
}

itcl::body TcsConfigControl::selectobj name {
#+
#  Updates the active components on the panel with the new configuration.
#-
   if { ! [string equal $name ""] } {
      foreach component $components option $options list $lists {
         if { [$itk_component($component) cget -active] } {
            set comp [$name cget $option]
            if { ! [string equal $comp ""] } {
               [$itk_component($component) component selector] select $comp
               $itk_component($component) configure \
                     -source [namespace tail $name]
            }
         }
      }
   }
}

itcl::configbody TcsConfigControl::shadow {
   $itk_component(scienceTarget) configure -shadow $itk_option(-shadow)
   $itk_component(guide) configure -shadow $itk_option(-shadow)
   $itk_component(rotator) configure -shadow $itk_option(-shadow)
   $itk_component(pointOrig) configure -shadow $itk_option(-shadow)
   $itk_component(chop) configure -shadow $itk_option(-shadow)
   $itk_component(slewOptions) configure -shadow $itk_option(-shadow)
   $itk_component(trackFrame) configure -shadow $itk_option(-shadow)
   $itk_component(instrument) configure -shadow $itk_option(-shadow)
}

itcl::body TcsConfigControl::wrap par {
   switch $par {
      azimuth {
         switch -- [$itk_component(azwrap) get] {
            + {return 1}
            "" {return 0}
            - {return -1}
         }
      }
      rotator {
         switch -- [$itk_component(rotwrap) get] {
            + {return 1}
            "" {return 0}
            - {return -1}
         }
      }
   }
}
