#+
#  GuideComponent.itcl
#
#  Implements the GuideComponent class. A GuideComponent object 
#  is a Guide object that is stored in a configuration list.
#
#  D Terrett 21 August 1998
#
#  Copyright CCLRC
#+

itcl::class GuideComponent {
   inherit Guide Component

   constructor {list args} {
      Component::constructor $list
   } {
      eval configure $args
   }

   public method save file
}

itcl::body GuideComponent::save file {
   set objname [namespace tail $this]
   set namespace [info namespace qualifiers $this]
   puts $file "catch {delete object \"$namespace::$objname\"}"
   puts $file "GuideComponent \"$namespace::$objname\"  $componentList \\"
   Guide::save $file
}
