#+
#  Guide
#
#  A guide component contains the names of the targes for the 3 wavefront 
#  sensors and which chop and nod states they should be active in.
#
#  Options:
#           -oiwfsTarget    The target for the on-instrument wavefront sensor.
#
#           -oiwfsChop      The chop state for the on-instrument wavefront 
#                           sensor.
#
#           -oiwfsNod       The nod state for the on-instrument wavefront 
#                           sensor.
#
#           -pwfs1Target    The target for peripheral wavefront sensor 1.
#
#           -pwfs1Chop      The chop state for the peripheral wavefront 
#                           sensor 1.
#
#           -pwfs1Nod       The nod state for the peripheral wavefront 
#                           sensor 1.
#
#           -pwfs2Target    The target for peripheral wavefront sensor 2.
#
#           -pwfs2Chop      The chop state for the peripheral wavefront 
#                           sensor 2.
#
#           -pwfs2Nod       The nod state for the peripheral wavefront 
#                           sensor 2.
#
#  Methods:
#           apply cs        Sets the system and equinox paramters of the
#                           command sender "cs".
#
#           init            Returns the guide object to its initial state.
#
#           preview         Sets the guide information in the preview.
#
#           save file       Writes the values of the options to the file
#                           descriptor "file".
#
#  Procs:
#           subcomponents   Returns a list of the Guide components 
#                           subcomponents.
#
#  D Terrett 26 September 2000
#
#  Copyright CCLRC
#+

itcl::class Guide {
   constructor {} {}
   destructor {$this init}

   public proc subcomponents {}

   public variable oiwfsTarget "" {newTarget oiwfs $oiwfsTarget}
   public variable oiwfsChop A
   public variable oiwfsNod AB
   public variable pwfs1Target "" {newTarget pwfs1 $pwfs1Target}
   public variable pwfs1Chop A
   public variable pwfs1Nod AB
   public variable pwfs2Target "" {newTarget pwfs2 $pwfs2Target}
   public variable pwfs2Chop A
   public variable pwfs2Nod AB

   public method apply args
   public method init
   public method preview
   public method save file

   private method setEnableFlags {wfs chop nod}
   private method newTarget {wfs name}
   private method park {wfs}

   private variable current_target
}

itcl::body Guide::constructor {} {
   set current_target(oiwfs) ""
   set current_target(pwfs1) ""
   set current_target(pwfs2) ""
}

itcl::body Guide::subcomponents {} {
   return { \
      {pwfs1Target WfsTarget WfsTargetNames WfsTargetList {PWFS1 Target} pwfs1} \
      {pwfs2Target WfsTarget WfsTargetNames WfsTargetList {PWFS2 Target} pwfs2} \
      {oiwfsTarget WfsTarget WfsTargetNames WfsTargetList {OIWFS Target} oiwfs} \
   }
}

itcl::body Guide::apply args {

# Call the apply method of all the targets that have a value and set the
# enable flags.
   if { ![string is space $pwfs1Target] } {
      ::WfsTargetNames::$pwfs1Target apply pwfs1
      setEnableFlags pwfs1 $pwfs1Chop $pwfs1Nod
   } else {
      setEnableFlags pwfs1 "" ""
      park pwfs1
   }
   if { ![string is space $pwfs2Target] } {
      ::WfsTargetNames::$pwfs2Target apply pwfs2
      setEnableFlags pwfs2 $pwfs2Chop $pwfs2Nod
   } else {
      setEnableFlags pwfs2 "" ""
      park pwfs2
   }
   if { ![string is space $oiwfsTarget] } {
      ::WfsTargetNames::$oiwfsTarget apply oiwfs
      setEnableFlags oiwfs $oiwfsChop $oiwfsNod
   } else {
      setEnableFlags oiwfs "" ""
   }
}

itcl::body Guide::init {} {
   $this configure -oiwfsTarget ""
   set oiwfsChop A
   set oiwfsNod AB
   $this configure -pwfs1Target ""
   set pwfs1Chop A
   set pwfs1Nod AB
   $this configure -pwfs2Target ""
   set pwfs2Chop A
   set pwfs2Nod AB
}

itcl::body Guide::preview {} {
   if { $pwfs1Target != "" } {
      ::WfsTargetNames::$pwfs1Target preview pwfs1
   }
   if { $pwfs2Target != "" } {
      ::WfsTargetNames::$pwfs2Target preview pwfs2
   }
   if { $oiwfsTarget != "" } {
      ::WfsTargetNames::$oiwfsTarget preview oiwfs
   }
}

itcl::body Guide::save file {
   puts $file "   -pwfs1Target \"$pwfs1Target\" \\"
   puts $file "   -pwfs1Chop $pwfs1Chop \\"
   puts $file "   -pwfs1Nod $pwfs1Nod \\"
   puts $file "   -pwfs2Target \"$pwfs2Target\" \\"
   puts $file "   -pwfs2Chop $pwfs2Chop \\"
   puts $file "   -pwfs2Nod $pwfs2Nod \\"
   puts $file "   -oiwfsTarget \"$oiwfsTarget\" \\"
   puts $file "   -oiwfsChop $oiwfsChop \\"
   puts $file "   -oiwfsNod $oiwfsNod"
}

itcl::body Guide::setEnableFlags {wfs chop nod} {
   if { [string first A $chop] != -1 } {
      set chopa 1
   } else {
      set chopa 0
   }
   if { [string first B $chop] != -1 } {
      set chopb 1
   } else {
      set chopb 0
   }
#   if { [string first C $chop] != -1 } {
#      set chopc 1
#   } else {
#      set chopc 0
#   }
   if { [string first A $nod] != -1 } {
      set noda 1
   } else {
      set noda 0
   }
   if { [string first B $nod] != -1 } {
      set nodb 1
   } else {
      set nodb 0
   }
#   if { [string first C $nod] != -1 } {
#      set nodc 1
#   } else {
#      set nodc 0
#   }
   if { $chopa && $noda } {
      cs ${wfs}Guide set nodachopa On
   } else {
      cs ${wfs}Guide set nodachopa Off
   }
   if { $chopb && $noda } {
      cs ${wfs}Guide set nodachopb On
   } else {
      cs ${wfs}Guide set nodachopb Off
   }
#   if { $chopc && $noda } {
#      cs ${wfs}Guide set nodachopc On
#   } else {
#      cs ${wfs}Guide set nodachopc Off
#   }
   if { $chopa && $nodb } {
      cs ${wfs}Guide set nodbchopa On
   } else {
      cs ${wfs}Guide set nodbchopa Off
   }
   if { $chopb && $nodb } {
      cs ${wfs}Guide set nodbchopb On
   } else {
      cs ${wfs}Guide set nodbchopb Off
   }
#   if { $chopc && $nodb } {
#      cs ${wfs}Guide set nodbchopc On
#   } else {
#      cs ${wfs}Guide set nodbchopc Off
#   }
#   if { $chopa && $nodc } {
#      cs ${wfs}Guide set nodcchopa On
#   } else {
#      cs ${wfs}Guide set nodcchopa Off
#   }
#   if { $chopb && $nodc } {
#      cs ${wfs}Guide set nodcchopb On
#   } else {
#      cs ${wfs}Guide set nodcchopb Off
#   }
#   if { $chopc && $nodc } {
#      cs ${wfs}Guide set nodcchopc On
#   } else {
#      cs ${wfs}Guide set nodcchopc Off
#   }
   logger command ${wfs}Guide
}

itcl::body Guide::newTarget {wfs name} {
   if { $current_target($wfs) != "" } {
      WfsTargetNames::$current_target($wfs) refdec
   }
   set current_target($wfs) ""
   if { ![string is space $name] } {
      if { [catch {WfsTargetNames::$name refinc}] } {
         error "Guide target \"$name\" does not exist"
      } else {
         set current_target($wfs) $name
      }
   }
}

itcl::body Guide::park {wfs} {
   switch $wfs {
      pwfs1 {
         cs pwfs1Park set dummy value 1
         logger command pwfs1Park
      }
      pwfs2 {
         cs pwfs2Park set dummy value 1
         logger command pwfs2Park
      }
   }
}
