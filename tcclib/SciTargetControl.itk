#+
#  SciTargetControl <- TargetControl
#
#  A SciTarget control is a TargetControl widget with widgets for
#  the target position etc.
#
#  D Terrett 7 April 2002
#
#  Copyright CCLRC
#+

itcl::class SciTargetControl {
   inherit TargetControl
   constructor args {}
   public {
      method load {name}
      method reset {}
      method save {name}
   }
   private {
      method orbtype {}
      method selplanet {}
      variable planet
   }
}

itk::usual SciTargetControl {
   keep -borderwidth -cursor -font -highlightthickness -insertborderwidth \
         -insertofftime -insertontime -insertwidth -labelfont -popupcursor \
         -selectborderwidth -textfont -title
}

itcl::body SciTargetControl::constructor args {

# Set colour of highlight frame.
   $itk_component(highlight) configure -background black

# Add page for planets
   set w [$itk_component(notebook) add -label "Planets" \
         -command "$itk_component(trackrate) configure -state disabled"]

# Radiobuttons for selecting a planet.
   itk_component add moon {
      radiobutton $w.moon -text Moon -variable [itcl::scope planet] \
            -value moon -command [itcl::code $this selplanet]
   }
   itk_component add mercury {
      radiobutton $w.mercury -text Mercury -variable [itcl::scope planet] \
            -value mercury -command [itcl::code $this selplanet]
   }
   itk_component add venus {
      radiobutton $w.venus -text Venus -variable [itcl::scope planet] \
            -value venus -command [itcl::code $this selplanet]
   }
   itk_component add mars {
      radiobutton $w.mars -text Mars -variable [itcl::scope planet] \
            -value mars -command [itcl::code $this selplanet]
   }
   itk_component add jupiter {
      radiobutton $w.jupiter -text Jupiter -variable [itcl::scope planet] \
            -value jupiter -command [itcl::code $this selplanet]
   }
   itk_component add saturn {
      radiobutton $w.saturn -text Saturn -variable [itcl::scope planet] \
            -value saturn -command [itcl::code $this selplanet]
   }
   itk_component add uranus {
      radiobutton $w.uranus -text Uranus -variable [itcl::scope planet] \
            -value uranus  -command [itcl::code $this selplanet]
   }
   itk_component add neptune {
      radiobutton $w.neptune -text Neptune -variable [itcl::scope planet] \
            -value neptune -command [itcl::code $this selplanet]
   }
   itk_component add pluto {
      radiobutton $w.pluto -text Pluto -variable [scope planet] -value pluto \
            -command [itcl::code $this selplanet]
   }
   grid $itk_component(moon) $itk_component(mars) $itk_component(uranus) \
         -padx 10 -pady 10 -sticky w
   grid $itk_component(mercury) $itk_component(jupiter) \
         $itk_component(neptune) -padx 10 -pady 10 -sticky w
   grid $itk_component(venus) $itk_component(saturn) $itk_component(pluto) \
         -padx 10 -pady 10 -sticky w

# Add page for orbits
   set w [$itk_component(notebook) add -label "Orbits" \
         -command "$itk_component(trackrate) configure -state disabled"]

# Option menu for the orbit type.
   itk_component add eltype {
      iwidgets::optionmenu $w.eltype -command [itcl::code $this orbtype]
   }
   $itk_component(eltype) insert end "Major planet orbital elements" \
         "Minor planet orbital elements" "Comet orbital elements"

# Entry widgets for each element.
   itk_component add epochofel {
      iwidgets::entryfield $w.epochofel -labeltext "epoch of elements (TT)"
   }
   itk_component add inclination {
      iwidgets::entryfield $w.inclination -labeltext \
            "Orbital inclination (deg)"
   }
   itk_component add anode {
      iwidgets::entryfield $w.anode -labeltext \
            "Longitude of ascending node (deg)"
   }
   itk_component add perihelion {
      iwidgets::entryfield $w.perihelion -labeltext \
            "Longitude of perihelion (deg)"
   }
   itk_component add aorq {
      iwidgets::entryfield $w.aorq -labeltext "Mean distance (AU)"
   }
   itk_component add e {
      iwidgets::entryfield $w.e -labeltext "Eccentricity"
   }
   itk_component add lorm {
      iwidgets::entryfield $w.lorm -labeltext "Mean longitude (deg)"
   }
   itk_component add n {
      iwidgets::entryfield $w.n -labeltext "Daily motion (deg)"
   }
   grid $itk_component(eltype) -pady 1
   grid $itk_component(epochofel) -sticky e -pady 1
   grid $itk_component(inclination) -sticky e -pady 1
   grid $itk_component(anode) -sticky e -pady 1
   grid $itk_component(perihelion) -sticky e -pady 1
   grid $itk_component(aorq) -sticky e -pady 1
   grid $itk_component(e) -sticky e -pady 1
   grid $itk_component(lorm) -sticky e -pady 1
   grid $itk_component(n) -sticky e -pady 1

# Add commands to the RA/Dec and Az/El pages to re-enable the track rates
# control.
   $itk_component(notebook) pageconfigure "RA/Dec" \
         -command "$itk_component(trackrate) configure -state normal"
   $itk_component(notebook) pageconfigure "Az/El" \
         -command "$itk_component(trackrate) configure -state normal"

# Unpack Apply button and checkbutton so that new science targets have to be
# applied from the main configuration window.
   pack forget $itk_component(aframe)

# Define object description.
   set description "science target"

   eval itk_initialize $args
}

itcl::body SciTargetControl::reset {} {
   $this TargetControl::reset
   $itk_component(epochofel) clear
   $itk_component(inclination) clear
   $itk_component(anode) clear
   $itk_component(perihelion) clear
   $itk_component(aorq) clear
   $itk_component(e) clear
   $itk_component(lorm) clear
   $itk_component(n) clear
}

itcl::body SciTargetControl::load {name} {

   $this TargetControl::load $name

   switch [$name cget -type] {
      namedTarget {
         $itk_component(notebook) select Planets
         set planet [$name cget -planet]
      }
      conicTarget {
         $itk_component(notebook) select Orbits
         set eltype [$name cget -eltype]
         switch $eltype {
            major {
               $itk_component(eltype) select 0
            }
            minor {
               $itk_component(eltype) select 1
            }
            comet {
               $itk_component(eltype) select 2
            }
         }
         orbtype
         $itk_component(epochofel) insert end [$name cget -epoch]
         $itk_component(inclination) insert end [$name cget -inclination]
         $itk_component(anode) insert end [$name cget -anode]
         $itk_component(aorq) insert end [$name cget -aorq]
         $itk_component(perihelion) insert end [$name cget -perihelion]
         $itk_component(e) insert end [$name cget -e]
         if { $eltype == "major" || $eltype == "minor" } {
            $itk_component(lorm) insert end [$name cget -LorM]
         }
         if { $eltype == "major" } {
            $itk_component(n) insert end [$name cget -n]
         }
      }
   }
}

itcl::body SciTargetControl::save {name} {
#+
# Updates a target object with the values currently entered in the
# control window.
#-
   $this TargetControl::save $name
   set page [lindex [$itk_component(notebook) pageconfigure \
         [$itk_component(notebook) select select] -label] 4]
   switch $page {
      Planets {
         $name configure \
               -type namedTarget \
               -objname [$itk_component(selector) get] \
               -planet $planet
      }
      Orbits {
         switch [$itk_component(eltype) get] {
            "Major planet orbital elements" {
               set eltype major
            }
            "Minor planet orbital elements" {
               set eltype minor
            }
            "Comet orbital elements" {
               set eltype comet
            }
         }
         $name configure \
               -type conicTarget \
               -objname [$itk_component(selector) get] \
               -eltype $eltype \
               -epoch [$itk_component(epochofel) get] \
               -inclination [$itk_component(inclination) get] \
               -anode [$itk_component(anode) get] \
               -e [$itk_component(e) get] \
               -perihelion [$itk_component(perihelion) get] \
               -aorq [$itk_component(aorq) get]
         if { $eltype == "major" || $eltype == "minor" } {
            $name configure -LorM [$itk_component(lorm) get]
         } else {
            $name configure -LorM ""
         }
         if { $eltype == "major" } {
            $name configure -n [$itk_component(n) get]
         } else {
            $name configure -n ""
         }
      }
   }
}

itcl::body SciTargetControl::orbtype {} {
   switch [$itk_component(eltype) get] {
      "Major planet orbital elements" {
         $itk_component(perihelion) configure -labeltext \
               "Longitude of perihelion (deg)"
         $itk_component(aorq) configure -labeltext \
               "Mean distance (AU)"
         $itk_component(lorm) configure -state normal -labeltext \
               "Mean longitude (deg)"
         $itk_component(n) configure -state normal
      }
      "Minor planet orbital elements" {
         $itk_component(perihelion) configure -labeltext \
               "Argument of perihelion (deg)"
         $itk_component(aorq) configure -labeltext \
               "Mean distance (AU)"
         $itk_component(lorm) configure -state normal -labeltext \
               "Mean anomaly (deg)"
         $itk_component(n) configure -state disabled
      }
      "Comet orbital elements" {
         $itk_component(perihelion) configure -labeltext \
               "Argument of perihelion (deg)"
         $itk_component(aorq) configure -labeltext \
               "Perihelion distance (AU)"
         $itk_component(lorm) configure -state disabled
         $itk_component(n) configure -state disabled
      }
   }
}

itcl::body SciTargetControl::selplanet {} {

# Fill in the selector with the planet name
   $itk_component(selector) insert $planet
}
