#+
#  SciTargetControl <- TargetControl
#
#  A SciTarget control is a TargetControl widget with widgets for
#  the target position etc.
#
#  D Terrett 7 June 2002
#
#  Copyright CCLRC
#+

itcl::class SciTargetControl {
   inherit TargetControl
   constructor args {}
   public {
      method load {name}
      method reset {}
      method save {name}
   }
   private {
      method orbtype {}
   }
}

itk::usual SciTargetControl {
   keep -borderwidth -cursor -font -highlightthickness -insertborderwidth \
         -insertofftime -insertontime -insertwidth -labelfont -popupcursor \
         -selectborderwidth -textfont -title
}

itcl::body SciTargetControl::constructor args {

# Set colour of highlight frame.
   $itk_component(highlight) configure -background black

# Add page for solar system objects
   set w [$itk_component(notebook) add -label "Solar System" \
         -command "$itk_component(trackrate) configure -state disabled"]

# Option menu for the orbit type.
   itk_component add eltype {
      iwidgets::optionmenu $w.eltype -command [itcl::code $this orbtype]
   }
   $itk_component(eltype) insert end "Major planet (AsA format)" \
         "Major planet (JPL Horizons format)" \
         "Minor planet or comet (JPL Horizons format)" \
         "Minor planet (AsA format)" "Minor planet (MPC format)" \
         "Comet (AsA format)" "Comet (MPC format)" \
         Mercury Venus Mars Jupiter Saturn Uranus Neptune Pluto

# Entry widgets for each element.
   itk_component add epochofel {
      iwidgets::entryfield $w.epochofel -labeltext "Epoch of elements (TT JD)"
   }
   itk_component add inclination {
      iwidgets::entryfield $w.inclination -labeltext \
            "Orbital inclination (deg)"
   }
   itk_component add anode {
      iwidgets::entryfield $w.anode -labeltext \
            "Longitude of ascending node (deg)"
   }
   itk_component add peri {
      iwidgets::entryfield $w.peri -labeltext \
            "Longitude of perihelion (deg)"
   }
   itk_component add aorq {
      iwidgets::entryfield $w.aorq -labeltext "Mean distance (AU)"
   }
   itk_component add e {
      iwidgets::entryfield $w.e -labeltext "Eccentricity"
   }
   itk_component add lormorTP {
      iwidgets::entryfield $w.lormorTP -labeltext "Mean longitude (deg)"
   }
   itk_component add n {
      iwidgets::entryfield $w.n -labeltext "Daily motion (deg)"
   }
   grid $itk_component(eltype) -pady 1
   grid $itk_component(epochofel) -sticky e -pady 1
   grid $itk_component(inclination) -sticky e -pady 1
   grid $itk_component(anode) -sticky e -pady 1
   grid $itk_component(peri) -sticky e -pady 1
   grid $itk_component(aorq) -sticky e -pady 1
   grid $itk_component(e) -sticky e -pady 1
   grid $itk_component(lormorTP) -sticky e -pady 1
   grid $itk_component(n) -sticky e -pady 1

# Add commands to the RA/Dec and Az/El pages to re-enable the track rates
# control.
   $itk_component(notebook) pageconfigure "RA/Dec" \
         -command "$itk_component(trackrate) configure -state normal"
   $itk_component(notebook) pageconfigure "Az/El" \
         -command "$itk_component(trackrate) configure -state normal"

# Unpack Apply button and checkbutton so that new science targets have to be
# applied from the main configuration window.
   pack forget $itk_component(aframe)

# Define object description.
   set description "science target"

   eval itk_initialize $args
}

itcl::body SciTargetControl::reset {} {

   $this TargetControl::reset

# Enable all entry fields.
   set lormorTPstate [$itk_component(lormorTP) cget -state]
   $itk_component(lormorTP) configure -state normal
   set nstate [$itk_component(n) cget -state]
   $itk_component(n) configure -state normal

# Clear the entry fields.
   $itk_component(epochofel) clear
   $itk_component(inclination) clear
   $itk_component(anode) clear
   $itk_component(peri) clear
   $itk_component(aorq) clear
   $itk_component(e) clear
   $itk_component(lormorTP) clear
   $itk_component(n) clear

# Restore the state of the controls
   $itk_component(lormorTP) configure -state $lormorTPstate
   $itk_component(n) configure -state $nstate
}

itcl::body SciTargetControl::load {name} {

   $this TargetControl::load $name

   switch [$name cget -type] {
      conicTarget {

# Select the solar system page.
         $itk_component(notebook) select "Solar System"

# Get the element type and format.
         set eltype [$name cget -eltype]
         set format [$name cget -format]
         switch $eltype {
            major {
               switch $format {
                  AsA {
                     $itk_component(eltype) select "Major planet (AsA format)"
                     $itk_component(epochofel) insert end [$name cget -epoch]
                     $itk_component(inclination) insert end \
                           [$name cget -inclination]
                     $itk_component(anode) insert end [$name cget -anode]
                     $itk_component(aorq) insert end [$name cget -a]
                     $itk_component(peri) insert end [$name cget -perihelion]
                     $itk_component(e) insert end [$name cget -e]
                     $itk_component(lormorTP) insert end [$name cget -L]
                     $itk_component(n) insert end [$name cget -n]
                  }
                  JPL {
                     $itk_component(eltype) select "Major planet (JPL Horizons format)"
                     $itk_component(epochofel) insert end [$name cget -epoch]
                     $itk_component(inclination) insert end \
                           [$name cget -inclination]
                     $itk_component(anode) insert end [$name cget -anode]
                     $itk_component(aorq) insert end [$name cget -a]
                     $itk_component(peri) insert end [$name cget -perihelion]
                     $itk_component(e) insert end [$name cget -e]
                     $itk_component(lormorTP) insert end [$name cget -MA]
                     $itk_component(n) insert end [$name cget -n]
                  }
               }
            }
            minor {
               switch $format {
                  AsA {
                      $itk_component(eltype) select "Minor planet (AsA format)"
                  }
                  MPC {
                      $itk_component(eltype) select "Minor planet (MPC format)"
                  }
                }
                $itk_component(epochofel) insert end [$name cget -epoch]
                $itk_component(inclination) insert end \
                      [$name cget -inclination]
                $itk_component(anode) insert end [$name cget -anode]
                $itk_component(aorq) insert end [$name cget -a]
                $itk_component(peri) insert end [$name cget -perihelion]
                $itk_component(e) insert end [$name cget -e]
                $itk_component(lormorTP) insert end [$name cget -M]
             }
             comet {
                switch $format {
                  JPL {
                     $itk_component(eltype) select \
                           "Minor planet or comet (JPL Horizons format)"
                     $itk_component(lormorTP) insert end [$name cget -TP]
                  }
                  MPC {
                     $itk_component(eltype) select "Comet (MPC format)"
                     $itk_component(lormorTP) insert end [$name cget -TP]
                  }
                  AsA {
                     $itk_component(eltype) select "Comet (AsA format)"
                  }
               }
               $itk_component(epochofel) insert end [$name cget -epoch]
               $itk_component(inclination) insert end \
                     [$name cget -inclination]
               $itk_component(anode) insert end [$name cget -anode]
               $itk_component(aorq) insert end [$name cget -q]
               $itk_component(peri) insert end [$name cget -perihelion]
               $itk_component(e) insert end [$name cget -e]
            }
         }

# Update the entry field labels.
         orbtype
      }
   }
}

itcl::body SciTargetControl::save {name} {
#+
# Updates a target object with the values currently entered in the
# control window.
#-
   $this TargetControl::save $name
   set page [lindex [$itk_component(notebook) pageconfigure \
         [$itk_component(notebook) select select] -label] 4]
   switch $page {
      "Solar System" {
         switch [$itk_component(eltype) get] {
            Mercury -
            Venus -
            Mars -
            Jupiter -
            Saturn -
            Uranus -
            Neptune -
            Pluto -
            "Major planet (AsA format)" {
               $name init
               $name configure \
                     -type conicTarget \
                     -objname [$itk_component(selector) get] \
                     -eltype major \
                     -format AsA \
                     -epoch [$itk_component(epochofel) get] \
                     -inclination [$itk_component(inclination) get] \
                     -anode [$itk_component(anode) get] \
                     -e [$itk_component(e) get] \
                     -perihelion [$itk_component(peri) get] \
                     -a [$itk_component(aorq) get] \
                     -L [$itk_component(lormorTP) get] \
                     -n [$itk_component(n) get]
            }
            "Major planet (JPL Horizons format)" {
               $name init
               $name configure \
                     -type conicTarget \
                     -objname [$itk_component(selector) get] \
                     -eltype major \
                     -format JPL \
                     -epoch [$itk_component(epochofel) get] \
                     -inclination [$itk_component(inclination) get] \
                     -anode [$itk_component(anode) get] \
                     -e [$itk_component(e) get] \
                     -perihelion [$itk_component(peri) get] \
                     -a [$itk_component(aorq) get] \
                     -MA [$itk_component(lormorTP) get] \
                     -n [$itk_component(n) get]
            }
            "Minor planet (AsA format)" {
               $name init
               $name configure \
                     -type conicTarget \
                     -objname [$itk_component(selector) get] \
                     -eltype minor \
                     -format AsA \
                     -epoch [$itk_component(epochofel) get] \
                     -inclination [$itk_component(inclination) get] \
                     -anode [$itk_component(anode) get] \
                     -e [$itk_component(e) get] \
                     -perihelion [$itk_component(peri) get] \
                     -a [$itk_component(aorq) get] \
                     -M [$itk_component(lormorTP) get]
            }
            "Minor planet (MPC format)" {
               $name init
               $name configure \
                     -type conicTarget \
                     -objname [$itk_component(selector) get] \
                     -eltype minor \
                     -format MPC \
                     -epoch [$itk_component(epochofel) get] \
                     -inclination [$itk_component(inclination) get] \
                     -anode [$itk_component(anode) get] \
                     -e [$itk_component(e) get] \
                     -perihelion [$itk_component(peri) get] \
                     -a [$itk_component(aorq) get] \
                     -M [$itk_component(lormorTP) get]
            }
            "Minor planet or comet (JPL Horizons format)" {
               $name init
               $name configure \
                     -type conicTarget \
                     -objname [$itk_component(selector) get] \
                     -eltype comet \
                     -format JPL \
                     -epoch [$itk_component(epochofel) get] \
                     -inclination [$itk_component(inclination) get] \
                     -anode [$itk_component(anode) get] \
                     -e [$itk_component(e) get] \
                     -perihelion [$itk_component(peri) get] \
                     -q [$itk_component(aorq) get] \
                     -TP [$itk_component(lormorTP) get]
            }
            "Comet (MPC format)" {
               $name init
               $name configure \
                     -type conicTarget \
                     -objname [$itk_component(selector) get] \
                     -eltype comet \
                     -format MPC \
                     -epoch [$itk_component(epochofel) get] \
                     -inclination [$itk_component(inclination) get] \
                     -anode [$itk_component(anode) get] \
                     -e [$itk_component(e) get] \
                     -perihelion [$itk_component(peri) get] \
                     -q [$itk_component(aorq) get] \
                     -TP [$itk_component(lormorTP) get]
            }
            "Comet (AsA format)" {
               $name init
               $name configure \
                     -type conicTarget \
                     -objname [$itk_component(selector) get] \
                     -eltype comet \
                     -format AsA \
                     -epoch [$itk_component(epochofel) get] \
                     -inclination [$itk_component(inclination) get] \
                     -anode [$itk_component(anode) get] \
                     -e [$itk_component(e) get] \
                     -perihelion [$itk_component(peri) get] \
                     -q [$itk_component(aorq) get] 
            }
         }
      }
   }
}

itcl::body SciTargetControl::orbtype {} {

# Update the entry field labels and states.
   set eltype [$itk_component(eltype) get]
   switch $eltype {
      Mercury -
      Venus -
      Mars -
      Jupiter -
      Saturn -
      Uranus -
      Neptune -
      Pluto -
      "Major planet (AsA format)" { 
         $itk_component(epochofel) configure -labeltext \
               "Epoch of elements (TT JD)"
         $itk_component(inclination) configure -labeltext \
               "Orbital inclination (deg)"
         $itk_component(anode) configure -labeltext \
               "Longitude of ascending node (deg)"
         $itk_component(peri) configure -labeltext \
               "Longitude of perihelion (deg)"
         $itk_component(aorq) configure -labeltext \
               "Mean distance (AU)"
         $itk_component(e) configure -labeltext "Eccentricity"
         $itk_component(lormorTP) configure -state normal -labeltext \
               "Mean longitude (deg)"
         $itk_component(n) configure -state normal -labeltext \
               "Daily motion (deg)"
      }
      "Major planet (JPL Horizons format)" {
         $itk_component(epochofel) configure -labeltext \
               "Epoch of elements (TT JD)"
         $itk_component(inclination) configure -labeltext IN
         $itk_component(anode) configure -labeltext OM
         $itk_component(peri) configure -labeltext W
         $itk_component(aorq) configure -labeltext A
         $itk_component(e) configure -labeltext EC
         $itk_component(lormorTP) configure -state normal -labeltext MA
         $itk_component(n) configure -state normal -labeltext N
      }
      "Minor planet (AsA format)" {
         $itk_component(epochofel) configure -labeltext \
               "Epoch of elements (TT JD)"
         $itk_component(inclination) configure -labeltext \
               "Orbital inclination (deg)"
         $itk_component(anode) configure -labeltext \
               "Longitude of ascending node (deg)"
         $itk_component(peri) configure -labeltext \
               "Argument of perihelion (deg)"
         $itk_component(aorq) configure -labeltext "Mean distance (AU)"
         $itk_component(e) configure -labeltext "Eccentricity"
         $itk_component(lormorTP) configure -state normal -labeltext \
               "Mean anomaly (deg)"
         $itk_component(n) configure -state disabled
      }
      "Minor planet (MPC format)" {
         $itk_component(epochofel) configure -labeltext "Epoch JDT"
         $itk_component(inclination) configure -labeltext Incl
         $itk_component(anode) configure -labeltext Node
         $itk_component(peri) configure -labeltext Peri
         $itk_component(aorq) configure -labeltext a
         $itk_component(e) configure -labeltext e
         $itk_component(lormorTP) configure -state normal -labeltext M
         $itk_component(n) configure -state disabled
      }
      "Minor planet or comet (JPL Horizons format)" {
         $itk_component(epochofel) configure -labeltext EPOCH
         $itk_component(inclination) configure -labeltext IN
         $itk_component(anode) configure -labeltext OM
         $itk_component(peri) configure -labeltext W
         $itk_component(aorq) configure -labeltext QR
         $itk_component(e) configure -labeltext EC
         $itk_component(lormorTP) configure -state normal -labeltext TP
         $itk_component(n) configure -state disabled
      }
      "Comet (AsA format)" {
         $itk_component(epochofel) configure -labeltext \
               "Epoch of elements (TT JD)"
         $itk_component(inclination) configure -labeltext \
               "Orbital inclination (deg)"
         $itk_component(anode) configure -labeltext \
               "Longitude of ascending node (deg)"
         $itk_component(peri) configure -labeltext \
               "Argument of perihelion (deg)"
         $itk_component(aorq) configure -labeltext "Perihelion distance (AU)"
         $itk_component(e) configure -labeltext "Eccentricity"
         $itk_component(lormorTP) configure -state disabled
         $itk_component(n) configure -state disabled
      }
      "Comet (MPC format)" {
         $itk_component(epochofel) configure -labeltext Epoch
         $itk_component(inclination) configure -labeltext Incl
         $itk_component(anode) configure -labeltext Node
         $itk_component(peri) configure -labeltext Peri
         $itk_component(aorq) configure -labeltext q
         $itk_component(e) configure -labeltext e
         $itk_component(lormorTP) configure -state normal -labeltext T
         $itk_component(n) configure -state disabled
      }
   }

# Fill in planet elements from  Chapront & Francou ephemeris.
   switch $eltype {
      Mercury -
      Venus -
      Mars -
      Jupiter -
      Saturn -
      Uranus -
      Neptune -
      Pluto {
         set file [file join $::ROOT series96 [string tolower $eltype]]
         set elements [plosc $file]
         $itk_component(epochofel) clear
         $itk_component(inclination) clear
         $itk_component(anode) clear
         $itk_component(peri) clear
         $itk_component(aorq) clear
         $itk_component(e) clear
         $itk_component(lormorTP) clear
         $itk_component(n) clear
         $itk_component(epochofel) insert end [lindex $elements 0]
         $itk_component(inclination) insert end [lindex $elements 1]
         $itk_component(anode) insert end [lindex $elements 2]
         $itk_component(peri) insert end [lindex $elements 3]
         $itk_component(aorq) insert end [lindex $elements 4]
         $itk_component(e) insert end [lindex $elements 5]
         $itk_component(lormorTP) insert end [lindex $elements 6]
         $itk_component(n) insert end [lindex $elements 7]
      }
   }
}
