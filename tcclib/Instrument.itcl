#+
#  Instrument <- Paramset
#
#  Implements the Instrument class. An Instrument object stores an 
#  instrument alignment angle.
#
#  Options:
#          -centralBaffle     The position of the M2 central baffle ("open"
#                             "closed" or "").
#
#          -deployableBaffle  The position of the M2 deployable baffle
#                             ("thermal IR", "near IR", "visible",
#                             "extended" or "").
#
#          -focusOffset       The focus offset to apply.
#
#          -iaa               The instrument alignment angle.
#
#          -issPort           The ISS port on which the instrument is 
#                             mounted.
#
#          -name              The name of the instrument (as known to the A&G).
#
#          -oiwfs             Whether the instrument has an OIWFS that needs
#                             to be configured in the A&G sequencer
#
#  Methods:
#          apply comp  Applies the iaa to the TCS by setting the values of 
#                      the command parameters. 
#
#          init        Returns the instrument object to its initial state.
#
#          preview     Sets the preview instrument configuration.
#
#          node        Saves the values of the options to the xml node. 
#
#  D Terrett 14 October 2003
#
#  Copyright CCLRC
#+

itcl::class Instrument {
   inherit Paramset
   public {
      method apply {comp}
      method init {}
      method preview {view}
      method save {node}
      variable iaa ""
      variable issPort 1
      variable centralBaffle open
      variable deployableBaffle ""
      variable focusOffset ""
      variable name ""
      variable oiwfs no
   }
}

itcl::body Instrument::apply {comp} {

# Set iaa and focus.
   if { ![string is space $iaa] } {
      cs rotator set iaa [list $iaa]
      logger command rotator
   }
   if { ![string is space $focusOffset] } {
      cs dtelFocus set focusOffset [list $focusOffset]
      logger command dtelFocus
   }

# Configure the A&G sequencer
   if { $oiwfs } {
     cs oiwfsSelect set oiwfs $name
   } else {
     cs oiwfsSelect set oiwfs NONE
   }
   logger command oiwfsSelect

# Configure ISS object.
   switch $centralBaffle {
      closed {cs m2Baffle set centralBaffle Closed}
      open {cs m2Baffle set centralBaffle Open}
   }
   switch $deployableBaffle {
      "thermal IR" {cs m2Baffle set deployBaffle Retracted}
      "near IR" {cs m2Baffle set deployBaffle [list "Near IR"]}
      visible {cs m2Baffle set deployBaffle Visible}
      extended {cs m2Baffle set deployBaffle Extended}
   }
   if { !( [string is space $centralBaffle] && \
         [string is space $deployableBaffle] ) } {
      logger command m2Baffle
   }
   iss configure -port $issPort -instrument $name

# Update ISS with new configuration.
   iss update
}

itcl::body Instrument::init {} {
   set iaa 0
   set issFace 1
   set centralBaffle ""
   set deployableBaffle ""
   set focusOffset 0
   set name ""
   set oiwfs no
}

itcl::body Instrument::preview {view} {
   if { [string length $iaa] } {
      $view configure -iaa $iaa
   } else {
      $view configure -iaa 0.0
   }
}

itcl::body Instrument::save {node} {
   set node [paramset $node instrument]
   param $node iaa $iaa
   param $node issPort $issPort
   param $node centralBaffle $centralBaffle
   param $node deployableBaffle $deployableBaffle
   param $node focusOffset $focusOffset
   param $node name $name
   param $node oiwfs $oiwfs
}
