#+
#  CosysComponent <- Cosys, tcclib::Component
#
#  A CosysComponent object is a Cosys object that is stored in a 
#  configuration list.
#
#
#  Options:
#           none
#
#  Methods:
#           constructor list  Creates the Cosys object and puts it onto
#                           "list".
#
#  D Terrett 19 September 2001
#
#  Copyright CCLRC
#+

itcl::class CosysComponent {
   inherit tcclib::Component Cosys
   constructor {list args} {
      tcclib::Component::constructor $list
   } {
      eval configure $args
   }
}
