#+
#  OnOffButton <- itk::Widget
#
#  Implements the OnOffButton class. A OnOffButton is a push button that
#  toggles the state of some mechanism. The current state of the
#  mechanism, is indicated by the background colour (red for Off, green for
#  On, yellow for unknown). When the button is pressed it goes yellow intil
#  the mechanism has changed state.
#
#  Options:
#          -oncommand      The a list of command sender, parameter and value 
#                          triplets that turns the mechanism on.
#
#          -onvalue        A list of the sad record values that indicate that
#                          the mechanism is on.
#
#          -onproc         A script to be executed to turn the mechanism on.
#
#          -offcommand     The a list of command sender, parameter and value 
#                          triplets that turns the mechanism off.
#
#          -offvalue       A list of the sad record values that indicate that
#                          the mechanism is off.
#
#          -offproc        A script to be executed to turn the mechanism on.
#
#          -sadrecord      The name of the sa that indicates the mechanism
#                          state.
#
#  Methods:
#          
#           select label   Selects the specified button.
#
#  D Terrett 26 June 2003
#
#  Copyright CCLRC
#-

itcl::class OnOffButton {
   inherit itk::Widget
   constructor args {}
   destructor {}
   itk_option define -oncommand onCommand Command {}
   itk_option define -offcommand offCommand Command {}
   itk_option define -onvalue onValue Value {} checkstate
   itk_option define -onproc onProc Proc {}
   itk_option define -offproc offProc Proc {}
   itk_option define -offvalue offValue Value {} checkstate
   itk_option define -sadrecord sadrecord SadRecord {} checkstate
   public {
      method select {label}
      method get {}
   }
   private {
      method pressed {}
      method monitor {record value}
      method checkstate {}
      variable state 0
      variable monid ""
   }
}

itk::usual OnOffButton {
   keep -activeforeground -cursor -disabledforeground \
         -foreground -font -highlightcolor -highlightthickness -width
}

itcl::body OnOffButton::constructor args {

   itk_component add button {
      button $itk_interior.button -command [itcl::code $this pressed]
   } {
      usual
      keep -state -text -width
      ignore -activebackground
      ignore -background
   }
   pack $itk_component(button) -fill both -expand y

   eval itk_initialize $args
}

itcl::body OnOffButton::destructor {} {

# If the sad record has been set then remove the monitor.
   if { [llength $itk_option(-sadrecord)] } {
      [lindex $itk_option(-sadrecord) 0].[lindex $itk_option(-sadrecord) 1] \
         remove $monid
   }
}

itcl::body OnOffButton::pressed {} {

# Assume no command senders.
   set cslist [list]

# Set the command sender parameter appropriate for the current state.
   if { $state } {
      if { ! [string equal $itk_option(-offproc) ""] } {
         uplevel #0 $itk_option(-offproc)
      }
      if { ! [string equal $itk_option(-offcommand) ""] } {
         foreach {cs par val} $itk_option(-offcommand) {
            cs $cs set $par $val
            lappend cslist $cs
         }
      }
   } else {
      if { ! [string equal $itk_option(-onproc) ""] } {
         uplevel #0 $itk_option(-onproc)
      }
      if { ! [string equal $itk_option(-oncommand) ""] } {
         foreach {cs par val} $itk_option(-oncommand) {
            cs $cs set $par $val
            lappend cslist $cs
         }
      }
   }

# If there is a commmand sender then log and post the command.
   if { [llength $cslist] } {
      foreach cs [lsort -unique $cslist] {
         logger command $cs
      }
      if { [catch {cs tcsApply post} msg] } {
         tk_messageBox -icon error -parent $itk_interior -message $msg
      }

# Set the button background to indicate that a state change is in progress.
      $itk_component(button) configure -background yellow \
            -activebackground yellow
   }
}

itcl::configbody OnOffButton::oncommand {
   if { ! [string equal $itk_option(-oncommand) ""] } {

      set cs [lindex $itk_option(-oncommand) 0]

# Create the command sender if it doesn't already exist.
      if { [catch {cs $cs info}] } {
         epics cs $cs
      }
   }
}

itcl::configbody OnOffButton::offcommand {
   if { ! [string equal $itk_option(-offcommand) ""] } {

      set cs [lindex $itk_option(-offcommand) 0]

# Create the command sender if it doesn't already exist.
      if { [catch {cs $cs info}] } {
         epics cs $cs
      }
   }
}

itcl::body OnOffButton::checkstate {} {
   if { [llength $itk_option(-sadrecord)] } {

# Extract the staus acceptor and record names.
      foreach {sa rec} $itk_option(-sadrecord) {}

# Create the status acceptor if it doesn't already exist.
      if { [llength [itcl::find objects ::$sa.$rec]] == 0 } {
         RecordMonitor ::$sa.$rec $sa $rec
      }

# Monitor the record.
      if { $monid == "" } {
         set monid [$sa.$rec add [itcl::code $this monitor]]
      }

# Call the monitor routine to update the state.
      monitor $sa.$rec [sa $sa get $rec]
   }
}

itcl::body OnOffButton::monitor {record value} {

# Determine the state of the mechanism and set the colour.
   if { [lsearch -exact $itk_option(-onvalue) $value] >= 0 } {
      set state 1
      $itk_component(button) configure -background green \
            -activebackground green
   } elseif { [lsearch -exact $itk_option(-offvalue) $value] >= 0 } {
      set state 0
      $itk_component(button) configure -background red \
            -activebackground red
   } else {
      $itk_component(button) configure -background yellow \
            -activebackground yellow
   }
}

itcl::body OnOffButton::select {label} {

   if {$label == "Off"} {
      if {$state} {
	   $itk_component(button) invoke
         } 
   } else {
      if {!$state} {
	   $itk_component(button) invoke
      }
  }

}

itcl::body OnOffButton::get {} {
    return $state
}
