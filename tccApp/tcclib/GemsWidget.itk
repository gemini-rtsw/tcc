itcl::body GemsWidget::onTTODGWxPress {op} {
   if { $op eq "push" } {
      $itk_component(ttcan1) clear
      $itk_component(ttcan2) clear
      $itk_component(ttcan3) clear
   }
}

itcl::body GemsWidget::onTTCxPress {op} {
   if { $op eq "push" } {
      $itk_component(ttodgw1) clear
      $itk_component(ttodgw2) clear
      $itk_component(ttodgw3) clear
      $itk_component(ttodgw4) clear
   }
}

itcl::body GemsWidget::getMagnetPoint { type } {
   puts "[winfo x $itk_component(ttframe)] + [winfo reqwidth $itk_component(ttframe)]"
   switch $type {
      TT_CAN_IN {
         set x [ expr [winfo x $itk_component(ttframe)] + [winfo width $itk_component(ttframe)] ]
         set y [ expr [winfo y $itk_component(ttframe)] + [winfo y $itk_component(ttcan3)] ]
      }
      TT_ODGW_IN {
         set x [ expr [winfo x $itk_component(ttframe)] + [winfo width $itk_component(ttframe)] ]
         set y [ expr [winfo y $itk_component(ttframe)] + [winfo y $itk_component(ttodgw4)] ]
      }
      ODGW_OUTR {
         set x [ expr [winfo x $itk_component(odgwframe)] + \
            [winfo x $itk_component(odgw1)] + [winfo width $itk_component(odgw1)] ]
         set y [ expr [winfo y $itk_component(odgwframe)] + ( [winfo y $itk_component(odgw1)] \
            + [winfo y $itk_component(odgw4)] + [winfo height $itk_component(odgw4)] ) / 2 ]
      }
      default {
         set x -1
         set y -1
      }
   }
   puts "GemsWidget::getMagnetPoint $type ($x, $y)"
   if { $x >= 0 } {
      return [ list [expr [winfo x $itk_interior] + $x ] [expr [winfo y $itk_interior] + $y ] ]
   } else {
      return [ list $x $y ]
   }
}

itcl::body GemsWidget::onLayoutChange {} {
   if { ! [string is space $itk_option(-layoutchangecmd)] } {
      eval $itk_option(-layoutchangecmd)
   }
}