#+
#  GemsWidget <- itk::Widget
#
#  Widget to specify parameters for a Altair.
##  Options:
#           none
#
#  Methods:
#           none
#
#  J. Luhrs 04 March 2010
#
#+

itcl::class GemsWidget {
	inherit itk::Widget
	
public {
	constructor {args} {}
	
	itk_option define -aocontroller aoController AoController {} { init }
	
	method reset {} {}
	method enable {} {}
	method recolor {} {}
	method init {}
}
private {
	variable sys
	method onGemsChange {reasons}
}
}

itk::usual GemsWidget {
#	keep -background -cursor -foreground -highlightcolor \
#		-highlightthickness
	keep -background -cursor
}

itcl::body GemsWidget::constructor {args} {

	itk_component add mainframe {
		frame $itk_interior.mainframe -relief solid -borderwidth 1 -background white 
	} { usual
		ignore -background }
	pack $itk_component(mainframe)
	set w $itk_component(mainframe)
	
	itk_component add gaoson {
		ToggleButton $w.gaoson -text AO -pushedbackground Green -pady 0 -width 7 \
				-command [itcl::code $this gaos]
	} { ignore -width }
	pack $itk_component(gaoson) -side top -anchor n -padx 2 -pady 2
	
	itk_component add buttonframe {
		frame $w.buttonframe -background white 
	} { usual
			ignore -background }
	itk_component add buttonframeright {
		frame $w.buttonframe.right -background white 
	}
	itk_component add buttonframeleft {
		frame $w.buttonframe.left -background white 
	}
	itk_component add ttgsloop {
		ToggleButton $w.buttonframe.left.ttgsloop -text TTGS -pushedbackground Green -pady 0  -width 6 \
			-command [itcl::code $this ttgsloop]
	} { ignore -width }
	itk_component add odgwloop {
		ToggleButton $w.buttonframe.right.odgwloop -text ODGW -pushedbackground Green -pady 0 -width 6 \
			-command [itcl::code $this ttgsloop]
	} { ignore -width }
	itk_component add oiloop {
		ToggleButton $w.buttonframe.left.oiloop -text OI -pushedbackground Green \
			-pady 0 -width 6
	} { ignore -width }
	itk_component add sfsloop {
		ToggleButton $w.buttonframe.right.sfsloop -text SFS -pushedbackground Green \
			-pady 0 -width 6
	} { ignore -width }
	itk_component add lgswfs {
		WfsWidget $w.lgswfs -label LGSWFS -explabel Hz -expvalues [list 100 200 400 800]
	}
	pack $itk_component(ttgsloop) $itk_component(oiloop) -side top -anchor w
	pack $itk_component(sfsloop) $itk_component(odgwloop) -side top -anchor e
	pack $itk_component(buttonframeright) -side right
	pack $itk_component(buttonframeleft) -side left
	pack $itk_component(lgswfs) -padx 2 -pady 2
	pack $itk_component(buttonframe) -fill x 
	
	itk_component add canframe {
		frame $w.canframe -background white
	} { usual
			ignore -background }
	itk_component add can1 {
		WfsWidget $w.canframe.can1 -label C1 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add can2 {
		WfsWidget $w.canframe.can2 -label C2 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add can3 {
		WfsWidget $w.canframe.can3 -label C3 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add sfs {
		WfsWidget $w.canframe.sfs -label SFS -explabel Hz -expvalues [list 100 200 400 800]
	}
	[$itk_component(can1) component exp] configure -width 3
	[$itk_component(can2) component exp] configure -width 3
	[$itk_component(can3) component exp] configure -width 3
	[$itk_component(sfs) component exp] configure -width 3
				
	grid $itk_component(can1) $itk_component(can2) -padx 1 -pady 1
	grid $itk_component(can3) $itk_component(sfs) -padx 1 -pady 1
	grid configure $itk_component(sfs) -padx 0 -pady 0 -sticky se
	pack $itk_component(canframe) -padx 2 -pady 2

	itk_component add odgwframe {
		frame $w.odgwframe -background white 
	} { usual
			ignore -background }
	itk_component add odgw1 {
		WfsWidget $w.odgwframe.odgw1 -label ODGW1 -explabel Hz -expvalues [list 100 200 400 800]
	}
	[$itk_component(odgw1) component exp] configure -width 3
	itk_component add odgw2 {
		WfsWidget $w.odgwframe.odgw2 -label ODGW2 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add odgw3 {
		WfsWidget $w.odgwframe.odgw3 -label ODGW3 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add odgw4 {
		WfsWidget $w.odgwframe.odgw4 -label ODGW4 -explabel Hz -expvalues [list 100 200 400 800]
	}
	[$itk_component(odgw1) component exp] configure -width 3
	[$itk_component(odgw2) component exp] configure -width 3
	[$itk_component(odgw3) component exp] configure -width 3
	[$itk_component(odgw4) component exp] configure -width 3
	
	grid $itk_component(odgw1) $itk_component(odgw2) -padx 1 -pady 1
	grid $itk_component(odgw3) $itk_component(odgw4) -padx 1 -pady 1
	pack $itk_component(odgwframe) -padx 2 -pady 2
	eval itk_initialize $args
	
	set sys [GemsSys::getSingleton]
	$sys subscribe [itcl::code $this onGemsChange]
}

itcl::body GemsWidget::init {} {
	if { $itk_option(-aocontroller) ne "" } {
		$itk_component(lgswfs) expSet [$itk_option(-aocontroller) cget -lwfsFreq]
		$itk_component(can1) expSet [$itk_option(-aocontroller) cget -ttgs1Mag]
		$itk_component(can2) expSet [$itk_option(-aocontroller) cget -ttgs2Mag]
		$itk_component(can3) expSet [$itk_option(-aocontroller) cget -ttgs3Mag]
		$itk_component(sfs) expSet [$itk_option(-aocontroller) cget -sfsMag]
		$itk_component(odgw1) expSet [$itk_option(-aocontroller) cget -odgw1Mag]
		$itk_component(odgw2) expSet [$itk_option(-aocontroller) cget -odgw2Mag]
		$itk_component(odgw3) expSet [$itk_option(-aocontroller) cget -odgw3Mag]
		$itk_component(odgw4) expSet [$itk_option(-aocontroller) cget -odgw4Mag]
	}
}

itcl::body GemsWidget::reset {} {
	$itk_component(gaoson) pop
   $itk_component(ttgsloop) pop
   $itk_component(oiloop) pop
	$itk_component(sfsloop) pop
	$itk_component(odgwloop) pop
	$itk_component(can1) switchPop
	$itk_component(can2) switchPop
	$itk_component(can3) switchPop
	$itk_component(sfs) switchPop
	$itk_component(odgw1) switchPop
	$itk_component(odgw2) switchPop
	$itk_component(odgw3) switchPop
	$itk_component(odgw4) switchPop
	$itk_component(lgswfs) switchPop
}

itcl::body GemsWidget::recolor {} {
	if { [$itk_option(-aocontroller) state gaos] } {
		$itk_component(gaos) configure -status on
		$itk_component(mainframe) configure -background Green
      # aoSettled
   } else {
		$itk_component(gaos) configure -status off
		$itk_component(mainframe) configure -background white
   }
	if { [$itk_option(-aocontroller) state lgswfs] } {
		$itk_component(lgswfs) configure -status on
	} else {
		$itk_component(lgswfs) configure -status off
	}
	set ttFlag 0
	if { [$itk_option(-aocontroller) state ttgs1] } {
		$itk_component(can1) configure -status on
		set ttFlag 1
	} else {
		$itk_component(can1) configure -status off
	}
	if { [$itk_option(-aocontroller) state ttgs2] } {
		$itk_component(can2) configure -status on
		set ttFlag 1
	} else {
		$itk_component(can2) configure -status off
	}
	if { [$itk_option(-aocontroller) state ttgs3] } {
		$itk_component(can3) configure -status on
		set ttFlag 1
	} else {
		$itk_component(can3) configure -status off
	}
	if { [$itk_option(-aocontroller) state sfs] } {
		$itk_component(sfs) configure -status on
	} else {
		$itk_component(sfs) configure -status off
	}
	if { $ttFlag } {
		$itk_component(canframe) configure -background Green
	} else {
		$itk_component(mainframe) configure -background white
	}
	set odgwFlag 0
	if { [$itk_option(-aocontroller) state odgw1] } {
		$itk_component(odgw1) configure -status on
		set odgwFlag 1
	} else {
		$itk_component(odgw1) configure -status off
	}
	if { [$itk_option(-aocontroller) state odgw2] } {
		$itk_component(odgw2) configure -status on
		set odgwFlag 1
	} else {
		$itk_component(odgw2) configure -status off
	}
	if { [$itk_option(-aocontroller) state odgw3] } {
		$itk_component(odgw3) configure -status on
		set odgwFlag 1
	} else {
		$itk_component(odgw3) configure -status off
	}
	if { [$itk_option(-aocontroller) state odgw4] } {
		$itk_component(odg41) configure -status on
		set odgwFlag 1
	} else {
		$itk_component(odgw4) configure -status off
	}
	if { $odgwFlag } {
		$itk_component(odgwframe) configure -background Green
	} else {
		$itk_component(odgwframe) configure -background white
	}
}

itcl::body GemsWidget::enable {} {
	$itk_option(-aocontroller) configure -gaos [expr \"[$itk_component(gaoson) switchGet]\" eq \"pushed\"] 
	$itk_option(-aocontroller) configure -ttgs1Active [expr \"[$itk_component(can1) switchGet]\" eq \"pushed\"] 
	$itk_option(-aocontroller) configure -ttgs1Exp [$itk_component(can1) expGet]
	$itk_option(-aocontroller) configure -ttgs2Active [expr \"[$itk_component(can2) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -ttgs2Exp	[$itk_component(can2) expGet]
	$itk_option(-aocontroller) configure -ttgs3Active [expr \"[$itk_component(can3) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -ttgs3Exp	[$itk_component(can3) expGet]
	$itk_option(-aocontroller) configure -sfsActive [expr \"[$itk_component(can1) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -sfsExp [$itk_component(sfs) expGet]
	$itk_option(-aocontroller) configure -odgw1Active [expr \"[$itk_component(sfs) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -odgw1Exp	[$itk_component(odgw1) expGet]
	$itk_option(-aocontroller) configure -odgw2Active [expr \"[$itk_component(odgw2) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -odgw2Exp	[$itk_component(odgw2) expGet]
	$itk_option(-aocontroller) configure -odgw3Active [expr \"[$itk_component(odgw3) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -odgw3Exp	[$itk_component(odgw3) expGet]
	$itk_option(-aocontroller) configure -odgw4Active [expr \"[$itk_component(odgw4) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -odgw4Exp	[$itk_component(odgw4) expGet]
	$itk_option(-aocontroller) configure -lwfsActive [expr \"[$itk_component(lgswfs) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -lwfsFreq [$itk_component(lgswfs) expGet]
	$itk_option(-aocontroller) configure -lwfsLoop [expr \"[$itk_component(lgswfs) switchGet]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -oigsLoop [expr \"[$itk_component(oiloop) get]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -odgwLoop [expr \"[$itk_component(odgwloop) get]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -ttgsLoop [expr \"[$itk_component(ttgsloop) get]\" eq \"pushed\"]
	$itk_option(-aocontroller) configure -sfsLoop [expr \"[$itk_component(sfsloop) get]\" eq \"pushed\"]

	#$itk_option(-aocontroller) configure -oigsActive [expr \"[$itk_component(can1) switchGet]\" eq \"pushed\"]
	#$itk_option(-aocontroller) configure -oigsMag [$itk_component(can1) expGet]
}

itcl::body GemsWidget::onGemsChange {reasons} {
	recolor
}