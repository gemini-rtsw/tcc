#+
#  GemsWidget <- itk::Widget
#
#  Widget to specify parameters for a Altair.
##  Options:
#           none
#
#  Methods:
#           none
#
#  J. Luhrs 04 March 2010
#
#+

itcl::class GemsWidget {
	inherit itk::Widget
	
public {
	constructor {args} {}
	
	itk_option define -aocontroller aoController AoController {} { init }
	
	method reset {} {}
	method enable {} {}
	method recolor {} {}
	method init {}
}
private {
	method gaos {val}
	method gaosTTGS {val}
	method gaosSFO {val}
	method oiblend {val}
	method ttgsloop {val}
	method sfoloop {val}
}
}

itk::usual GemsWidget {
#	keep -background -cursor -foreground -highlightcolor \
#		-highlightthickness
	keep -background -cursor
}

itcl::body GemsWidget::constructor {args} {

	itk_component add mainframe {
		frame $itk_interior.mainframe -relief solid -borderwidth 1 -background white 
	} { usual
		ignore -background }
	pack $itk_component(mainframe)
	set w $itk_component(mainframe)
	
	itk_component add gaoson {
		ToggleButton $w.gaoson -text AO -pushedbackground Green -pady 0 -width 7 \
				-command [itcl::code $this gaos]
	} { ignore -width }
	pack $itk_component(gaoson) -side top -anchor n -padx 2 -pady 2
	
	itk_component add buttonframe {
		frame $w.buttonframe -background white 
	} { usual
			ignore -background }
	itk_component add buttonframeright {
		frame $w.buttonframe.right -background white 
	}
	itk_component add buttonframeleft {
		frame $w.buttonframe.left -background white 
	}
	itk_component add ttgsloop {
		ToggleButton $w.buttonframe.left.ttgsloop -text TTGS -pushedbackground Green -pady 0  -width 6 \
			-command [itcl::code $this ttgsloop]
	} { ignore -width }
	itk_component add odgwloop {
		ToggleButton $w.buttonframe.right.odgwloop -text ODGW -pushedbackground Green -pady 0 -width 6 \
			-command [itcl::code $this ttgsloop]
	} { ignore -width }
	itk_component add oiloop {
		ToggleButton $w.buttonframe.left.oiloop -text OI -pushedbackground Green \
			-pady 0 -width 6
	} { ignore -width }
	itk_component add sfsloop {
		ToggleButton $w.buttonframe.right.sfsloop -text SFS -pushedbackground Green \
			-pady 0 -width 6
	} { ignore -width }
	itk_component add lgswfs {
		WfsWidget $w.lgswfs -label LGSWFS -explabel Hz -expvalues [list 100 200 400 800]
	}
	pack $itk_component(ttgsloop) $itk_component(oiloop) -side top -anchor w
	pack $itk_component(sfsloop) $itk_component(odgwloop) -side top -anchor e
	pack $itk_component(buttonframeright) -side right
	pack $itk_component(buttonframeleft) -side left
	pack $itk_component(lgswfs) -padx 2 -pady 2
	pack $itk_component(buttonframe) -fill x 
	
	itk_component add canframe {
		frame $w.canframe -background white
	} { usual
			ignore -background }
	itk_component add can1 {
		WfsWidget $w.canframe.can1 -label C1 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add can2 {
		WfsWidget $w.canframe.can2 -label C2 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add can3 {
		WfsWidget $w.canframe.can3 -label C3 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add sfs {
		WfsWidget $w.canframe.sfs -label SFS -explabel Hz -expvalues [list 100 200 400 800]
	}
	[$itk_component(can1) component exp] configure -width 3
	[$itk_component(can2) component exp] configure -width 3
	[$itk_component(can3) component exp] configure -width 3
	[$itk_component(sfs) component exp] configure -width 3
				
	grid $itk_component(can1) $itk_component(can2) -padx 1 -pady 1
	grid $itk_component(can3) $itk_component(sfs) -padx 1 -pady 1
	grid configure $itk_component(sfs) -padx 0 -pady 0 -sticky se
	pack $itk_component(canframe) -padx 2 -pady 2

	itk_component add odgwframe {
		frame $w.odgwframe -background white 
	} { usual
			ignore -background }
	itk_component add odgw1 {
		WfsWidget $w.odgwframe.odgw1 -label ODGW1 -explabel Hz -expvalues [list 100 200 400 800]
	}
	[$itk_component(odgw1) component exp] configure -width 3
	itk_component add odgw2 {
		WfsWidget $w.odgwframe.odgw2 -label ODGW2 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add odgw3 {
		WfsWidget $w.odgwframe.odgw3 -label ODGW3 -explabel Hz -expvalues [list 100 200 400 800]
	}
	itk_component add odgw4 {
		WfsWidget $w.odgwframe.odgw4 -label ODGW4 -explabel Hz -expvalues [list 100 200 400 800]
	}
	[$itk_component(odgw1) component exp] configure -width 3
	[$itk_component(odgw2) component exp] configure -width 3
	[$itk_component(odgw3) component exp] configure -width 3
	[$itk_component(odgw4) component exp] configure -width 3
	
	grid $itk_component(odgw1) $itk_component(odgw2) -padx 1 -pady 1
	grid $itk_component(odgw3) $itk_component(odgw4) -padx 1 -pady 1
	pack $itk_component(odgwframe) -padx 2 -pady 2
	eval itk_initialize $args
}

itcl::body GemsWidget::init {} {
	return
	if { $itk_option(-aocontroller) ne "" } {
		$itk_component(gaos) expSet [$itk_option(-aocontroller) cget -gaosExpose]
		$itk_component(aosfo) expSet [$itk_option(-aocontroller) cget -sfoExpose]
	}
	$itk_component(aottgs) expSet "10.0(0.001)"
}

itcl::body GemsWidget::reset {} {
	return
	$itk_component(oiao) pop
   $itk_component(gaos) switchPop
   $itk_component(ttao) pop
   $itk_component(sfao) pop
   $itk_component(aosfo) switchPop
   $itk_component(aottgs) switchPop
}

itcl::body GemsWidget::recolor {} {
return
#	 Disable LGS options unless useLwfs is true
   if {[$itk_option(-aocontroller) state useLwfs]} {
       $itk_component(ttao) configure -state normal
       $itk_component(sfao) configure -state normal
       $itk_component(aosfo) configure -state normal
       $itk_component(aottgs) configure -state normal
   } else {
       $itk_component(ttao) clear
       $itk_component(ttao) configure -state disabled
       $itk_component(sfao) clear
       $itk_component(sfao) configure -state disabled
       $itk_component(aosfo) clear
       $itk_component(aosfo) configure -state disabled
       $itk_component(aottgs) clear
       $itk_component(aottgs) configure -state disabled
   }

#	 GAOS signals
	if { [$itk_option(-aocontroller) state gaos] } {
		$itk_component(gaos) configure -status on
		$itk_component(mainframe) configure -background Green
      # aoSettled
   } else {
		$itk_component(gaos) configure -status off
		$itk_component(mainframe) configure -background white
   }
   if { [$itk_option(-aocontroller) state gaosTTGS] } {
		$w itemconfigure gaos_ttgs -fill green
      if { [$itk_option(-aocontroller) state ttgsloop] } {
	  		$w itemconfigure ttgs_gaos -fill green
      } else {
	  		$w itemconfigure ttgs_gaos -fill yellow
		}
	}
	if { [$itk_option(-aocontroller) state gaosSFO] } {
		$itk_component(aosfo) configure -status on
		if { [$itk_option(-aocontroller) state sfoloop] } {
			$w itemconfigure sfo_gaos -fill green
		} else {
			$w itemconfigure sfo_gaos -fill yellow
		}
	} else {
		$itk_component(aosfo) configure -status off
	}
}

itcl::body GemsWidget::enable {} {
	return
   AO configure -gaosExpose [$itk_component(gaos) expGet]

   if { [string match "*LGS*" $::Config(tcs.gaos,value)] } {
       set ttgsexp [$itk_component(aottgs) expGet]
       set ind [string first "(" $ttgsexp]
       set ttgsmag [string range $ttgsexp 0 [expr $ind-1]]
       set ttgsexp [string trim [string range $ttgsexp $ind end] "()"]

       AO configure -ttgsExpose $ttgsexp
       AO configure -sfoExpose [$itk_component(aosfo) expGet]

       switch $ttgsmag {
	   10.0 -
	   10.5 -
	   11.0 -
	   11.5 -
	   12.0 -
	   12.5 {
	       AO configure -ttgsGain 0.2
	       AO configure -ttgsFlux 1
	   }
	   13.0 -
	   13.5 -
	   14.0 -
	   14.5 -
	   15.0 -
	   15.5 -
	   16.0 {
	       AO configure -ttgsGain 0.2
	       AO configure -ttgsFlux 0
	   }
	   16.5 {
	       AO configure -ttgsGain 0.4
	       AO configure -ttgsFlux 0
	   }
	   17.0 {
	       AO configure -ttgsGain 0.7
	       AO configure -ttgsFlux 0
	   }
	   17.5 {
	       AO configure -ttgsGain 1.1
	       AO configure -ttgsFlux 0
	   }
	   18.0 {
	       AO configure -ttgsGain 1.6
	       AO configure -ttgsFlux 0
	   }
	   18.5 {
	       AO configure -ttgsGain 2.0
	       AO configure -ttgsFlux 0
	   }
	   19.0 {
	       AO configure -ttgsGain 2.6
	       AO configure -ttgsFlux 0
	   }
       }
   }
   if { [calparam cget -site] eq "MK" && $::Config(tcs.gaos,value) ne "No AO" && $::Config(tcs.gaos,value) != "" } {
       switch [$itk_component(gaos_ex) get] {
	   0.001 { $::Config(tcs.gaos,namespace)::$::Config(tcs.gaos,value) configure -gsmag 11 }
	   0.002 { $::Config(tcs.gaos,namespace)::$::Config(tcs.gaos,value) configure -gsmag 12 }
	   0.005 { $::Config(tcs.gaos,namespace)::$::Config(tcs.gaos,value) configure -gsmag 13 }
	   0.01  { $::Config(tcs.gaos,namespace)::$::Config(tcs.gaos,value) configure -gsmag 14 }
	   0.02  { $::Config(tcs.gaos,namespace)::$::Config(tcs.gaos,value) configure -gsmag 15 }
	   default { $::Config(tcs.gaos,namespace)::$::Config(tcs.gaos,value) configure -gsmag 11 }
       }
   }
}

itcl::body GemsWidget::gaos {val} {
	
	$itk_option(-aocontroller) configure -useLwfs [$itk_option(-aocontroller)  state useLwfs]
	
	switch $val {
		push {
			$itk_option(-aocontroller) configure -gaos 1
		}
		pop {
			$itk_option(-aocontroller) configure -gaos 0
		}
	}
}

itcl::body GemsWidget::gaosTTGS {val} {
	switch $val {
		push {
			$itk_option(-aocontroller) configure -gaosTTGS 1
		}
		pop {
			$itk_option(-aocontroller) configure -gaosTTGS 0
		}
	}
}

itcl::body GemsWidget::ttgsloop {val} {
	switch $val {
		push {
			$itk_option(-aocontroller) configure -ttgsloop 1
		}
		pop {
			$itk_option(-aocontroller) configure -ttgsloop 0
		}
	}
}

itcl::body GemsWidget::gaosSFO {val} {
	switch $val {
		push {
			$itk_option(-aocontroller) configure -gaosSFO 1
		}
		pop {
			$itk_option(-aocontroller) configure -gaosSFO 0
		}
	}
}

itcl::body GemsWidget::sfoloop {val} {
	switch $val {
	push {
		$itk_option(-aocontroller) configure -sfoloop 1
	}
	pop {
		$itk_option(-aocontroller) configure -sfoloop 0
	}
	}
}

itcl::body GemsWidget::oiblend {val} {
	switch $val {
		push {
			 $itk_option(-aocontroller) configure -oiblend 1
		}
		pop {
			 $itk_option(-aocontroller) configure -oiblend 0
		}
	}
}
