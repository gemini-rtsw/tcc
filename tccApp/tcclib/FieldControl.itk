itcl::body FieldControl::load {name} {
# If the targets are currently swapped, swap back
#   if {($curr_guide != "") && ( ${name} != ${currentname} )} {
#
#	#puts "swapping back because loading new target ..."
#	
#	switch $curr_guide {
#	   "P1-P2" -
#	   "P1-OI" -
#	   "AO-P1" -
#	   "P1" {
#		   $fieldObj configure -pwfs1target $curr_guidetarget
#		   set lpath "Sky>Instr"
#	        }
#	   "P2-OI" -
#	   "P2" {
#		   $fieldObj configure -pwfs2target $curr_guidetarget
#		   set lpath "Sky>Instr"
#	        }
#	   "OI" {
#		   $fieldObj configure -oiwfstarget $curr_guidetarget
#		   set lpath "Sky>Instr"
#	        }
#	   "AO-OI" -
#	   "AO" {
#		   $fieldObj configure -aowfstarget $curr_guidetarget
#		   set lpath "Sky>AO>Inst"
#	        }
#	}
#	$fieldObj configure -guide $curr_guide
#	$fieldObj configure -sciencetarget $curr_sciencetarget
#	${curr_ns}::$curr_guidetarget configure -objname ${curr_objname}
#	$fieldObj configure -wavelength $curr_wl_name
#
#	# set Light Path Mode (for the A&G)
#	if [winfo exists .observePanel] {
#	    ::.observePanel.frame.control.botframe.mirrors.lpath select $lpath
#	}
#	
#	#clear temp storage
#	set curr_guide ""
#	set curr_sciencetarget ""
#	set curr_guidetarget ""
#	set curr_wl_name ""
#	set curr_wavelength ""
#	$itk_component(swapguide) configure -text "Swap Science/Guide Targets" -bg "white"
#    }
	if {( ${name} != ${currentname} ) && ![string is space $currentname ]} {
		$currentname clearSwapTarget
	}

# Copy the contents of the field object selected in the combobox into the 
# edit controls.

# Save the existing name so that we can copy all the targets it
# contains.
	if {![string equal $currentname ""]} {
		$currentname unsubscribe [itcl::code $this onFieldChange]
	}
   set currentname ${name}

# Set the namespace and list to save targets and track rates in.
   foreach target {science pwfs1 pwfs2 oiwfs aowfs} {
      set ::Config($comp.${target}target,namespace) ${name}TargetNames
      set ::Config($comp.${target}target.trackrate,namespace) \
            ${name}TrackRateNames
      set ::Config($comp.${target}target,list) ${name}TargetList
		if {[$name cget -${target}target] ne "" && [[$name cget -${target}target] cget -target] ne "" } {
      	set ::Config($comp.${target}target,value) [namespace tail [[$name cget -${target}target] cget -target]]
		} else {
			set ::Config($comp.${target}target,value) ""
		}
		set ::Config($comp.${target}target.trackrate,list) ${name}TrackRateList
   }
  set ::Config($comp.target,namespace) ${name}TargetNames
  set ::Config($comp.trackrate,namespace) ${name}TrackRateNames
  set ::Config($comp.trackrate2,namespace) ${name}TrackRateNames
  set ::Config($comp.target,list) ${name}TargetList 
  set ::Config($comp.target,value) ""
  set ::Config($comp.taggedtarget,list) [${name} cget -taggedTargets] 
  set ::Config($comp.taggedtarget,value) ""
  set ::Config($comp.trackrate,list) ${name}TrackRateList
  set ::Config($comp.trackrate2,list) ${name}TrackRateList
 
	if { [string is space [$name getSwapTarget]] } {
   	set ::Config($comp.guide,value) [$name cget -guide]
		set ::Config($comp.wavelength,value) [$name cget -wavelength]
	} else {
		set ::Config($comp.guide,value) [$name cget -swapguide]
		set ::Config($comp.wavelength,value) [$name cget -swapwavelength]
	}

	set ::Config($comp.rotator,value) [$name cget -rotator]
   $itk_component(progid) clear
   $itk_component(airmass) clear
   $itk_component(progid) insert end [$name cget -programid]
   $itk_component(airmass) insert end [$name cget -airmassLimit]

	$currentname subscribe [itcl::code $this onFieldChange]
}

itcl::configbody FieldControl::component {
# Remove any existing trace
	if { $comp ne "" } {
   	trace vdelete ::Config($comp,value) w [itcl::code $this newname]
   	set comp ""
	}

   if { $itk_option(-component) != "" } {
       set comp $itk_option(-component)

# Configure the component options of the target controls.
#      foreach target {science pwfs1 pwfs2 oiwfs aowfs} {
#         $itk_component(${target}control) configure \
#               -component $comp.${target}target

# Configure the textvariable option on the target display widgets to the
# config array.
#         $itk_component(${target}name) configure -textvariable \
#               ::Config($comp.${target}target,value)
#      }
      $itk_component(targets) configure -component $comp.taggedtarget
		

# Configure the guide, rotator and wavelength components.
      $itk_component(guide) configure -component $comp.guide
      $itk_component(rotator) configure -component $comp.rotator
      $itk_component(wavelength) configure -component $comp.wavelength

# Set a trace on the component value so that we can detect the selection
# of the scratch object.
      trace variable ::Config($comp,value) w [itcl::code $this newfieldval]

# Set the name of the current component and the list and namespace for
# targets.
      set currentname $::Config($comp,anon)
      foreach target {science pwfs1 pwfs2 oiwfs aowfs} {
         set ::Config($comp.${target}target,list) ${currentname}TargetList
         set ::Config($comp.${target}target,namespace) ${currentname}TargetNames
      }
      set ::Config($comp.target,namespace) ${currentname}TargetNames
		set ::Config($comp.trackrate,namespace) ${currentname}TrackRateNames
		set ::Config($comp.trackrate2,namespace) ${currentname}TrackRateNames
      set ::Config($comp.target,list) ${currentname}TargetList
      set ::Config($comp.taggedtarget,list) [${currentname} cget -taggedTargets]
      set ::Config($comp.trackrate,list) ${currentname}TrackRateList
      set ::Config($comp.trackrate2,list) ${currentname}TrackRateList
     
		set name $::Config($comp.wavelength,value)
   }
}

itcl::body FieldControl::sync {component name} {
return
   switch $component {
      tcs.field.sciencetarget {
         $itk_component(sciencecontrol) sync $name
      }
      tcs.field.pwfs1target {
         $itk_component(pwfs1control) sync $name
      }
      tcs.field.pwfs2target {
         $itk_component(pwfs2control) sync $name
      }
      tcs.field.oiwfstarget {
         $itk_component(oiwfscontrol) sync $name
      }
      tcs.field.aowfstarget {
         $itk_component(aowfscontrol) sync $name
      }
   }
}

itcl::body FieldControl::newfieldval {n1 n2 op} {

# Update the current name if the scratch object is selected. This is required
# because load will not get called.
   if { $::Config($comp,value) == "" } {
      #set currentname $::Config($comp,anon)
		load $::Config($comp,anon)
   }
}

itcl::body FieldControl::newtarget {name type args} {
   if { $::Config(tcs.field,value) == "" } {
      set field $::Config(tcs.field,anon)
   } else {
      set field $::Config(tcs.field,namespace)::$::Config(tcs.field,value)
   }

# See if a name was specified.
   if { $name != "" } {
      set target $name
   } else {
      set target "Unnamed target"
   }

# Remove any existing target with the specified name.
   if { $target == $::Config(tcs.field.sciencetarget,value) } {
      $field configure -sciencetarget ""
   }
   if { $target == $::Config(tcs.field.pwfs1target,value) } {
      $field configure -pwfs1target ""
   }
   if { $target == $::Config(tcs.field.pwfs2target,value) } {
      $field configure -pwfs2target ""
   }
   if { $target == $::Config(tcs.field.oiwfstarget,value) } {
      $field configure -oiwfstarget ""
   }
   if { $target == $::Config(tcs.field.aowfstarget,value) } {
      $field configure -aowfstarget ""
   }
   catch {$field remove target $target}

# Create the new target.
   $field add target $target

# Configure the new target.
   eval [list $field] subconfigure target [list $target] $args

# Make it the specified target and select it.
   if { $type != "" } {
		switch $type {
			sciencetarget {
				$field setDefaultTarget [$field addTaggedTarget Base [$field cget -targetns]::$target]
			}
			pwfs1target {
				$field setDefaultTarget [$field addTaggedTarget PWFS1 [$field cget -targetns]::$target]
			}
			pwfs2target {
				$field setDefaultTarget [$field addTaggedTarget PWFS2 [$field cget -targetns]::$target]
			}
			oiwfstarget {
				$field setDefaultTarget [$field addTaggedTarget OIWFS [$field cget -targetns]::$target]
			}
			aowfstarget {
				$field setDefaultTarget [$field addTaggedTarget AOWFS [$field cget -targetns]::$target]
			}
			ttgs1target {
				$field setDefaultTarget [$field addTaggedTarget CWFS1 [$field cget -targetns]::$target]
			}
			ttgs2target {
				$field setDefaultTarget [$field addTaggedTarget CWFS2 [$field cget -targetns]::$target]
			}
			ttgs3target {
				$field setDefaultTarget [$field addTaggedTarget CWFS3 [$field cget -targetns]::$target]
			}
			odgw1target {
				$field setDefaultTarget [$field addTaggedTarget ODGW1 [$field cget -targetns]::$target]
			}
			odgw2target {
				$field setDefaultTarget [$field addTaggedTarget ODGW2 [$field cget -targetns]::$target]
			}
			odgw3target {
				$field setDefaultTarget [$field addTaggedTarget ODGW3 [$field cget -targetns]::$target]
			}
			odgw4target {
				$field setDefaultTarget [$field addTaggedTarget ODGW4 [$field cget -targetns]::$target]
			}
		}
   }
}

itcl::body FieldControl::pageSelectCB {color} {
return
# Re-configure the notebook background to match the selected page.
   $itk_component(targets) config -background $color -tabbackground $color \
         -backdrop $color

# Restore the colours of the tabs.
#   $itk_component(targets) pageconfigure Science -background \
#         [option get $itk_component(sciencecontrol) background Background] 
#   $itk_component(targets) pageconfigure PWFS1 -background \
#         [option get $itk_component(pwfs1control) background Background] 
#   $itk_component(targets) pageconfigure PWFS2 -background \
#         [option get $itk_component(pwfs2control) background Background] 
#   $itk_component(targets) pageconfigure OIWFS -background \
#         [option get $itk_component(oiwfscontrol) background Background] 
#   $itk_component(targets) pageconfigure AOWFS -background \
#         [option get $itk_component(aowfscontrol) background Background] 
}

itcl::body FieldControl::onSelectTarget {target} {
	$itk_component(trgDetails) load $target
}

itcl::body FieldControl::deleteTarget {target} {
	$::Config(tcs.field,namespace)::$::Config(tcs.field,value) removeTaggedTarget $target
}

itcl::body FieldControl::onDeleteTarget {} {
	set target [$itk_component(targets) getSelected]
	if { ![string equal $target ""] } {
		deleteTarget $target
	}
}

itcl::body FieldControl::addNewTarget {} {
	set currTarget [$itk_component(targets) getSelected]
	if { [string equal $currTarget ""] } {
		set tag Base
	} elseif {[string equal [$currTarget cget -tagPrefix] "Base"]} {
		set tag User
	} else {
		set tag [$currTarget cget -tagPrefix]
	}
	
	return [$::Config(tcs.field,namespace)::$::Config(tcs.field,value) addTaggedTarget $tag]
}

itcl::body FieldControl::onAddNewTarget {} {
	set newTarget [addNewTarget]
	$itk_component(targets) select $newTarget 
}

itcl::body FieldControl::onSaveTarget {} {
	set tagtarget [$itk_component(targets) getSelected]
	if { $tagtarget ne "" } {
		set tagtarget [$itk_component(trgDetails) save $tagtarget]
		$itk_component(targets) refresh
		$itk_component(targets) select $tagtarget
	}
}

itcl::body FieldControl::onFieldChange {elementList} {
	foreach attr $elementList {
		switch -glob $attr {
			*target 	{
				onAnyAssignedTargetChange $attr
				if { $attr eq "swaptarget" } {
					if { [string is space [$::Config(tcs.field,namespace)::$::Config(tcs.field,value) getSwapTarget]] } {
						$itk_component(swapguide) configure -text "Swap Science/Guide Targets" -bg $itk_option(-background)
						setTooltip $itk_component(swapguide) "Temporarily slew telescope to selected target."
						set ::Config($comp.wavelength,value) [$currentname cget -wavelength]
						set ::Config($comp.guide,value) [$currentname cget -guide]
					} else {
						$itk_component(swapguide) configure -text "Revert Science/Guide Targets" -bg red
						setTooltip $itk_component(swapguide) "Revert telescope to Science target."
						set ::Config($comp.wavelength,value) [$currentname cget -swapwavelength]
						set ::Config($comp.guide,value) [$currentname cget -swapguide]
					}
				}
			}
		}
	}
}

itcl::body FieldControl::onAnyAssignedTargetChange {attr} {
	$itk_component(targets) onAnyAssignedTargetChange
}

itcl::body FieldControl::onSetDefault {} {
	set tagtarget [$itk_component(targets) getSelected]
	set tag [$tagtarget cget -tagPrefix]
	set default [$::Config(tcs.field,namespace)::$::Config(tcs.field,value) getDefaultTarget $tag]
	if { $default eq $tagtarget } {
		$::Config(tcs.field,namespace)::$::Config(tcs.field,value) clearDefaultTarget $tag
	} else {
		$::Config(tcs.field,namespace)::$::Config(tcs.field,value) setDefaultTarget $tagtarget
	}
}

itcl::body FieldControl::onSwapTarget {} {
	#Currently, store has the effect of reloading the field, so I must save the
	#current selection beforehand
	set tagtarget [$itk_component(targets) getSelected]
	#Always store windows contents before doing a swap
	#FIXME: It would be better to warn the user of unsaved changes, and give 
	#her/him the option to save or ignore.
	store [$itk_component(selector) get]
	
	set swaptarget [$::Config(tcs.field,namespace)::$::Config(tcs.field,value) getSwapTarget]
	#If the science and guide are swapped, just unswap
	if { ![string is space $swaptarget]} {
		$::Config(tcs.field,namespace)::$::Config(tcs.field,value) clearSwapTarget
	} else {
		set tag [$tagtarget cget -tagPrefix]
		if { $tagtarget eq [$::Config(tcs.field,namespace)::$::Config(tcs.field,value) getDefaultTarget $tag] && \
				$tag ne "Base" && $tag ne "User" } {
			$::Config(tcs.field,namespace)::$::Config(tcs.field,value) setSwapTarget $tagtarget
		}
	}
	#Keep the target selected
	$itk_component(targets) select $tagtarget
	
	#Force an apply of the swapped configuration
	if { $swaptarget ne [$::Config(tcs.field,namespace)::$::Config(tcs.field,value) getSwapTarget] } {
		#set light path
		set swaptarget [$::Config(tcs.field,namespace)::$::Config(tcs.field,value) getSwapTarget]
		if { [string is space $swaptarget]} {
			set guide [$::Config(tcs.field,namespace)::$::Config(tcs.field,value) cget -guide]
			if {$guide ne "" } {
				switch $guide {
					"No guiding" -
				   "P1-P2" -
				   "P1-OI" -
				   "AO-P1" -
				   "P1" -
				   "P2-OI" -
				   "P2" -
				   "OI" {
					   set lpath "Sky>Instr"
					}
				   "AO-OI" -
				   "AO" -
					"GeMS" -
					"GeMS-OI" {
					   set lpath "Sky>AO>Inst"
					}
				}
				if [winfo exists .observePanel] {
				    ::.observePanel.frame.control.botframe.mirrors.lpath select $lpath
				}
			}		
		} else {
			set tag [$swaptarget cget -tagPrefix]
			switch $tag {
			   "AOWFS" {
			       set lpath "Sky>AO>AC/HR"
			   }
			   default {
			       set lpath "Sky>AC/HR"
			   }
			}
			if [winfo exists .observePanel] {
			    ::.observePanel.frame.control.botframe.mirrors.lpath select $lpath
			}	
		}
		#Apply the swapped configuration
		$::Config($comp,namespace)::$::Config($comp,value) apply \
			$itk_option(-component)
		if [catch {cs $itk_option(-apply) post} msg] {
			  tk_messageBox -icon error -parent $itk_interior -message \
					"Error posting command: $itk_option(-system) reports \"$msg\""
		}
	}
}

itcl::body FieldControl::store {name} {
	#Force store of target
	onSaveTarget
	ComponentControl::store $name
}