#      label $w.pwfs1name -width 30 -borderwidth 2 -relief sunken
#   }
#   itk_component add pwfs2label {
#      label $w.pwfs2label -text "PWFS2 Target"
#   }
#   itk_component add pwfs2name {
#      label $w.pwfs2name -width 30 -borderwidth 2 -relief sunken
#   }
#   itk_component add oiwfslabel {
#      label $w.oiwfslabel -text "OIWFS target"
#   }
#   itk_component add oiwfsname {
#      label $w.oiwfsname -width 30 -borderwidth 2 -relief sunken
#   }
#   itk_component add aowfslabel {
#      label $w.aowfslabel -text "AOWFS target"
#   }
#   itk_component add aowfsname {
#      label $w.aowfsname -width 30 -borderwidth 2 -relief sunken
#   }
#   grid $itk_component(sciencelabel) $itk_component(sciencename)
#   grid $itk_component(pwfs1label)  $itk_component(pwfs1name)
#   grid $itk_component(pwfs2label) $itk_component(pwfs2name)
#   grid $itk_component(oiwfslabel) $itk_component(oiwfsname)
#   grid $itk_component(aowfslabel) $itk_component(aowfsname)

# Guide, rotator and wavelength selection.
   itk_component add subsel {
      frame $itk_interior.subsel
   }
   set w $itk_component(subsel)
   itk_component add guide {
      SubComponentSelector $w.guide -labeltext "Guide Configuration" \
            -labelpos w -width 30
   }
   itk_component add rotator {
      SubComponentSelector $w.rotator -labeltext "Rotator Configuration" \
            -labelpos w -width 30
   }
   itk_component add wavelength {
      SubComponentSelector $w.wavelength -labeltext "Observing wavelength" \
            -labelpos w -width 30
   }
   pack $itk_component(subsel) -anchor w
   pack $itk_component(guide) $itk_component(rotator) \
         $itk_component(wavelength) -side top -pady 3 -anchor e

# Data entry widgets.
   itk_component add data {
      frame $itk_interior.data
   }
   set w $itk_component(data)

# Swapguide button
	itk_component add swapguide {
		button $w.swapguide -text "Swap Science/Guide Targets" -command [itcl::code $this onSwapTarget]
	}
	setTooltip $itk_component(swapguide) "Temporarily slew telescope to selected target."
	pack $itk_component(swapguide) -side top -pady 3


# Frame for target entry controls.
   itk_component add tarframe {
      frame $w.tarframe -borderwidth 0 -relief flat
   }
   pack $itk_component(tarframe) -expand true -fill x
   set w $itk_component(tarframe)

   itk_component add targets {
      TargetList $w.targets -selectcommand [itcl::code $this onSelectTarget]
   }

   itk_component add trgOpFrm { frame $w.trgOpFrm }


   image create photo ::images::addIcon -file [file join tcclib add.gif]
	image create photo ::images::delIcon -file [file join tcclib remove.gif]
   itk_component add addTrg { button $w.trgOpFrm.add -image ::images::addIcon -command [itcl::code $this onAddNewTarget]}
   itk_component add delTrg { button $w.trgOpFrm.del -image ::images::delIcon -command [itcl::code $this onDeleteTarget]}

	setTooltip $itk_component(addTrg) "Add new target."
	setTooltip $itk_component(delTrg) "Delete selected target."

#   frame $w.trgOpFrm.edBtnFrm
#   image create photo ::images::copyIcon -file [file join tcclib copy.gif]
#   image create photo ::images::pasteIcon -file [file join tcclib paste.gif]
#   image create photo ::images::duplicateIcon -file [file join tcclib duplicate.gif]
#   itk_component add copyTrg { button $w.trgOpFrm.edBtnFrm.copy -image ::images::copyIcon }
#   itk_component add pasteTrg { button $w.trgOpFrm.edBtnFrm.paste -image ::images::pasteIcon }
#   itk_component add duplicateTrg { button $w.trgOpFrm.edBtnFrm.duplicate -image ::images::duplicateIcon }
#
#	pack $w.trgOpFrm.edBtnFrm.copy $w.trgOpFrm.edBtnFrm.paste $w.trgOpFrm.edBtnFrm.duplicate \
#		-side left

	frame $w.trgOpFrm.opBtnFrm
	image create photo ::images::makedefaultIcon -file [file join tcclib star.gif]
	itk_component add makeDefault { button $w.trgOpFrm.opBtnFrm.makedefault -image ::images::makedefaultIcon \
		-command [itcl::code $this onSetDefault]}
	setTooltip $itk_component(makeDefault) "Select/unselect target as the default for science/WFS." 
	image create photo ::images::swapTargetsIcon -file [file join tcclib dep_loop.gif]
#	itk_component add swapTargets { button $w.trgOpFrm.opBtnFrm.swaptargets -image ::images::swapTargetsIcon \
#		-command [itcl::code $this onSwapTarget]}
#	pack $w.trgOpFrm.opBtnFrm.makedefault $w.trgOpFrm.opBtnFrm.swaptargets -side left 
	pack $w.trgOpFrm.opBtnFrm.makedefault -side left 
		

   pack $w.trgOpFrm.add $w.trgOpFrm.del  -side left
#	pack $w.trgOpFrm.add $w.trgOpFrm.del  $w.trgOpFrm.edBtnFrm -side left
#	pack configure $w.trgOpFrm.edBtnFrm -padx 5

	pack $w.trgOpFrm.opBtnFrm -side right 


#   itk_component add hideNonDefaultBtn { button $w.trgOpFrm.hideNonDefaultBtn -text "Show non-defaults" }
#   pack $w.trgOpFrm.hideNonDefaultBtn -side right
   itk_component add trgFrm { iwidgets::labeledframe $w.trgFrm -labeltext "Selected Target" \
	   -labelpos nw -relief groove}

   itk_component add trgDetails { TargetDetail  $w.trgFrm.trgDetails -relief flat \
		-savecommand [itcl::code $this onSaveTarget]}
   grid $w.trgFrm.trgDetails

   pack $itk_component(targets) $itk_component(trgOpFrm) $itk_component(trgFrm) -side top
   pack configure $itk_component(targets) -expand true -fill x
   pack configure $itk_component(trgFrm) -fill x -padx 4
   pack configure $itk_component(trgOpFrm) -anchor w -fill x

# Airmass limit and program ID.
   set w $itk_component(data)
   frame $w.sf
   itk_component add progid {
      iwidgets::entryfield $w.sf.progid -labeltext "Program ID" -width 15
   }
   itk_component add airmass {
      iwidgets::entryfield $w.sf.airmass -labeltext "Airmass limit" -width 8
   }
   pack $itk_component(airmass) $itk_component(progid) -side left \
         -padx 5 -pady 10 -expand yes

   #$itk_component(targets) select Science

   pack $w.sf -side top -pady 3

   pack $itk_component(data) -side left -padx 3 -pady 3 -expand yes -fill y

# Set the current field name to the scratch field.
   set currentname $::Config(tcs.field,anon)

# Define the object description.
   set description "field"

# Turn off geometry propogation once the widget is constructed so that
# re-configuring the notebook widgets doesn't cause the top level window
# to be re-sized.
   #after idle pack propagate $itk_component(tarframe) 0

   eval itk_initialize $args
#   $itk_component(swapguide) configure -text "Swap Science/Guide Targets" -bg "white"
}

itcl::body FieldControl::destructor {} {

# Remove variable trace.
   trace vdelete ::Config($comp,value) w [itcl::code $this newfieldval]
}

itcl::body FieldControl::save {name} {
#+
# Updates the named field object.
#-

# If this is a new field then add each target and track rate from the old 
# field to the new provided that the old field still exists.
   if { ![string equal $currentname $name] && \
         ( [string equal $currentname $::Config(tcs.field,anon)] ||
         [lsearch -exact [itcl::find objects -class FieldComponent] \
         $currentname] >= 0 ) } {

# Copy each track rate first so that they all exist when we configure the
# targets.
      set n [${currentname}TrackRateList length]
      for { set i 0 } { $i < $n } { incr i } {
         set trackrate [${currentname}TrackRateList get $i]
         if { ![string is space $trackrate] } {
            $name add trackrate $trackrate

# Copy all parameters.
            foreach par [$currentname subconfigure trackrate $trackrate] {
               $name subconfigure trackrate $trackrate [lindex $par 0] \
                     [lindex $par 2]
            }

# Set refcount to zero since the new target isn't referenced anywhere yet.
            ${name}TrackRateNames::$trackrate configure -refcount 0
         }
      }

# Copy each target.
      set n [${currentname}TargetList length]
      for { set i 0 } { $i < $n } { incr i } {
         set target [${currentname}TargetList get $i]
         if { ![string is space $target] } {
            $name add target $target

# Copy all parameters.
            foreach par [$currentname subconfigure target $target] {
               $name subconfigure target $target [lindex $par 0] [lindex $par 2]
            }

# Set refcount to zero since the new target isn't referenced anywhere yet.
            ${name}TargetNames::$target configure -refcount 0
         }
      }

# If we have just copied the anonymous field then delete all its targets and
# track rates.
      if { [string equal $currentname $::Config(tcs.field,anon)] } {
         while { [${currentname}TargetList length] > 1 } {
            ${currentname}TargetList remove [${currentname}TargetList get 1]
         }
         while { [${currentname}TrackRateList length] > 1 } {
            ${currentname}TrackRateList remove \
                  [${currentname}TrackRateList get 1]
         }
      }
   }

# Set the remaining components.
	if {[string is space [$name getSwapTarget]]} {
		$name configure -guide [$itk_component(guide) get] \
			-wavelength [$itk_component(wavelength) get]
	} else {
		$name configure -swapguide [$itk_component(guide) get] \
			-swapwavelength [$itk_component(wavelength) get]
	}
   $name configure -rotator [$itk_component(rotator) get] \
		-programid [$itk_component(progid) get] \
		-airmassLimit [$itk_component(airmass) get]

# Record the new current object.
   set currentname $name
}

itcl::body FieldControl::reset {} {
   $itk_component(progid) clear
   $itk_component(airmass) clear
	
	set ::Config(tcs.field.target,value) ""
	
   set ::Config(tcs.field.sciencetarget,value) ""
   set ::Config(tcs.field.pwfs1target,value) ""
   set ::Config(tcs.field.pwfs2target,value) ""
   set ::Config(tcs.field.oiwfstarget,value) ""
   set ::Config(tcs.field.aowfstarget,value) ""
}


