itcl::body GuideAlarm::retrieveGeMSCounts {} {
   global guideCounts
   
   set guideCounts(sfs) [$gemsSys getSFSCounts]
   alarmCheck sfs
   set guideCounts(ttwfs1) [$gemsSys getTTWFSCounts 1]
   alarmCheck ttwfs
   set guideCounts(ttwfs2) [$gemsSys getTTWFSCounts 2]
   alarmCheck ttwfs
   set guideCounts(ttwfs3) [$gemsSys getTTWFSCounts 3]
   alarmCheck ttwfs
   set guideCounts(lgswfs1) [$gemsSys getLGSWFSCounts 1]
   alarmCheck lgswfs
   set guideCounts(lgswfs2) [$gemsSys getLGSWFSCounts 2]
   alarmCheck lgswfs
   set guideCounts(lgswfs3) [$gemsSys getLGSWFSCounts 3]
   alarmCheck lgswfs
   set guideCounts(lgswfs4) [$gemsSys getLGSWFSCounts 4]
   alarmCheck lgswfs
   set guideCounts(lgswfs5) [$gemsSys getLGSWFSCounts 5]
   alarmCheck lgswfs
   set guideCounts(odgw1) [$gemsSys getODGWCounts 1]
   alarmCheck odgw
   set guideCounts(odgw2) [$gemsSys getODGWCounts 2]
   alarmCheck odgw
   set guideCounts(odgw3) [$gemsSys getODGWCounts 3]
   alarmCheck odgw
   set guideCounts(odgw4) [$gemsSys getODGWCounts 4]
   alarmCheck odgw
}