#WFS control commands
itcl::body RealGems::setupODGW {idList} {
   set change 0
   set logmult ""
   if { [llength $idList] > 0 } { 
      set odgwBaseExpTime [calculateBaseExpTime $idList $expTimeTolerance]
   }
   foreach id {1 2 3 4} {
      if {[lsearch $idList $id] == -1} {
         set mult 0
      } else {
   		set mult [expr "round(double($odgwExpTime($id)) / $odgwBaseExpTime )"]
   		if { $mult < 1 } {
   			set mult 1
   		}
      }
      set currentMult [sa odgwsad get expMult${id} value]
      if { ![string is integer -strict $currentMult] || $currentMult != $mult } {
   		cs gems::odgwSetup set expMult${id} $mult
         set change 1
      }
      set logmult "$logmult $id:$mult"
   }
   set currentBaseExpTime [sa odgwsad get baseExpTime]
   if { ![string is double -strict $currentBaseExpTime] || $currentBaseExpTime != $odgwBaseExpTime } {
      cs gems::odgwSetup set baseExpTime $odgwBaseExpTime
      set change 1
   }
   
   if { $change } {
      set lastCmdSys odgwsad
      $logger logmess "gems::odgwSetup multipliers $logmult"
      catch {cs gems::odgwSetup post}
      after 1000
   } else {
      set lastCmdSys ""
   }
}

itcl::body RealGems::startODGW {idList} {
   catch {cs gems::odgwGuide set command MARK}
   after 100
   catch {cs gems::odgwGuide set command START}
   set lastCmdSys ""
   $logger logmess "gems::odgwGuide"
   after 1000
}

itcl::body RealGems::stopODGW {idList} {
   catch {cs gems::odgwEndGuide set command MARK}
   after 100
   catch {cs gems::odgwEndGuide set command START}
   set lastCmdSys ""
   $logger logmess "gems::odgwEndGuide"
   after 1000
}

itcl::body RealGems::startTTWFS {idList} {
   if { [getTTWFSActive 1] } {
      set apd1Op START
   } else {
      set apd1Op STOP
   }
   if { [getTTWFSActive 2] } {
      set apd2Op START
   } else {
      set apd2Op STOP
   }
   if { [getTTWFSActive 3] } {
      set apd3Op START
   } else {
      set apd3Op STOP
   }
   
   foreach id $idList {
		switch $id {
		1 { set apd1Op START }
		2 { set apd2Op START }
		3 { set apd3Op START }
		default {
			$logger logmess "RealGems::startTTWFS invalid index $id"
		}
		}
   }
   cs gems::ttApdCtrl set apd1 $apd1Op
   cs gems::ttApdCtrl set apd2 $apd2Op
   cs gems::ttApdCtrl set apd3 $apd3Op
   
	$logger logmess "gems::ttApdCtrl $apd1Op $apd2Op $apd3Op"
	set lastCmdSys gemssad
	catch {cs gems::ttApdCtrl post}
}

itcl::body RealGems::stopTTWFS {idList} {
   if { [getTTWFSActive 1] } {
      set apd1Op START
   } else {
      set apd1Op STOP
   }
   if { [getTTWFSActive 2] } {
      set apd2Op START
   } else {
      set apd2Op STOP
   }
   if { [getTTWFSActive 3] } {
      set apd3Op START
   } else {
      set apd3Op STOP
   }
  
   foreach id $idList {
      switch $id {
      1 { set apd1Op STOP }
      2 { set apd2Op STOP }
      3 { set apd3Op STOP }
      default {
         $logger logmess "RealGems::stopTTWFS invalid index $id"
      }
      }
   }
   cs gems::ttApdCtrl set apd1 $apd1Op
   cs gems::ttApdCtrl set apd2 $apd2Op
   cs gems::ttApdCtrl set apd3 $apd3Op
   
   $logger logmess "gems::ttApdCtrl $apd1Op $apd2Op $apd3Op"
   set lastCmdSys gemssad
   catch {cs gems::ttApdCtrl post}
}

itcl::body RealGems::startLGSWFS {} {
	$logger logmess "RealGems::startLGSWFS Gems command undefined."
	set lastCmdSys gemssad
}

itcl::body RealGems::stopLGSWFS {} {
	$logger logmess "RealGems::stopLGSWFS Gems command undefined."
	set lastCmdSys gemssad
}

itcl::body RealGems::pauseLis {} {
   cs gems::lisPause set command MARK
   $logger logmess "gems::lisPause"
   set lastCmdSys lissad
   after 100
   catch {cs gems::lisPause post}
}

itcl::body RealGems::setODGWExposure {id val} {
   if { $val < $minExpTime } {
      set val $minExpTime
   }
	set odgwExpTime($id) $val
	set lastCmdSys ""
}

itcl::body RealGems::setTTWFSExposure {id val} {
	cs gems::ttExpCtrl set freqDiv $val
	$logger logmess "gems::ttExpCtrl $val"
	set lastCmdSys rtcsad
	catch {cs gems::ttExpCtrl post}
}

itcl::body RealGems::setLGSWFSExposure {val} {
	cs gems::lgsExpCtrl set expTime $val
	$logger logmess "gems::lgsExpCtrl $val"
	set lastCmdSys rtcsad
	catch {cs gems::lgsExpCtrl post}
}


