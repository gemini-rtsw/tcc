	sa gemssad unproc ngs1Mag [itcl::code $this onStatusChange]
	sa gemssad unproc ngs2Mag [itcl::code $this onStatusChange]
	sa gemssad unproc ngs3Mag [itcl::code $this onStatusChange]
	sa gemssad unproc odgs1Mag [itcl::code $this onStatusChange]
	sa gemssad unproc odgs2Mag [itcl::code $this onStatusChange]
	sa gemssad unproc odgs3Mag [itcl::code $this onStatusChange]
