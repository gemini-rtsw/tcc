#Loop configuration
itcl::body RealGems::configureNGS {sources} {
   set lastCmdSys gemssad
   if { [setTTLoopInputs $sources] } {
      catch {cs gems::ngsConfig post}
   } 
}

itcl::body RealGems::setTTLoopInputs {sources} {
   set notUsed ""
	foreach wfs {ttgs1 ttgs2 ttgs3 odgw1 odgw2 odgw3 odgw4 oigs} {
      if {[string first $wfs $sources] == -1} {
         lappend notUsed $wfs
      }
	}
   foreach wfs $notUsed {
      lappend sources $wfs NotUsed 15.0
   }
   set change 0
	foreach {wfs loop mag} $sources {
		switch $wfs {
		ttgs1 {
         if {[sa gemssad get ngs1 value] ne $loop} {
   			cs gems::ngsConfig set ngs1 $loop
            set change 1
         }
         if { $loop ne "NotUsed" && [sa gemssad get ngs1Mag value] != $mag} {
   			cs gems::ngsConfig set ngs1Mag $mag
            set change 1
         }
		}
		ttgs2 {
         if {[sa gemssad get ngs2 value] ne $loop} {
            cs gems::ngsConfig set ngs2 $loop
            set change 1
         }
         if { $loop ne "NotUsed" && [sa gemssad get ngs2Mag value] != $mag} {
            cs gems::ngsConfig set ngs2Mag $mag
            set change 1
         }
		}
		ttgs3 {
         if {[sa gemssad get ngs3 value] ne $loop} {
            cs gems::ngsConfig set ngs3 $loop
            set change 1
         }
         if { $loop ne "NotUsed" && [sa gemssad get ngs3Mag value] != $mag} {
            cs gems::ngsConfig set ngs3Mag $mag
            set change 1
         }
		}
		odgw1 {
         if {[sa gemssad get odgs1 value] ne $loop} {
            cs gems::ngsConfig set odgs1 $loop
            set change 1
         }
         if { $loop ne "NotUsed" && [sa gemssad get odgs1Mag value] != $mag} {
            cs gems::ngsConfig set odgs1Mag $mag
            set change 1
         }
		}
		odgw2 {
         if {[sa gemssad get odgs2 value] ne $loop} {
            cs gems::ngsConfig set odgs2 $loop
            set change 1
         }
         if { $loop ne "NotUsed" && [sa gemssad get odgs2Mag value] != $mag} {
            cs gems::ngsConfig set odgs2Mag $mag
            set change 1
         }
		}
		odgw3 {
         if {[sa gemssad get odgs3 value] ne $loop} {
            cs gems::ngsConfig set odgs3 $loop
            set change 1
         }
         if { $loop ne "NotUsed" && [sa gemssad get odgs3Mag value] != $mag} {
            cs gems::ngsConfig set odgs3Mag $mag
            set change 1
         }
		}
		odgw4 {
         if {[sa gemssad get odgs4 value] ne $loop} {
            cs gems::ngsConfig set odgs4 $loop
            set change 1
         }
         if { $loop ne "NotUsed" && [sa gemssad get odgs4Mag value] != $mag} {
            cs gems::ngsConfig set odgs4Mag $mag
            set change 1
         }
		}
		oigs {
         if {[sa gemssad get oigs value] ne $loop} {
            cs gems::ngsConfig set oigs $loop
            set change 1
         }
         if { $loop ne "NotUsed" && [sa gemssad get oigs value] != $mag} {
            cs gems::ngsConfig set oigsMag $mag
            set change 1
         }
		}
		}
	}
	$logger logmess "gems::ngsConfig $sources"
   
   return $change
}

#Astrometry
itcl::body RealGems::setAstroMode {mode} {
	switch $mode {
	None -
	Regular -
	Good -
	Best { 
      set astroMode $mode
      $logger logmess "RealGems::setAstroMode $mode"
      cs gems::slewReset set astroMode $mode
	} 
	default {
		$logger logmess "RealGems::setAstroMode unknow mode $mode"
	}
	}
	set lastCmdSys gemssad
   catch {cs gems::slewReset post}
}

itcl::body RealGems::startAstrometry {} {
	cs gems::astrometricCtrl set cmd START
	cs gems::astrometricCtrl set mode $astroMode
	$logger logmess "gems::astrometricCtrl START $astroMode"
	set lastCmdSys gemssad
	catch {cs gems::astrometricCtrl  post}
}

itcl::body RealGems::stopAstrometry {} {
