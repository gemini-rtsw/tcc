itcl::body RealGems::getODGWCounts {id} {
	switch id {
	1 { set index 3 }
	2 { set index 4 }
	3 { set index 5 }
	4 { set index 6 }
	default {
		$logger log "RealGems::getODGWCounts invalid index $id"
		return
	}
	}
	set vals [sa gemssad get ngsFlux value]
	return [lindex $vals $index]
}

itcl::body RealGems::getTTWFSCounts {id} {
	switch id {
	1 { set index 0 }
	2 { set index 1 }
	3 { set index 2 }
	default {
		$logger log "RealGems::getTTWFSCounts invalid index $id"
		return
	}
	}
	set vals [sa gemssad get ngsFlux value]
	return [lindex $vals $index]
}

itcl::body RealGems::getLGSWFSCounts {id} {
	switch id {
	1 { set index 1 }
	2 { set index 2 }
	3 { set index 3 }
	4 { set index 4 }
	5 { set index 5 }
	default {
		$logger log "RealGems::getLGSWFSCounts invalid index $id"
		return
	}
	}
	set vals [sa gemssad get lgsFlux value]
	return [lindex $vals $index]
}

