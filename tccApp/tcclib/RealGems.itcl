#WFS control commands
itcl::body RealGems::startODGW {id} {
	$logger log "RealGems::startODGW $id Gems command undefined."
	set lastCmdSys gemssad
}

itcl::body RealGems::stopODGW {id} {
	$logger log "RealGems::startODGW $id Gems command undefined."
	set lastCmdSys gemssad
}

itcl::body RealGems::startTTWFS {id} {
	switch $id {
	1 { cs gems::ttApdCtrl set apd1 START }
	2 { cs gems::ttApdCtrl set apd2 START }
	3 { cs gems::ttApdCtrl set apd3 START }
	default {
		$logger log "RealGems::startTTWFS invalid index $id"
		return
	}
	}
	$logger command gems::ttApdCtrl
	set lastCmdSys gemssad
	catch {cs gems::ttApdCtrl post}
}

itcl::body RealGems::stopTTWFS {id} {
	switch $id {
	1 { cs gems::ttApdCtrl set apd1 STOP }
	2 { cs gems::ttApdCtrl set apd2 STOP }
	3 { cs gems::ttApdCtrl set apd3 STOP }
	default {
		$logger log "RealGems::startTTWFS invalid index $id"
		return
	}
	}
	$logger command gems::ttApdCtrl
	set lastCmdSys gemssad
	catch {cs gems::ttApdCtrl post}
}

