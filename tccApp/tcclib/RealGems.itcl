	if { $lastCmdSys ne "" } {
		return [sa $lastCmdSys get message value]
	} else {
		return ""
	}
}

#Observable interface
itcl::body RealGems::subscribe {observer} {
# Check that the observer isn't already on the list.
	if { [lsearch -exact $observerList $observer] == -1 } {
# Append the observer to the list.
		lappend observerList $observer
	}
}

itcl::body RealGems::unsubscribe {observer} {
# Check that the observer is registered.
	set index [lsearch -exact $observerList $observer]
	if { $index != -1 } {
		set observerList [lreplace $observerList $index $index]
	}
}

itcl::body RealGems::notify {reasons} {
	foreach observer $observerList {
      if {$observer ne ""} {
   		$observer $reasons
      } else {
         $logger logmess "RealGems::notify: found invalid subscriptor"
      }
	}
}

itcl::body RealGems::onStatusChange {name alarm time value} {
	set reasons ""
	switch $name {
	gemssad.applyC -
	aomsad.applyC { lappend reason cmdState }
	gemssad.lgsFlux {
		for { set i 1 } { $i <= 5 } { incr i } {
			if { [lindex $value $i] != [lindex lastLGSFlux $i] } {
				lappend reasons lgswfsCounts($i)
			}
		}
	}
	gemssad.ngsFlux {
		foreach {i reason} {0 ttwfsCounts(1) 1 ttwfsCounts(2) 2 ttwfsCounts(3) 3 odgwCounts(1) 4 odgwCounts(2) 5 odgwCounts(3) 6 odgwCounts(4)} {
			if { [lindex $value $i] != [lindex lastTTFlux $i] } {
				lappend reasons $reason
			}
		}
	}
	gemssad.apd1Status { lappend reasons ttwfsActive1 }
	gemssad.apd2Status { lappend reasons ttwfsActive2 }
	gemssad.apd3Status { lappend reasons ttwfsActive3 }
	gemssad.ngs1 -
	gemssad.ngs2 -
	gemssad.ngs3 -
	gemssad.odgw1 -
	gemssad.odgw2 -
	gemssad.odgw3 -
	gemssad.odgw4 -
	gemssad.oigs { lappend reasons ttLoopSources }
	gemssad.lgsLoop { lappend reasons lgsLoopState }
	gemssad.ttLoop { lappend reasons ttLoopState }
	gemssad.focLoop { lappend reasons focLoopState }
	gemssad.flexLoop { lappend reasons flexLoopState }
	gemssad.astromReady { lappend reasons astroState }
	gemssad.aniLoop { lappend reasons aniLoopState }
   gemssad.rtcHealth { lappend reasons lgswfsActive }
	gemssad.sciReady { lappend reasons loopsSettled }
   gemssad.m1Offload { lappend reasons m1OffloadState }
   gemssad.m2Offload { lappend reasons m2OffloadState }
   gemssad.crOffload { lappend reasons rotOffloadState }
	aomsad.adcScState { lappend reasons adcPos }
	aomsad.adcScLoop { lappend reasons adcState }
	aomsad.beamSplitterState { lappend reasons beamSplitterPos }
	rtcsad.tt1Active { lappend reasons ttwfsActive(1) }
	rtcsad.tt2Active { lappend reasons ttwfsActive(2) }
	rtcsad.tt3Active { lappend reasons ttwfsActive(3) }
	odgwsad.counts1 { lappend reasons odgwCounts(1) }
	odgwsad.counts2 { lappend reasons odgwCounts(2) }
	odgwsad.counts3 { lappend reasons odgwCounts(3) }
	odgwsad.counts4 { lappend reasons odgwCounts(4) }
	odgwsad.expMult1 { lappend reasons odgwActive(1) }
	odgwsad.expMult2 { lappend reasons odgwActive(2) }
	odgwsad.expMult3 { lappend reasons odgwActive(3) }
	odgwsad.expMult4 { lappend reasons odgwActive(4) }
   odgwsad.odgwSize { lappend reasons odgwSize }
   odgwsad.notGuiding { lappend reasons odgwActive(1) odgwActive(2) odgwActive(3) odgwActive(4) }
	}
	switch $name {
	gemssad.lgsLoop -
	gemssad.ttLoop -
	gemssad.focLoop -
	gemssad.flexLoop -
	gemssad.astromReady -
	gemssad.aniLoop {
		if { [checkGemsActive] } {
			lappend reasons gemsActive
		}
	}	
	}
	if { [llength $reasons] > 0 } {
		notify $reasons
	}
}

itcl::body RealGems::checkGemsActive {} {
	set oldVal $gemsActive
	set gemsActive OFF
	foreach loop { ttLoop aniLoop flexLoop focLoop lgsLoop } {
		if { [string equal -nocase "[sa gemssad get $loop value]" "CLOSED" ] } {
			set gemsActive ON
		}
	}
	if { [string equal -nocase "[sa gemssad get astromReady value]" "READY" ] } {
		set gemsActive ON
	}
	if { $gemsActive ne $oldVal } {
		return 1
	}
	return 0
}

#ODGW special commands
itcl::body RealGems::setODGWSize { size {apply 1}} {
   cs gems::odgwSetup set odgwSize $size
   $logger logmess "gems::setODGWSize $size"
   
   #Autoset idleRows and sciRows
   setODGWSciRows [calparam odgwGetSciRows $size] 0
   setODGWIdleRows [calparam odgwGetIdleRows $size] 0
   setODGWDisplayRate [calparam odgwGetDisplayRate $size] 0

   set lastCmdSys applyC
   if { $apply } {
      catch {cs gems::odgwSetup post}
   }
}

