#+
# RealGems
#
# This class encapsulates the configuration interactions with the real GEMS
# through EPICS. It is a singleton.
#
# J Luhrs 01 April 2009
#
#  $Id: Exp $
#-

package require Ocspkg

itcl::class RealGems {
	inherit IGemsSys  
public {
	constructor {} {}
	destructor {}

	method slewReset {}
	#Loop control commands
	method openLGSLoop {}
	method closeLGSLoop {}
	method openTTLoop {}
	method closeTTLoop {}
	method openFocLoop {}
	method closeFocLoop {}
	method openFlexLoop {}
	method closeFlexLoop {}
	method openAniLoop {}
	method closeAniLoop {}
	method disableM1Offload {}
	method enableM1Offload {}
	method disableM2Offload {}
	method enableM2Offload {}
	method disableRotOffload {}
	method enableRotOffload {}
	method pauseLoops {why}
	method resumeLoops {}
	method stopLoops {}
   method setupLoops {loopList sources}
	
	#Loop configuration
	method configureNGS {sources}
	
	#Astrometry
	method setAstroMode {mode}
	method startAstrometry {}
	method stopAstrometry {}
	
	method moveADC {pos}
	method startADC {}
	method stopADC {}
	method moveBeamSplitter {pos}

	#WFS control commands
   method setupODGW {idList}
	method startODGW {idList}
	method stopODGW {idList}
	method startTTWFS {idList}
	method stopTTWFS {idList}
	method startLGSWFS {}
	method stopLGSWFS {}
	method setODGWExposure {id val}
	method setTTWFSExposure {id val}
	method setLGSWFSExposure {val}

   #ODGW special commands
   method setODGWSize { size {apply 1} }
   method getODGWSize {}
   method setODGWSciRows { num {apply 1} }
   method getODGWSciRows {}
   method setODGWIdleRows { num {apply 1} }
   method getODGWIdleRows {}
   method setODGWDisplay { opt {apply 1} }
   method getODGWDisplayRate {}
   method setODGWDisplayRate { val {apply 1} }
   
   #LIS commands
   method pauseLis {}

	#States
	method getGemsActive {}
	method getLoopsState {}
	method getLGSLoopState {}
	method getTTLoopState {}
	method getFocLoopState {}
	method getFlexLoopState {}
	method getAniLoopState {}
	method getM1OffloadState {}
	method getM2OffloadState {}
	method getRotOffloadState {}
	method getTTLoopSources {}
   method getFlexLoopSources {}
	method getODGWActive {id}
   method getODGWEnabled {id}
	method getTTWFSActive {id}
	method getLGSWFSActive {}
	method getODGWExposure {id}
	method getTTWFSExposure {id}
	method getLGSWFSExposure {}
	method getODGWCounts {id}
	method getTTWFSCounts {id}
	method getLGSWFSCounts {id}
   method getLGSWFSAverage {}
	method getAstroMode {}
	method getAstrometryState {}
	method getADCPos {}
	method getADCLoopState {}
	method getBeamSplitterPos {}
	method getLaserProp {}
   
   #Loops commands state
   method getLGSCmdState {}
   method getLGSCmdMess {}
   method getTTCmdState {}
   method getTTCmdMess {}
   method getFocCmdState {}
   method getFocCmdMess {}
   method getFlexCmdState {}
   method getFlexCmdMess {}
   method getAniCmdState {}
   method getAniCmdMess {}

	
	#Command state
	method getCommandState {}
	method getLastError {}

	#Observable interface
	method subscribe {observer}
	method unsubscribe {observer}
	
	variable logger logactions
}
private {
	variable lastCmdSys ""
	variable lastTTFLux
	variable lastLGSFlux
	variable gemsActive OFF
	variable astroMode None
	variable odgwBaseExpTime 0.00125
	variable odgwExpTime
   variable validLGSWFSCounts 1
   
   common minExpTime 0.00125
   common expTimeTolerance 0.1
		
	variable observerList {}
	method notify {reasons}
	
	method onStatusChange {name alarm time value}
	method checkGemsActive {}
   method waitForCmdIdle {{timeout 1000}}
   method setTTLoopInputs {sources}
   method calculateBaseExpTime { idList tolerance }
}
}

itcl::body RealGems::constructor {} {
	if { [llength [info commands epics]] == 0 } {
		error "unable to load package: EPICS ocs service does not exist"
	}
   epics cs gems::slewReset
	epics cs gems::lgsLoopCtrl
	epics cs gems::ttLoopCtrl
	epics cs gems::focLoopCtrl
	epics cs gems::flexLoopCtrl
	epics cs gems::taLoopCtrl
	epics cs gems::m1OffloadCtrl
	epics cs gems::m2OffloadCtrl
	epics cs gems::crLoopCtrl
	epics cs gems::seqLoopCtrl
	epics cs gems::ngsConfig
	#epics cs gems::astroMode
	epics cs gems::astrometricCtrl
	epics cs gems::adcMech
	epics cs gems::adcLoop
	epics cs gems::beamSplitter
	epics cs gems::ttApdCtrl
	epics cs gems::ttExpCtrl
	epics cs gems::lgsExpCtrl
	epics cs gems::odgwSetup
   epics cs gems::odgwGuide
   epics cs gems::odgwEndGuide
   epics cs gems::lisPause
	epics sa gemssad
	epics sa aomsad
   epics sa aomauxsad
   epics sa aomadcsad
   epics sa rtcsad
	epics sa odgwsad
	
	cs gems::aomAuxApply setTimeout 3
   cs gems::aomAdcApply setTimeout 3
	cs gems::mystApply setTimeout 3
	
	set lastTTFLux {-1 -1 -1 -1 -1 -1 -1 -1}
	set lastLGSFlux {-1 -1 -1 -1 -1 -1}
   set odgwExpTime(1) 0.1
   set odgwExpTime(2) 0.1
   set odgwExpTime(3) 0.1
   set odgwExpTime(4) 0.1
	
	#sa gemssad proc applyC [itcl::code $this onStatusChange]
	sa gemssad proc sciReady [itcl::code $this onStatusChange]
	sa gemssad proc lgsLoop [itcl::code $this onStatusChange]
	sa gemssad proc ttLoop [itcl::code $this onStatusChange]
	sa gemssad proc focLoop [itcl::code $this onStatusChange]
	sa gemssad proc flexLoop [itcl::code $this onStatusChange]
	sa gemssad proc astromReady [itcl::code $this onStatusChange]
	sa gemssad proc aniLoop [itcl::code $this onStatusChange]
   sa gemssad proc aniLoop [itcl::code $this onStatusChange]
   sa gemssad proc rtcHealth [itcl::code $this onStatusChange]
	#sa gemssad proc lgsFlux [itcl::code $this onStatusChange]
	#sa gemssad proc ngsFlux [itcl::code $this onStatusChange]
   sa gemssad proc m1Offload [itcl::code $this onStatusChange]
   sa gemssad proc m2Offload [itcl::code $this onStatusChange]
   sa gemssad proc crOffload [itcl::code $this onStatusChange]

	sa gemssad proc ngs1 [itcl::code $this onStatusChange]
	sa gemssad proc ngs2 [itcl::code $this onStatusChange]
	sa gemssad proc ngs3 [itcl::code $this onStatusChange]
	sa gemssad proc odgs1 [itcl::code $this onStatusChange]
	sa gemssad proc odgs2 [itcl::code $this onStatusChange]
	sa gemssad proc odgs3 [itcl::code $this onStatusChange]
	sa gemssad proc odgs4 [itcl::code $this onStatusChange]
	sa gemssad proc oigs [itcl::code $this onStatusChange]
	sa gemssad proc ngs1Mag [itcl::code $this onStatusChange]
	sa gemssad proc ngs2Mag [itcl::code $this onStatusChange]
	sa gemssad proc ngs3Mag [itcl::code $this onStatusChange]
	sa gemssad proc odgs1Mag [itcl::code $this onStatusChange]
	sa gemssad proc odgs2Mag [itcl::code $this onStatusChange]
	sa gemssad proc odgs3Mag [itcl::code $this onStatusChange]
	sa gemssad proc odgs4Mag [itcl::code $this onStatusChange]
	sa gemssad proc apd1Status [itcl::code $this onStatusChange]
	sa gemssad proc apd2Status [itcl::code $this onStatusChange]
	sa gemssad proc apd3Status [itcl::code $this onStatusChange]

	#sa aomsad proc applyC [itcl::code $this onStatusChange]
	sa aomsad proc adcScState [itcl::code $this onStatusChange]
	sa aomsad proc beamSplitterState [itcl::code $this onStatusChange]
	sa aomsad proc adcScLoop [itcl::code $this onStatusChange]
	
	sa rtcsad proc tt1Active [itcl::code $this onStatusChange]
	sa rtcsad proc tt2Active [itcl::code $this onStatusChange]
	sa rtcsad proc tt3Active [itcl::code $this onStatusChange]
	
#	sa odgwsad proc counts1 [itcl::code $this onStatusChange]
#	sa odgwsad proc counts2 [itcl::code $this onStatusChange]
#	sa odgwsad proc counts3 [itcl::code $this onStatusChange]
#	sa odgwsad proc counts4 [itcl::code $this onStatusChange]
	sa odgwsad proc expMult1 [itcl::code $this onStatusChange]
	sa odgwsad proc expMult2 [itcl::code $this onStatusChange]
	sa odgwsad proc expMult3 [itcl::code $this onStatusChange]
	sa odgwsad proc expMult4 [itcl::code $this onStatusChange]
   sa odgwsad proc odgwSize [itcl::code $this onStatusChange]
   sa odgwsad proc notGuiding [itcl::code $this onStatusChange]
}

