	return [string toupper [sa gemssad get m2Offload value]]
}

itcl::body RealGems::getRotOffloadState {} {
	return [string toupper [sa gemssad get crOffload value]]
}

itcl::body RealGems::getTTLoopSources {} {
	set sources ""
	for {set i 1} { $i <= 3} { incr i } {
		if { [sa gemssad get ngs${i} value] eq "Used" } {
			lappend sources ttgs${i} [sa gemssad get ngs${i}Mag value]
		}
	}
	for {set i 1} { $i <= 4} { incr i } {
		if { [sa gemssad get odgs${i} value] eq "Used" } {
			lappend sources odgw${i} [sa gemssad get odgs${i}Mag value]
		}
	}
	if { [sa gemssad get oigs value] eq "Used" } {
		lappend sources oigs [sa gemssad get oigsMag value]
	}
	
	return $sources
}

itcl::body RealGems::getODGWActive {id} {
	if { [ sa odgwsad get expMult${id} value] > 0 } {
		return ON
	}
	return OFF
}

itcl::body RealGems::getTTWFSActive {id} {
	if { [string compare -nocase [sa rtcsad get tt${id}Active value] "ENABLED"] == 0} {
		return ON
	}
	return OFF
}

itcl::body RealGems::getLGSWFSActive {} {
#	$logger logmess "RealGems::getLGSWFSActive Gems status undefined."
	return ON
}

itcl::body RealGems::getSFSActive {} {
#	$logger logmess "RealGems::getSFSActive Gems status undefined."
	set sfsActive [sa sfssad get sfsActive value]
	if { [string is integer -strict $sfsActive] && $sfsActive != 0 } {
		return ON
	}
	return OFF
}

itcl::body RealGems::getODGWExposure {id} {
   set base [sa odgwsad get baseExpTime value]
   set mult [sa odgwsad get expMult${id} value]
   
   if {[string is double -strict $base] && [string is double -strict $mult] } {
      return [expr "$base * $mult"]
   } else {
     return "0"
   }
}

itcl::body RealGems::getTTWFSExposure {id} {
   return [sa rtcsad get ngsExpMult value]
}

itcl::body RealGems::getLGSWFSExposure {} {
	return [sa rtcsad get lgsExp value]
}

itcl::body RealGems::getSFSExposure {} {
	return [sa sfssad get sfsExp value]
}

itcl::body RealGems::getODGWCounts {id} {
	switch $id {
	1 { set index 3 }
	2 { set index 4 }
	3 { set index 5 }
	4 { set index 6 }
	default {
		$logger logmess "RealGems::getODGWCounts invalid index $id"
		return
	}
	}
	set vals [sa gemssad get ngsFlux value]
	if { [llength $vals] < 7 } {
		$logger logmess "RealGems::getODGWCounts invalid values read from Myst $vals"
		return 0
	}
	return [lindex $vals $index]
}

itcl::body RealGems::getTTWFSCounts {id} {
	switch $id {
	1 { set index 0 }
	2 { set index 1 }
	3 { set index 2 }
	default {
		$logger logmess "RealGems::getTTWFSCounts invalid index $id"
		return
	}
	}
	set vals [sa gemssad get ngsFlux value]
	if { [llength $vals] < 3 } {
		$logger logmess "RealGems::getTTWFSCounts invalid values read from Myst $vals"
		return 0
	}
	return [lindex $vals $index]
}

itcl::body RealGems::getLGSWFSCounts {id} {
	switch $id {
	1 { set index 1 }
	2 { set index 2 }
	3 { set index 3 }
	4 { set index 4 }
	5 { set index 5 }
	default {
		$logger logmess "RealGems::getLGSWFSCounts invalid index $id"
		return
	}
	}
	set vals [sa gemssad get lgsFlux value]
	if { [llength $vals] < 6 } {
		$logger logmess "RealGems::getLGSWFSCounts invalid values read from Myst $vals"
		return 0
	}
	return [lindex $vals $index]
}

itcl::body RealGems::getSFSCounts {} {
#	$logger logmess "RealGems::getSFSCounts Gems status undefined."
	return [sa sfssad get sfsCounts value]
}

itcl::body RealGems::getAstroMode {} {
#	$logger logmess "RealGems::getAstroMode Gems status undefined."
	#return [sa gemssad get astroMode value]
	return $astroMode
}

itcl::body RealGems::getAstrometryState {} {
	return [string toupper [sa gemssad get astromReady value]]
}

itcl::body RealGems::getADCPos {} {
	return [sa aomsad get adcScState value]
}

itcl::body RealGems::getADCLoopState {} {
	return [string toupper [sa aomsad get adcScLoop value]]
}


itcl::body RealGems::getBeamSplitterPos {} {
	return [sa aomsad get beamSplitterState value]
}

itcl::body RealGems::getLaserProp {} {
	return [sa gemssad get laserProp value]
}

#Command state
itcl::body RealGems::getCommandState {} {
	if { $lastCmdSys ne "" } {
		return [sa $lastCmdSys get applyC value]
	} else {
		return IDLE
	}
}

itcl::body RealGems::getLastError {} {
	if { $lastCmdSys ne "" } {
		return [sa $lastCmdSys get message value]
	} else {
		return ""
	}
}

#Observable interface
itcl::body RealGems::subscribe {observer} {
# Check that the observer isn't already on the list.
	if { [lsearch -exact $observerList $observer] == -1 } {
# Append the observer to the list.
		lappend observerList $observer
	}
}

itcl::body RealGems::unsubscribe {observer} {
# Check that the observer is registered.
	set index [lsearch -exact $observerList $observer]
	if { $index != -1 } {
		set observerList [lreplace $observerList $index $index]
	}
}

itcl::body RealGems::notify {reasons} {
	foreach observer $observerList {
		$observer $reasons
	}
}

itcl::body RealGems::onStatusChange {name alarm time value} {
	set reasons ""
	switch $name {
	gemssad.applyC -
	aomsad.applyC { lappend reason cmdState }
	gemssad.lgsFlux {
		for { set i 1 } { $i <= 5 } { incr i } {
			if { [lindex $value $i] != [lindex lastLGSFlux $i] } {
				lappend reasons lgswfsCounts($i)
			}
		}
	}
	gemssad.ngsFlux {
		foreach {i reason} {0 ttwfsCounts(1) 1 ttwfsCounts(2) 2 ttwfsCounts(3) 3 odgwCounts(1) 4 odgwCounts(2) 5 odgwCounts(3) 6 odgwCounts(4)} {
			if { [lindex $value $i] != [lindex lastTTFlux $i] } {
				lappend reasons $reason
			}
		}
	}
	gemssad.apd1Status { lappend reasons ttwfsActive1 }
	gemssad.apd2Status { lappend reasons ttwfsActive2 }
	gemssad.apd3Status { lappend reasons ttwfsActive3 }
	gemssad.ngs1 -
	gemssad.ngs2 -
	gemssad.ngs3 -
	gemssad.odgw1 -
	gemssad.odgw2 -
	gemssad.odgw3 -
	gemssad.odgw4 -
	gemssad.oigs { lappend reasons ttLoopSources }
	gemssad.lgsLoop { lappend reasons lgsLoopState }
	gemssad.ttLoop { lappend reasons ttLoopState }
	gemssad.focLoop { lappend reasons focLoopState }
	gemssad.flexLoop { lappend reason flexLoopState }
	gemssad.astromReady { lappend reasons astroState }
	gemssad.aniLoop { lappend reasons aniLoopState }
	gemssad.sciReady { lappend reasons loopsSettled }
	aomsad.adcScState { lappend reasons adcPos }
	aomsad.adcScLoop { lappend reasons adcState }
	aomsad.beamSplitterState { lappend reasons beamSplitterPos }
	sfssad.sfsActive { lappend reasons sfsActive }
	sfssad.sfsCounts { lappend reasons sfsCounts }
	rtcsad.tt1Active { lappend reasons ttwfsActive(1) }
	rtcsad.tt2Active { lappend reasons ttwfsActive(2) }
	rtcsad.tt3Active { lappend reasons ttwfsActive(3) }
	odgwsad.counts1 { lappend reasons odgwCounts(1) }
	odgwsad.counts2 { lappend reasons odgwCounts(2) }
	odgwsad.counts3 { lappend reasons odgwCounts(3) }
	odgwsad.counts4 { lappend reasons odgwCounts(4) }
	odgwsad.expMult1 { lappend reasons odgwActive(1) }
	odgwsad.expMult2 { lappend reasons odgwActive(2) }
	odgwsad.expMult3 { lappend reasons odgwActive(3) }
	odgwsad.expMult4 { lappend reasons odgwActive(4) }
   odgwsad.odgwSize { lappend reasons odgwSize }
	}
	switch $name {
	gemssad.lgsLoop -
	gemssad.ttLoop -
	gemssad.focLoop -
	gemssad.flexLoop -
	gemssad.astromReady -
	gemssad.aniLoop {
		if { [checkGemsActive] } {
			lappend reasons gemsActive
		}
	}	
	}
	if { [llength $reasons] > 0 } {
		notify $reasons
	}
}

itcl::body RealGems::checkGemsActive {} {
	set oldVal $gemsActive
	set gemsActive OFF
	foreach loop { ttLoop aniLoop flexLoop focLoop lgsLoop } {
		if { [string equal -nocase "[sa gemssad get $loop value]" "CLOSED" ] } {
			set gemsActive ON
		}
	}
	if { [string equal -nocase "[sa gemssad get astromReady value]" "READY" ] } {
		set gemsActive ON
	}
	if { $gemsActive ne $oldVal } {
		return 1
	}
	return 0
}

#ODGW special commands
itcl::body RealGems::setODGWSize { size {apply 1}} {
   cs gems::odgwSetup set odgwSize $size
   $logger logmess "gems::odgwSetup $size"
   set lastCmdSys tcssad
   if { $apply } {
      catch {cs gems::odgwSetup post}
   }
}

itcl::body RealGems::getODGWSize {} {
   return [sa odgwsad get odgwSize value]
}
