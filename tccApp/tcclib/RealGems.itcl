itcl::body RealGems::waitForCmdIdle {{timeout 1000}} {
   set elapsedTime 0
   while {$timeout==0 || $elapsedTime<$timeout} {
      if {[getCommandState] eq "IDLE"} {
         return ok
      } elseif {[getCommandState] eq "ERROR"} {
         return error
      }
      after 100
      set elapsedTime [expr $elapsedTime + 100]
      update
   }
   return timeout
}

itcl::body RealGems::setupLoops {loopList sources} {
   if { [llength $sources] > 0 } {
      set change [setTTLoopInputs $sources]
   } else {
      set change 0
   }
   
   if { [lsearch $loopList lwfs] >= 0 } {
      if { [getLGSLoopState] ne "CLOSED" } {
         cs gems::lgsLoopCtrl set cmd START
         set change 1
      }
   } else {
      if { [getLGSLoopState] ne "OPEN" } {
         cs gems::lgsLoopCtrl set cmd STOP
         set change 1
      }
   }
   if { [lsearch $loopList ani] >= 0 } {
      if { [getAniLoopState] ne "CLOSED" } {
         cs gems::taLoopCtrl set cmd START
         set change 1
      }
   } else {
      if { [getAniLoopState] ne "OPEN" } {
         cs gems::taLoopCtrl set cmd STOP
         set change 1
      }
   }
   if { [lsearch $loopList tt] >= 0 } {
      if { [getTTLoopState] ne "CLOSED" } {
         cs gems::ttLoopCtrl set cmd START
         set change 1
      }
   } else {
      if { [getTTLoopState] ne "OPEN" } {
         cs gems::ttLoopCtrl set cmd STOP
         set change 1
      }
   }
   if { [lsearch $loopList flex] >= 0 } {
      if { [getFlexLoopState] ne "CLOSED" } {
         cs gems::flexLoopCtrl set cmd START
         set change 1
      }
   } else {
      if { [getFlexLoopState] ne "OPEN" } {
         cs gems::flexLoopCtrl set cmd STOP
         set change 1
      }
   }
   if { [lsearch $loopList sfs] >= 0 } {
      if { [getFocLoopState] ne "CLOSED" } {
         cs gems::focLoopCtrl set cmd START
         set change 1
      }
   } else {
      if { [getFocLoopState] ne "OPEN" } {
         cs gems::focLoopCtrl set cmd STOP
         set change 1
      }
   }
   if { [lsearch $loopList m1] >= 0 } {
      if { [getM1OffloadState] ne "CLOSED" } {
         cs gems::m1OffloadCtrl set cmd START
         set change 1
      }
   } else {
      if { [getM1OffloadState] ne "OPEN" } {
         cs gems::m1OffloadCtrl set cmd STOP
         set change 1
      }
   }
   if { [lsearch $loopList m2] >= 0 } {
      if { [getM2OffloadState] ne "CLOSED" } {
         cs gems::m2OffloadCtrl set cmd START
         set change 1
      }
   } else {
      if { [getM2OffloadState] ne "OPEN" } {
         cs gems::m2OffloadCtrl set cmd STOP
         set change 1
      }
   }
   if { [lsearch $loopList rot] >= 0 } {
      if { [getRotOffloadState] ne "CLOSED" } {
         cs gems::crLoopCtrl set cmd START
         set change 1
      }
   } else {
      if { [getRotOffloadState] ne "OPEN" } {
         cs gems::crLoopCtrl set cmd STOP
         set change 1
      }
   }
   set lastCmdSys gemssad
   if { $change } {
      catch {cs gems::lgsLoopCtrl post}
   }
}

itcl::body RealGems::calculateBaseExpTime { idList tolerance } {
   set len [llength $idList]
   # return a default value if no ODGW is active
   if { $len == 0 } {
      return 0.1
   }
   set expTimes ""
   for { set i 0 } { $i < $len } { incr i } {
      lappend expTimes $odgwExpTime([lindex $idList $i])
   }
   set expTimes [lsort -real -increasing -unique $expTimes]
   set len [llength $expTimes]
   #if only one ODGW, or all have the same exposure time, return that value
   if { $len == 1 } {
      return $expTimes
   }
   #Find a big exposure time that keeps al exposure times within tolerance.
   #The method uses brute force to find a suitable value.
   set minT [lindex $expTimes 0]
   set bestExpTime $minExpTime
   for { set i 0 } { $i < $len } { incr i } {
      set expTime [lindex $expTimes $i]
      set minN [expr round ( $expTime / ( $minT*(1.0+$tolerance) ) ) ]
      set minN [expr $minN>0 ? $minN : 1]
      set maxN [expr floor ( $expTime / $minExpTime ) ]
      for { set j $minN } { $j <= $maxN } { incr j } {
         set baseExpTime [expr $expTime / $j]
         set k 0
         for { } { $k < $len } { incr k } {
            if { $k != $i } {
               set testExpTime [lindex $expTimes $k]
               set mult [expr round( $testExpTime/$baseExpTime ) ]
               set mult [expr $mult>0 ? $mult : 1]
               if { [expr abs( $mult * $baseExpTime / $testExpTime - 1.0 ) ] > $tolerance } {
                  break
               }
            }
         }
         if { $k == $len } {
            if { $baseExpTime > $bestExpTime } { 
               set  bestExpTime $baseExpTime
            }
            break
         }
      }
   }
   return $bestExpTime
}

