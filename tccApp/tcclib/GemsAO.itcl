#+
# GemsAO
#
# This class keeps the GeMS AO settings and sequences its commands.
#
# J Luhrs 01 April 2009
#
#  $Id: Exp $
#+

itcl::class GemsAO {
public {
	variable gaos 0
	variable ttgs1Active 0
	variable ttgs1Exp	10
	variable ttgs2Active 0
	variable ttgs2Exp	10
	variable ttgs3Active 0
	variable ttgs3Exp	10
	variable sfsActive 0
	variable sfsExp 10
	variable odgw1Active 0
	variable odgw1Exp	10
	variable odgw2Active 0
	variable odgw2Exp	10
	variable odgw3Active 0
	variable odgw3Exp	10
	variable odgw4Active 0
	variable odgw4Exp	10
	variable ttgs1Mag	5
	variable ttgs2Mag	5
	variable ttgs3Mag	5
	variable odgw1Mag 5
	variable odgw2Mag 5
	variable odgw3Mag 5
	variable odgw4Mag 5
	variable oigsMag 5
	variable lwfsActive 0
	variable lwfsFreq 100
	variable lwfsLoop 0
	variable oigsLoop 0
	variable odgwLoop 0
	variable ttgsLoop 0
	variable sfsLoop 0
	
	variable lastError ""
	
	method enable {}
	method disable {}
	method state {var}

	constructor {} {}

	method configure {args} { if {[llength $args] > 0 } {logactions logmess "$this configure $args"} ; eval _itcl_config $args }
}
private {
	variable sys
	method waitFor {timeout outCondition}
	method waitForCmdIdle {{timeout 1000}}
	method waitForCmdComplete {idleTimeout settledTimeout settledCond timeoutMsg}
	method startWFS {}
	method startTTGS {id}
	method startODGW {id}
	method stopWFS {}
	method stopTTGS {id}
	method stopODGW {id}
	method startLoops {}
	method stopLoops {}
	method disableWFS
	method disableTTGS {id}
	method disableODGW {id}
	method disableLoops {}
	method defineTTSources {}
	method _itcl_config {option args} \
		@itcl-builtin-configure
}
}

itcl::body GemsAO::constructor {} {
	set sys [GemsSys::getSingleton]
}

itcl::body GemsAO::enable {} {
	set lastError ""
	#WFS are enabled first
	if { [startWFS] } {
		return 1
	}

	#Then close loops
	if { [startLoops] } {
		return 1
	}
	
	#Then open loops that must be opened
	if { [stopLoops] } {
		return 1
	}
	#And finally disable WFS
	if { [stopWFS] } {
		return 1
	}	

	return 0
}

itcl::body GemsAO::disable {} {
	set errMsg ""
	set ret 0
	
	if  { [disableLoops] } {
		set ret 1
		set errMsg $lastError
	}
	if  { [disableWFS] } {
		set ret 1
		set errMsg "$errMsg\n$lastError"
	}
	
	set lastError $errMsg
	return $ret
}

itcl::body GemsAO::waitFor {timeout outCondition} {
	set elapsedTime 0
	while {$timeout==0 || $elapsedTime<$timeout} {
		if {[eval $outCondition]} {
			return ok
		}
		after 100
		set elapsedTime [expr $elapsedTime + 100]
		update
	}
	return timeout
}

itcl::body GemsAO::waitForCmdIdle {{timeout 1000}} {
	set elapsedTime 0
	while {$timeout==0 || $elapsedTime<$timeout} {
		if {[$sys getCommandState] eq "IDLE"} {
			return ok
		} elseif {[$sys getCommandState] eq "ERROR"} {
			set lastError [$sys getLastError]
			return error
		}
		after 100
		set elapsedTime [expr $elapsedTime + 100]
		update
	}
	return timeout
}

itcl::body GemsAO::waitForCmdComplete {idleTimeout settledTimeout settledCond timeoutMsg} {
	set result [waitForCmdIdle $idleTimeout]
	if {$result eq "error"} {
		return 1
	} elseif {$result eq "timeout" || [waitFor $settledTimeout $settledCond] eq "timeout" } {
		set lastError "Timed out waiting for $timeoutMsg"
		return 1
	}
	return 0
}

itcl::body GemsAO::startWFS {} {
	for {set i 1} {$i <= 3} { incr i} {
		if { [startTTGS $i] } {
			return 1
		}
	}
	if { $sfsActive } {
		if { $sfsExp ne "" && $sfsExp != [$sys getSFSExposure] } {
			$sys setSFSExposure $sfsExp
			if { [waitForCmdComplete 1000 1000 "expr 1" "SFS exposure setup"] } {
				return 1
			}
		}
		if { ![state sfs] } {
			$sys startSFS
			if { [waitForCmdComplete 1000 1000 "state sfs" "SFS to go ON"] } {
				return 1
			}
		}
	}

	if { $lwfsActive} {
		if {$lwfsFreq ne "" && $lwfsFreq != [$sys getLGSWFSExposure]} {
			$sys setLGSWFSExposure $lwfsFreq 
			if { [waitForCmdComplete 1000 1000 "expr 1" "LGSWFS exposure setup"] } {
				return 1
			}			
		}
		if { ![state lgswfs] } {
			$sys startLGSWFS
			if { [waitForCmdComplete 1000 1000 "state lgswfs" "LGSWFS to go ON"] } {
				return 1
			}
		}
	}
	for {set i 1} {$i <= 4} { incr i} {
		if { [startODGW $i] } {
			return 1
		}
	}
	return 0
}

itcl::body GemsAO::startTTGS {id} {
	if { [set ttgs${id}Active] } {
		if {[set ttgs${id}Exp] ne "" && [set ttgs${id}Exp] != [$sys getTTWFSExposure $id]} {
			$sys setTTWFSExposure $id [set ttgs${id}Exp] 
			if { [waitForCmdComplete 1000 1000 "expr 1" "TTWFS${id} exposure setup"] } {
				return 1
			}
		}
		if { ![state ttgs${id}] } {
			$sys startTTWFS $id
			if { [waitForCmdComplete 1000 1000 "state ttgs${id}" "TTWFS${id} to go ON"] } {
				return 1
			}
		}
	}
	return 0	
}

itcl::body GemsAO::startODGW {id} {
	if { [set odgw${id}Active] } {
		if {[set odgw${id}Exp] ne "" && [set odgw${id}Exp] != [$sys getODGWExposure $id]} {
			$sys setODGWExposure $id [set odgw${id}Exp] 
			if { [waitForCmdComplete 1000 1000 "expr 1" "ODGW${id} exposure setup"] } {
				return 1
			}
		}
		if { ![state odgw${id}] } {
			$sys startODGW $id
			if { [waitForCmdComplete 1000 1000 "state odgw${id}" "ODGW${id} to go ON"] } {
				return 1
			}
		}
	}
	return 0	
}

itcl::body GemsAO::stopWFS {} {
	set errMsg ""
	set ret 0
	
	for {set i 1} {$i <= 4} { incr i} {
		if { [stopODGW $i] } {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { !$lwfsActive && [state lgswfs] } {
		$sys stopLGSWFS
		if {[waitForCmdComplete 1000 1000 {expr ![state lgswfs]} "LGSWFS to go OFF"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { !$sfsActive && [state sfs] } {
		$sys stopSFS
		if {[waitForCmdComplete 1000 1000 {expr ![state sfs]} "SFS to go OFF"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	for {set i 1} {$i <= 3} { incr i} {
		if { [stopTTGS $i] } {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	set lastError $errMsg
	return $ret
}

itcl::body GemsAO::stopTTGS {id} {
	if { ![set ttgs${id}Active] && [state ttgs${id}] } {
		$sys stopTTWFS $id
		if {[waitForCmdComplete 1000 1000 "expr ![state ttgs"${id}"]" "TTWFS${id} to go OFF"]} {
			return 1
		}
	}
	return 0
}

itcl::body GemsAO::stopODGW {id} {
	if { ![set odgw${id}Active] && [state odgw${id}] } {
		$sys stopODGW $id
		if {[waitForCmdComplete 1000 1000 "expr ![state odgw"${id}"]" "ODGW${id} to go OFF"]} {
			return 1
		}
	}
	return 0
}

itcl::body GemsAO::disableWFS {} {
	set errMsg ""
	set ret 0
	
	for {set i 1} {$i <= 4} { incr i} {
		if { [disableODGW $i] } {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state lgswfs] } {
		$sys stopLGSWFS
		if {[waitForCmdComplete 1000 1000 {expr ![state lgswfs]} "LGSWFS to go OFF"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state sfs] } {
		$sys stopSFS
		if {[waitForCmdComplete 1000 1000 {expr ![state sfs]} "SFS to go OFF"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	for {set i 1} {$i <= 3} { incr i} {
		if { [disableTTGS $i] } {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	set lastError $errMsg
	return $ret
}

itcl::body GemsAO::disableTTGS {id} {
	if { [state ttgs${id}] } {
		$sys stopTTWFS $id
		if {[waitForCmdComplete 1000 1000 "expr ![state ttgs"${id}"]" "TTWFS${id} to go OFF"]} {
			return 1
		}
	}
	return 0
}

itcl::body GemsAO::disableODGW {id} {
	if { [state odgw${id}] } {
		$sys stopODGW $id
		if {[waitForCmdComplete 1000 1000 "expr ![state odgw"${id}"]" "ODGW${id} to go OFF"]} {
			return 1
		}
	}
	return 0
}

itcl::body GemsAO::startLoops {} {
	if { $gaos } {
		#Set TT loop sources
		$sys configureTTLoop [defineTTSources]
		if {[waitForCmdComplete 1000 1000 "expr 1" "TT sources configure"]} {
			return 1
		}
		set astroMode [state astromode]
		set useAstrometry [expr {$astroMode eq "Regular" || $astroMode eq "Good" || $astroMode eq "Best" } ]
		if { $useAstrometry && ( $ttgs1Active || $ttgs2Active || $ttgs3Active ) && ![state astrometry]} {
			$sys startAstrometry
			if {[waitForCmdComplete 1000 132000 "state astrometry" "Astrometry to stabilize"]} {
				return 1
			}
		}
		if { $gaos && [AO cget -m1source] eq "GAOS" && ![state m1Offload] } {
			$sys enableM1Offload
			if {[waitForCmdComplete 1000 1000 "state m1Offload" "M1 Offload to go ON"]} {
				return 1
			}
		}
		if { $gaos && [AO cget -aoguide] eq "On" && ![state m2Offload] } {
			$sys enableM2Offload
			if {[waitForCmdComplete 1000 1000 "state m2Offload" "M2 Offload to go ON"]} {
				return 1
			}
		}
		if { $lwfsLoop && ![state lwfsLoop] } {
			$sys closeLGSLoop
			if {[waitForCmdComplete 1000 5000 "state lwfsLoop" "LGS Loop to close"]} {
				return 1
			}
		}
		set ttLoop [expr $ttgsLoop || ( $odgwLoop && \
			( $odgw1Active + $odgw2Active + $odgw3Active + $odgw4Active ) >= 3 ) ]
		if { $ttLoop && ![state ttgsLoop] } {
			$sys closeTTLoop
			if {[waitForCmdComplete 1000 5000 "state ttgsLoop" "TT Loop to close"]} {
				return 1
			}
		}
		if { $sfsLoop && ![state sfsLoop] } {
			$sys closeFocLoop
			if {[waitForCmdComplete 1000 5000 "state sfsLoop" "Focus Loop to close"]} {
				return 1
			}
		}
		if { ( $odgwLoop || $oigsLoop ) && ![state flexLoop] } {
			$sys closeFlexLoop
			if {[waitForCmdComplete 1000 5000 "state flexLoop" "Flexure Loop to close"]} {
				return 1
			}
		}
		if { $ttLoop && ![state aniLoop] } {
			$sys closeAniLoop
			if {[waitForCmdComplete 1000 5000 "state aniLoop" "Anisoplanetism Loop to close"]} {
				return 1
			}
		}
		if { $gaos && [AO cget -crsource] eq "GAOS" && ![state rotOffload] } {
			$sys enableRotOffload
			if {[waitForCmdComplete 1000 1000 "state rotOffload" "Rotator Offload to go ON"]} {
				return 1
			}
		}
	}
	return 0
}

itcl::body GemsAO::stopLoops {} {
	if { !$gaos } {
		disableLoops
	} else {
		if { ( !$gaos || [AO cget -crsource] ne "GAOS" ) && [state rotOffload] } {
			$sys disableRotOffload
			if {[waitForCmdComplete 1000 1000 {expr ![state rotOffload]} "Rotator Offload to go OFF"]} {
				set ret 1
				set errMsg 
			}
		}
		set ttLoop [expr $ttgsLoop || ( $odgwLoop && \
			( $odgw1Active + $odgw2Active + $odgw3Active + $odgw4Active ) >= 3 ) ]
		if { !$ttLoop && [state aniLoop] } {
			$sys openAniLoop
			if {[waitForCmdComplete 1000 1000 {expr ![state aniLoop]} "Anisoplanetism Loop to open"]} {
				return 1
			}
		}
		if { ( !$odgwLoop && !$oigsLoop ) && [state flexLoop] } {
			$sys openFlexLoop
			if {[waitForCmdComplete 1000 1000 {expr ![state flexLoop]} "Flexure Loop to open"]} {
				return 1
			}
		}
		if { !$sfsLoop && [state sfsLoop] } {
			$sys openFocLoop
			if {[waitForCmdComplete 1000 1000 {expr ![state sfsLoop]} "Focus Loop to open"]} {
				return 1
			}
		}
		if { !$ttLoop && [state ttgsLoop] } {
			$sys openTTLoop
			if {[waitForCmdComplete 1000 5000 {expr ![state ttgsLoop]} "TT Loop to open"]} {
				return 1
			}
		}
		if { !$lwfsLoop && [state lwfsLoop] } {
			$sys openLGSLoop
			if {[waitForCmdComplete 1000 1000 {expr ![state lwfsLoop]} "LGS Loop to open"]} {
				return 1
			}
		}
		if { ( !$gaos || [AO cget -aoguide] ne "On" ) && [state m2Offload] } {
			$sys disableM2Offload
			if {[waitForCmdComplete 1000 1000 {expr ![state m2Offload]} "M2 Offload to go OFF"]} {
				return 1
			}
		}
		if { ( !$gaos || [AO cget -m1source] ne "GAOS" ) && [state m1Offload] } {
			$sys disableM1Offload
			if {[waitForCmdComplete 1000 1000 {expr ![state m1Offload]} "M1 Offload to go OFF"]} {
				return 1
			}
		}
		set astroMode [state astromode]
		set useAstrometry [expr {$astroMode eq "Regular" || $astroMode eq "Good" || $astroMode eq "Best" } ]
		if { ( !$useAstrometry || !( $ttgs1Active || $ttgs2Active || $ttgs3Active ) ) && [state astrometry]} {
			$sys stopAstrometry
			if {[waitForCmdComplete 1000 1000 {expr ![state astrometry]} "Astrometry to stop"]} {
				return 1
			}
		}
	}
	return 0
}

itcl::body GemsAO::disableLoops {} {
	set errMsg ""
	set ret 0
	
	if { [state rotOffload] } {
		$sys disableRotOffload
		if {[waitForCmdComplete 1000 1000 {expr ![state rotOffload]} "Rotator Offload to go OFF"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state aniLoop] } {
		$sys openAniLoop
		if {[waitForCmdComplete 1000 1000 {expr ![state aniLoop]} "Anisoplanetism Loop to open"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state flexLoop] } {
		$sys openFlexLoop
		if {[waitForCmdComplete 1000 1000 {expr ![state flexLoop]} "Flexure Loop to open"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state sfsLoop] } {
		$sys openFocLoop
		if {[waitForCmdComplete 1000 1000 {expr ![state sfsLoop]} "Focus Loop to open"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state ttgsLoop] } {
		$sys openTTLoop
		if {[waitForCmdComplete 1000 5000 {expr ![state ttgsLoop]} "TT Loop to open"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state lwfsLoop] } {
		$sys openLGSLoop
		if {[waitForCmdComplete 1000 1000 {expr ![state lwfsLoop]} "LGS Loop to open"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state m2Offload] } {
		$sys disableM2Offload
		if {[waitForCmdComplete 1000 1000 {expr ![state m2Offload]} "M2 Offload to go OFF"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state m1Offload] } {
		$sys disableM1Offload
		if {[waitForCmdComplete 1000 1000 {expr ![state m1Offload]} "M1 Offload to go OFF"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	if { [state astrometry]} {
		$sys stopAstrometry
		if {[waitForCmdComplete 1000 1000 {expr ![state astrometry]} "Astrometry to stop"]} {
			set ret 1
			set errMsg "$errMsg\n$lastError"
		}
	}
	return 0
}

itcl::body GemsAO::state {var} {
	switch $var {
	astrometry { return [expr {[$sys getAstrometryState] eq "READY"}] }
	astromode  { return [$sys getAstroMode] }
	m1Offload  { return [expr {[$sys getM1OffloadState] eq "ON"}] }
	m2Offload  { return [expr {[$sys getM2OffloadState] eq "ON"}] }
	lwfsLoop   { return [expr {[$sys getLGSLoopState] eq "CLOSED"}] }
	ttgsLoop   { return [expr {[$sys getTTLoopState] eq "CLOSED"}] }
	sfsLoop    { return [expr {[$sys getFocLoopState] eq "CLOSED"}] }
	aniLoop    { return [expr {[$sys getAniLoopState] eq "CLOSED"}] }
	rotOffload { return [expr {[$sys getRotOffloadState] eq "ON"}] }
	flexLoop   { return [expr {[$sys getFlexLoopState] eq "CLOSED"}] }
	lgswfs     { return [expr {[$sys getLGSWFSActive] eq "ON"}] }
	sfs        { return [expr {[$sys getSFSActive] eq "ON"}] }
	ttgs1      { return [expr {[$sys getTTWFSActive 1] eq "ON"}] }
	ttgs2      { return [expr {[$sys getTTWFSActive 2] eq "ON"}] }
	ttgs3      { return [expr {[$sys getTTWFSActive 3] eq "ON"}] }
	odgw1      { return [expr {[$sys getODGWActive 1] eq "ON"}] }
	odgw2      { return [expr {[$sys getODGWActive 2] eq "ON"}] }
	odgw3      { return [expr {[$sys getODGWActive 3] eq "ON"}] }
	odgw4      { return [expr {[$sys getODGWActive 4] eq "ON"}] }
	gaos       { return [expr {[$sys getGemsActive] eq "ON"}] }
	aoSettled  { return [expr {[$sys getLoopsState] eq "READY"}] }
	}
	return 0
}

itcl::body GemsAO::defineTTSources {} {
	set sources ""
	
	if { $ttgsLoop } {
   	if { $ttgs1Active } {
   		set sources [lappend sources ttgs1 $ttgs1Mag]
   	}
   	if { $ttgs2Active } {
   		set sources [lappend sources ttgs2 $ttgs2Mag]
   	}
   	if { $ttgs3Active } {
   		set sources [lappend sources ttgs3 $ttgs3Mag]
   	}
	}
	if { $odgwLoop } {
   	if { $odgw1Active } {
   		set sources [lappend sources odgw1 $odgw1Mag]
   	}
   	if { $odgw2Active } {
   		set sources [lappend sources odgw2 $odgw2Mag]
   	}
   	if { $odgw3Active } {
   		set sources [lappend sources odgw3 $odgw3Mag]
   	}
   	if { $odgw4Active } {
   		set sources [lappend sources odgw4 $odgw4Mag]
   	}
	}
	if { $oigsLoop } {
		set sources [lappend sources oigs $oigsMag]
	}
	
	return $sources
}