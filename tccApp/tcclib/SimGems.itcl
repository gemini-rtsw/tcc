#Observable interface
itcl::body SimGems::subscribe {observer} {
# Check that the observer isn't already on the list.
	if { [lsearch -exact $observerList $observer] == -1 } {
# Append the observer to the list.
		lappend observerList $observer
	}
}

itcl::body SimGems::unsubscribe {observer} {
# Check that the observer is registered.
	set index [lsearch -exact $observerList $observer]
	if { $index != -1 } {
		set observerList [lreplace $observerList $index $index]
	}
}

itcl::body SimGems::notify {reasons} {
	foreach observer $observerList {
		$observer $reasons
	}
}

itcl::body SimGems::simDelayedChange { var value {reason ""} } {
	set $var $value
	if { $reason eq "" } {
		notify $var 
	} else {
		notify $reason
	}
	endCmd
}

itcl::body SimGems::simLoopStabilize { var delay {reason ""} } {
	endCmd
	incr loopsSettling
	if { $loopSettled eq "TRUE"}
		set loopSettled FALSE
		notify loopSettled
	}
	after $delay [itcl::code $this simLoopClose $var]
}

itcl::body SimGems::simLoopOpen {var {reason ""} } {
	set $var OPEN
	if { $reason eq "" } {
		notify $var 
	} else {
		notify $reason
	}
	endCmd
	incr loopClosed -1
	if { $loopSettled eq "TRUE"  && $loopClosed == 0 } {
		set loopsSettled FALSE
		notify loopsSettled
	}
}

itcl::body SimGems::simLoopClose {var {reason ""} } {
	set $var CLOSED
	if { $reason eq "" } {
		notify $var 
	} else {
		notify $reason
	}
	incr loopClosed
	incr loopSettling -1
	if { $loopSettled eq "FALSE" && loopSettling == 0 } {
		set loopsSettled TRUE
		notify loopsSettled
	}
}

itcl::body SimGems::simLoopOpen::beginCmd {} {
	if { $cmdState eq "BUSY" } {
		set cmdState ERROR
		set errMsg "ERROR: GeMS command in progress."
		set ret 0
	} else {
		set cmdState BUSY
		set errMsg ""
		set ret 1
	}
	notify cmdState
	return $ret
}

itcl::body SimGems::simLoopOpen::endCmd {} {
	if { $cmdState eq "BUSY" } {
		set cmdState IDLE
		notify cmdState
	}
}

itcl::body SimGems::configCmd { name var value {delay 200} {reason ""}} {
	$logger log "SimGems: configure $name to $value"
	if { [beginCmd] } {
		after $delay [itcl::code $this simDelayedChange $var $value $reason]
	}
}

itcl::body SimGems::simCycle {} {
	foreach {stateVar countVar} { ttwfsActive(1) ttwfsCounts(1)  \
											ttwfsActive(2) ttwfsCounts(2)  \
											ttwfsActive(3) ttwfsCounts(3)  \
											odgwActive(1)  odgwCounts(1)   \
											odgwActive(2)  odgwCounts(2)   \
											odgwActive(3)  odgwCounts(3)   \
											odgwActive(4)  odgwCounts(4)   \
											sfsActive      sfsCounts       \
											lgswfsActive   lgswfsCounts(1) \
											lgswfsActive   lgswfsCounts(2) \
											lgswfsActive   lgswfsCounts(3) \
											lgswfsActive   lgswfsCounts(4) \
											lgswfsActive   lgswfsCounts(5) } {
		set oldVal [set $countVar]
		if { $stateVar eq "ON" } {
			set $countVar [expr "100 + round( rand() * 400 )"]
		} else {
			set $countVar 0
		}
		if { $oldVal != [set $countVar] } {
			notify $countVar
		}
	}
	set timerId [after 1000 [itcl::code this simCycle] ]
}