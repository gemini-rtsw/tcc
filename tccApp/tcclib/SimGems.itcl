itcl::class SimGems {
	inherit GemsSys  
	public {
		#Loop control commands
		method openLGSLoop {}
		method closeLGSLoop {}
		method openTTLoop {}
		method closeTTLoop {}
		method openFocLoop {}
		method closeFocLoop {}
		method openFlexLoop {}
		method closeFlexLoop {}
		method openAniLoop {}
		method closeAniLoop {}
		method disableM1Offload {}
		method enableM1Offload {}
		method disableM2Offload {}
		method enableM2Offload {}
		method disableRotOffload {}
		method enableRotOffload {}
		method pauseLoops {why}
		method resumeLoops {}
		method stopLoops {}
		
		#Loop configuration
		method configureTTLoop {sources}
		
		#Astrometry
		method setAstroMode {mode}
		method startAstrometry {}
		method stopAstrometry {}
		
		method moveADC {pos}
		method startADC {}
		method stopADC {}
		method moveBeamSplitter {pos}

		#WFS control commands
		method startODGW {id}
		method stopODGW {id}
		method startTTWFS {id}
		method stopTTWFS {id}
		method startLGSWFS {}
		method stopLGSWFS {}
		method startSFS {}
		method stopSFS {}
		method setODGWExposure {id val}
		method setTTWFSExposure {id }val
		method setLGSWFSExposure {val}
		method setSFSExposure {val}

		#States
		method getLGSLoopState {}
		method getTTLoopState {}
		method getFocLoopState {}
		method getFlexLoopState {}
		method getAniLoopState {}
		method getM1OffloadState {}
		method getM2OffloadState {}
		method getRotOffloadState {}
		method getTTLoopSources {}
		method getODGWActive {id}
		method getTTWFSActive {id}
		method getLGSWFSActive {}
		method getSFSActive {}
		method getODGWExposure {id}
		method getTTWFSExposure {id}
		method getLGSWFSExposure {}
		method getSFSExposure {}
		method getODGWCounts {id}
		method getTTWFSCounts {id}
		method getLGSWFSCounts {id}
		method getSFSCounts {}
		method getAstroMode {}
		method getAstrometryState {}
		method getADCPos {}
		method getADCState {}
		method getBeamSplitterPos {}
		
		#Command state
		method getCommandState {}
		method getLastError {}
#		method getODGWWavelength {}

		#Observable interface
		method subscribe {observer}
		method unsubscribe {observer}
		
		variable logger logger

		constructor {} {}
		destructor {}
	}
	private {
		variable lgsLoopState OPEN 
		variable ttLoopState OPEN
		variable focLoopState OPEN
		variable flexLoopState OPEN
		variable aniLoopState OPEN
		variable m1OffloadState OFF
		variable m2OffloadState OFF
		variable rotOffloadState OFF
		variable ttLoopSources ""
		variable astroMode FAST
		variable astroState OFF
		variable adcPos OUT
		variable adcState OFF
		variable beamSplitterPos OUT
		variable ttwfsExposure
		variable odgwExposure
		variable sfsExposure 100
		variable lgswgsExposure 100
		variable ttwfsActive
		variable odgwActive
		variable sfsActive OFF
		variable lgswfsActive OFF
		variable ttwfsCounts
		variable odgwCounts
		variable sfsCounts 0
		variable lgswfsCounts
		variable loopsSettled FALSE
		
		variable loopsSettling 0
		variable loopsClosed 0 
		
		variable cmdState IDLE
		variable errMsg ""

		variable observerList {}
		
		method notify {reasons}
		
		method simDelayedChange { var value {reason ""} }
		method simLoopStabilize { var delay {reason ""} }
		method simLoopOpen {var {reason ""} }
		method simLoopClose {var {reason ""} }
		method openLoop {name var {reason ""}}
		method closeLoop {name var {delay 2000} {reason ""}}
		method configCmd { name var value {delay 200} {reason ""}}
		method beginCmd {}
		method endCmd {}
		
		#Simulation
		variable timerId {}
		method simCycle {}
	}
}

itcl::body SimGems::constructor {} {
	for { set i 1 } { $i <= 3 } { incr i } {
		set $ttwfsExposure($i) 100
		set $ttwfsActive($i) OFF
		set $ttwfsCounts($i) 0
	}
	for { set i 1 } { $i <= 4 } { incr i } {
		set $odgwExposure($i) 100
		set $odgwActive($i) OFF
		set $odgwCounts($i) 0
	}
	for { set i 1 } { $i <= 5 } { incr i } {
		set $lgswfsCounts($i) 0
	}
	set timerId [after idle [itcl::code this simCycle] ]
}

itcl::body SimGems::destructor {} {
	after cancel $timerId
}

#Loop control commands
itcl::body SimGems::openLoop {name var {reason ""}} {
	$logger log "SimGems: open $name loop command"
	if { [beginCmd] } {
		after 200 [itcl::code $this simLoopOpen $var $reason]
	}
}

itcl::body SimGems::closeLoop {name var {delay 2000} {reason ""}} {
	$logger log "SimGems: close $name loop command"
	if { [beginCmd] } {
		after 200 [itcl::code $this simLoopStabilize lgsLoopState $delay $reason]
	}
}

itcl::body SimGems::openLGSLoop {} {
	openLoop LGS lgsLoopState
}

itcl::body SimGems::closeLGSLoop {} {
	closeLoop LGS lgsLoopState
}

itcl::body SimGems::openTTLoop {} {
	openLoop TT ttLoopState
}

itcl::body SimGems::closeTTLoop {} {
	closeLoop TT ttLoopState
}

itcl::body SimGems::openFocLoop {} {
	openLoop Focus focLoopState
}

itcl::body SimGems::closeFocLoop {} {
	closeLoop Focus focLoopState
}

itcl::body SimGems::openFlexLoop {} {
	openLoop Flexure flexLoopState
}

itcl::body SimGems::closeFlexLoop {} {
	closeLoop Flexure flexLoopState
}

itcl::body SimGems::openAniLoop {} {
	openLoop Anisoplanetism aniLoopState
}

itcl::body SimGems::closeAniLoop {} {
