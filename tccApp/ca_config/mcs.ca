#-

command telstop tcsApply Stop mount
{
   stopAxis tcs:telstop.A Axis
   azBrakes tcs:telstop.B Az brake
   elBrakes tcs:telstop.C El brake
}

command telpark	tcsApply Park mount
{
   dummy tcs:telpark.A
}

command mountDatum tcsApply Datum mount
{
   datumAxis  tcs:mountDatum.A Axis
   azDevice   tcs:mountDatum.B Az device
   elDevice   tcs:mountDatum.C El device
}

command elevation tcsApply Set mount elevation
{
   el tcs:elevation.A Position
}

command azimuth tcsApply Set mount azimuth
{
   az tcs:azimuth.A Position
}

command azel tcsApply Move mount
{
   az tcs:azel.A Azimuth
   el tcs:azel.B Elevation
}

command azConfig tcsApply Configure azimuth encoders
{
   azAlgorithm tcs:azConfig.A Algorithm
}

command elConfig tcsApply Configure elevation encoders
{
   elAlgorithm tcs:elConfig.A Algorithm
}

command mountLog tcsApply Set MCS fast data logging
{
   sampFreq tcs:mountLog.B Sampling Frequency (Hz)
   switch tcs:mountLog.C state
}

command mountTolerance tcsApply Set mount tolerances
{
   azPosError tcs:mountTolerance.A Azimuth position error
   azVelError tcs:mountTolerance.B Azimuth velocity error
   elPosError tcs:mountTolerance.C Elevation position error
   elVelError tcs:mountTolerance.D Elevation velocity error
}
