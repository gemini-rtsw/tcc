#+
# pwfs2.ca
#
# Channel access configuration file for direct access to PWFS2
#
# J. Luhrs May 2008
#
#-


command pwfs2m2Gain tcsApply
{
   tipGain       pwfs2:dc:detSigInitFgGain.A
   tiltGain      pwfs2:dc:detSigInitFgGain.B
   focusGain     pwfs2:dc:detSigInitFgGain.C
   dir           pwfs2:dc:detSigInitFgGain.DIR
   resetDefaults pwfs2:dc:initSigInit.J
}

