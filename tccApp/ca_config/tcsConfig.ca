command difTrMount tcsApply Mount differential track rate
{
   system tcs:difTrMount.A System
   equinox tcs:difTrMount.B Equinox
   t0 tcs:difTrMount.C Epoch (MJD TT)
   dtheta1 tcs:difTrMount.D RA/Az
   dtheta2 tcs:difTrMount.E Dec/El
}

