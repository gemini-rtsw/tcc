command guidersMapping tcsApply Mapping of virtual guiders to physical devices
{
	G1guider tcs:guiderConfig.A Physical guider for G1
	G2guider tcs:guiderConfig.B Physical guider for G2
	G3guider tcs:guiderConfig.C Physical guider for G3
	G4guider tcs:guiderConfig.D Physical guider for G4
}

command poriginA tcsApply Instrument origin A
{
   x tcs:poriginA.A X (mm)
   y tcs:poriginA.B Y (mm)
}

command poriginB tcsApply Instrument origin B
{
   x tcs:poriginB.A X (mm)
   y tcs:poriginB.B Y (mm)
}

command poriginC tcsApply Instrument origin C
{
   x tcs:poriginC.A X (mm)
   y tcs:poriginC.B Y (mm)
}

command poriginM tcsApply Mount instrument origin
{
   x tcs:poriginM.A X (mm)
   y tcs:poriginM.B Y (mm)
}

command rotator tcsApply Rotator configuration
{
   ipa tcs:rotator.A Position angle
   system tcs:rotator.B Reference frame
   equinox tcs:rotator.C Equinox
   iaa tcs:rotator.D Alignment angle
}

command slew tcsApply Slew
{
   chopThrow tcs:slew.A Zero chop throw
   sourceOffset tcs:slew.B Zero source offsets
   sourceDifTr tcs:slew.C Zero source differential track rates
   mountOffset tcs:slew.D Zero mount offsets
   mountDifTr tcs:slew.E Zero mount differential track rates
   filter1 tcs:slew.F Short circuit target filters
   filter2 tcs:slew.G Short circuit mount filters
   pointing tcs:slew.H Reset local pointing model adjustments
   guiding tcs:slew.I Stop guiding
   guideOffset tcs:slew.J Zero guide star offsets
   instrOffset tcs:slew.K Zero instrument offsets
   parkPwfs1 tcs:slew.L Park PWFS1
   parkPwfs2 tcs:slew.M Park PWFS2
   parkOiwfs tcs:slew.N Park OIWFS
   parkGeMS tcs:slew.O Park GeMS
   followPwfs1 tcs:slew.P Follow PWFS1
   followPwfs2 tcs:slew.Q Follow PWFS2
   followOiwfs tcs:slew.S Follow OIWFS
   followGeMS tcs:slew.T Follow GeMS
#   dummy tcs:slew.L Mark CAD
}

command orbit tcsApply Science Target Orbital elements
{
   eltype      tcs:orbit.A Orbital element type
   epoch       tcs:orbit.B Epoch of elements (TT)
   inclination tcs:orbit.C Orbital inclination (deg)
   anode       tcs:orbit.D Longitude of ascending node (deg)
   perihelion  tcs:orbit.E Longitude or argument of perihelion (deg)
   aorq        tcs:orbit.F Mean or perihelion distance (AU)
   e           tcs:orbit.G Eccentricity
   LorM        tcs:orbit.H Mean longitude or anomaly (deg)
   n           tcs:orbit.I Daily motion (deg)
   objName     tcs:orbit.J Object name
}

