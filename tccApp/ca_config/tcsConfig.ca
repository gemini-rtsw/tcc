   anode       tcs:g3orbit.D Longitude of ascending node (deg)
   perihelion  tcs:g3orbit.E Longitude or argument of perihelion (deg)
   aorq        tcs:g3orbit.F Mean or perihelion distance (AU)
   e           tcs:g3orbit.G Eccentricity
   LorM        tcs:g3orbit.H Mean longitude or anomaly (deg)
   n           tcs:g3orbit.I Daily motion (deg)
   objName     tcs:g3orbit.J Object name
}

command g4orbit tcsApply  G4 Orbital elements
{
   eltype      tcs:g4orbit.A Orbital element type
   epoch       tcs:g4orbit.B Epoch of elements (TT)
   inclination tcs:g4orbit.C Orbital inclination (deg)
   anode       tcs:g4orbit.D Longitude of ascending node (deg)
   perihelion  tcs:g4orbit.E Longitude or argument of perihelion (deg)
   aorq        tcs:g4orbit.F Mean or perihelion distance (AU)
   e           tcs:g4orbit.G Eccentricity
   LorM        tcs:g4orbit.H Mean longitude or anomaly (deg)
   n           tcs:g4orbit.I Daily motion (deg)
   objName     tcs:g4orbit.J Object name
}

command planet tcsApply Solar system
{
   object tcs:planet.A object
}

command chopRelative tcsApply Relative chop
{
   throw tcs:chopRelative.A Throw
   angle tcs:chopRelative.B Position angle
   system tcs:chopRelative.C System
   equinox tcs:chopRelative.D Equinox
}

command filter1 tcsApply Target filter
{
   bandwidth    tcs:filter1.A Bandwidth
   maxv         tcs:filter1.B Maximum velocity
   grab         tcs:filter1.C Grab radius
   shortCircuit tcs:filter1.D shortCircuit
}

command filter2 tcsApply Target filter
{
   a 		tcs:filter2.A A weight
   b         	tcs:filter2.B B weight
   shortCircuit tcs:filter2.H shortCircuit
}
