command mount tcsApply Mount target
{
   objName tcs:mount.A Name
   system tcs:mount.B System
   theta1 tcs:mount.C RA/Az
   theta2 tcs:mount.D Dec/El
   epoch tcs:mount.F Epoch
   equinox tcs:mount.E Equinox
   parallax tcs:mount.G Parallax
   dtheta1 tcs:mount.H Proper motion in RA
   dtheta2 tcs:mount.I Proper motion in Dec
   rv tcs:mount.J Radial velocity
   mag tcs:mount.K Brightness
}

command sourceA tcsApply Source A target
{
   objName tcs:sourceA.A Name
   system tcs:sourceA.B System
   theta1 tcs:sourceA.C RA/Az
   theta2 tcs:sourceA.D Dec/El
   epoch tcs:sourceA.F Epoch
   equinox tcs:sourceA.E Equinox
   parallax tcs:sourceA.G Parallax
   dtheta1 tcs:sourceA.H Proper motion in RA
   dtheta2 tcs:sourceA.I Proper motion in Dec
   rv tcs:sourceA.J Radial velocity
   mag tcs:sourceA.K Brightness
}

