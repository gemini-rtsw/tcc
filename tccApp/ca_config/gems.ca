#+
# crs.ca
#
# Channel access configuration file for GeMS subsystem commands.
#
# J Luhrs July 2009
#
#-

apply gems::aomApply aom:apply aom:applyC Primary GeMS Apply Record
apply gems::mystApply myst:apply myst:applyC Primary Myst Apply Record

command gems::adcMech gems::aomApply ADC Control
{
	pos	aom:adcScCtrl.A		ADC unit position In/Out
}

command gems::adcLoop gems::aomApply ADC Control
{
	loop	aom:adcScLpCtrl.A		ADC loop control On/Off
}

command gems::beamSplitter gems::aomApply ADC Control
{
	pos	aom:bsCtrl.A			Dichroic beamsplitter position 1|2
}

command gems::astroMode gems::mystApply ADC Control
{
	mode	myst:astrometric.A 	Astrometric mode Off|Regular|Good|Best
}

command gems::ngsPr1Ctrl	gems::aomApply	Canopus probe 1 control
{
	command aom:ngsPr1Ctrl.A	Command Park|Datum
}

command gems::ngsPr2Ctrl	gems::aomApply	Canopus probe 2 control
{
	command aom:ngsPr2Ctrl.A	Command Park|Datum
}

command gems::ngsPr3Ctrl	gems::aomApply	Canopus probe 3 control
{
	command aom:ngsPr3Ctrl.A	Command Park|Datum
}

status gemssad
{
	applyC		myst:applyC.VAL			0	Command Status
	message		myst:applyC.OMSS			0	Command completion message

	lgsMatrix	myst:lgsMatrixReady.VAL	0	LGS matrix calculation status (Not Ready|Ready)
	lgsLoop		myst:lgsLoopStatus.VAL	0	LGS loop status (OPEN|CLOSED|PAUSED)
	ttLoop		myst:ttLoopStatus.VAL	0	TT loop status (OPEN|CLOSED|PAUSED)
	focLoop		myst:focLoopStatus.VAL	0	Focus loop status (OPEN|CLOSED|PAUSED)
	flexLoop		myst:flexLoopStatus.VAL	0	Flexure loop status (OPEN|CLOSED|PAUSED)
	astromReady	myst:astromModeReady.VAL	0	Astrometry calculation status (Not Ready|Ready)
	aniLoop		myst:aniLoopStatus.VAL	0	ANI loop status (OPEN|CLOSED|PAUSED)
	sciReady		myst:sciReady.VAL			0	Ready for science (Not Ready|Ready)
   laserProp	lis:lasPropProc.VALA		0	Is the Laser Propagating to the Sky
   
   lgsFlux     myst:lgsFlux.VAL 0 Average flux/LGS frame 
   ngsFlux	   myst:ngsFlux.VAL 0 Average flux/NGS frame 

	ngs1Follow	aom:ngsPr1followS.VAL	0	Canopus 1 in follow mode
	ngs2Follow	aom:ngsPr2followS.VAL	0	Canopus 2 in follow mode
	ngs3Follow	aom:ngsPr3followS.VAL	0	Canopus 3 in follow mode
}

status aomsad
{
	applyC		aom:applyC.VAL			0	Command Status
	message		aom:applyC.OMSS		0	Command completion message
	
	adcScState aom:adcScState.VAL    0 Science ADC state (In|Out|Moving|Invalid)
	beamSplitterState aom:bsState.VAL 0 Beam splitter state (In|Out|Moving|Invalid)
	adcScLoop	aom:adcScLoop.VAL    0 Science ADC loop satus (OPEN|CLOSED)
}

command gems::slewReset gems::mystApply Reset ngs config, cmat optimization, astrometric mode, etc
{
	dummy myst:slewReset.DIR	Dummy input
}

command gems::lgsLoopCtrl gems::mystApply HO loop 
{
	cmd myst:lgsLoopCtrl.A		Command (START/PAUSE/RESUME/STOP) 
}

command gems::ttLoopCtrl gems::mystApply TT loop 
{
	cmd myst:ttLoopCtrl.A		Command (START/PAUSE/RESUME/STOP) 
}

command gems::taLoopCtrl  gems::mystApply TA loop 
{
	cmd myst:taLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::astrometricCtrl  gems::mystApply  astrometric aquisition sequence 
{
	cmd myst:astrometricCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::m1OffloadCtrl   gems::mystApply M1 offload
{
	cmd myst:m1OffloadCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::m2OffloadCtrl   gems::mystApply M2 offload
{
	cmd myst:m2OffloadCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::focLoopCtrl   gems::mystApply SFS/zoom loop 
{
	cmd myst:focusLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::flexLoopCtrl    gems::mystApply Setup/TCC - OD/OI Flex loop 
{
	cmd myst:flexLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::crLoopCtrl    gems::mystApply Cassegrain offload
{
	cmd myst:crLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::seqLoopCtrl     gems::mystApply SeqExec dither/filter/sky changes 
{
	cmd myst:seqLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP)
	reason  myst:seqLoopCtrl.B  Reason (Dither/Filter/Sky)
}

command gems::ngsConfig    gems::mystApply Myst configuration
{
	ngs1  myst:ngsConfig.A   NGS1 active (Used/NotUsed) 
	ngs2  myst:ngsConfig.B   NGS2 active (Used/NotUsed)
	ngs3  myst:ngsConfig.C   NGS3 active (Used/NotUsed)
	odgs1 myst:ngsConfig.D   ODGS1 active (Used/NotUsed)
	odgs2 myst:ngsConfig.E   ODGS2 active (Used/NotUsed)
	odgs3 myst:ngsConfig.F   ODGS3 active (Used/NotUsed)
	odgs4 myst:ngsConfig.G   ODGS4 active (Used/NotUsed)
	oigs  myst:ngsConfig.H   OIGS active (Used/NotUsed)
	ngs1Mag  myst:ngsConfig.I  NGS1 Magnitude
	ngs2Mag  myst:ngsConfig.J  NGS2 Magnitude
	ngs3Mag  myst:ngsConfig.K  NGS3 Magnitude
	odgs1Mag myst:ngsConfig.L  ODGS1 Magnitude
	odgs2Mag myst:ngsConfig.M  ODGS2 Magnitude
	odgs3Mag myst:ngsConfig.N  ODGS3 Magnitude
	odgs4Mag myst:ngsConfig.O  ODGS4 Magnitude
	oigsMag  myst:ngsConfig.P  OIGS Magnitude
}


command gems::ttApdCtrl     gems::mystApply Canopus APD control
{
	apd1 myst:ttApdCtrl.A	APD1 control (START/STOP)
	apd2 myst:ttApdCtrl.B	APD2 control (START/STOP)
	apd3 myst:ttApdCtrl.C	APD3 control (START/STOP)
}
