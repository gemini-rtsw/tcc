   pwfs1YDemand        tcs:sad:pwfs1YDemand       0 PWFS1 Y demand
   pwfs2XDemand        tcs:sad:pwfs2XDemand       0 PWFS2 X demand
   pwfs2YDemand        tcs:sad:pwfs2YDemand       0 PWFS2 Y demand
   oiwfsXDemand        tcs:drives:oiwfsXdemand    0 OIWFS X demand
   oiwfsYDemand        tcs:drives:oiwfsYdemand    0 OIWFS Y demand
   elError             tcs:sad:elError            0 Elevation error
   azError             tcs:sad:azError            0 Azimuth error
   rmaError            tcs:sad:rmaError           0 Rotator angle error
   calocal             tcs:sad:calocal            0 Local CA adjustment
   celocal             tcs:sad:celocal            0 Local CE adjustment
   caguide             tcs:sad:caguide            0 Guiding CA adjustment
   ceguide             tcs:sad:ceguide            0 Guiding CE adjustment
   nodState            tcs:sad:nodState           0 Nod state
   chopState           tcs:sad:chopState          0 Chop state
   chopBeam            tcs:om:chopBeam            0 Chop beam
   autoMoveDome        tcs:autoMoveDome           0 Dome under tcs control
   autoMoveShtrs       tcs:autoMoveShtrs          0 Shutters under tcs control
   instrAA             tcs:sad:instrAA            0 Instrument alignment angle
   xoffsetPoA1         tcs:offsetPoA1.VALA        0 X offset
   yoffsetPoA1         tcs:offsetPoA1.VALB        0 Y offset
   currentWindDir      tcs:sad:currentWindDir     0 Wind direction
   currentWindSpeed    tcs:sad:currentWindSpeed   0 Wind speed
   name                tcs:sad:name               0 Telescope name
   ellimit             tcs:ellimit                0 Elevation limit
   azlolimit           tcs:azlolimit              0 Azimuth low limit
   azhilimit           tcs:azhilimit              0 Azimuth high limit
   rotlolimit          tcs:rotlolimit             0 Rotator low limit
   rothilimit          tcs:rothilimit             0 Rotator high limit
   zlimit              tcs:zlimit                 0 Zenith avoidance limit
   m1FigUpdatesFlag    tcs:im:m1FigUpdatesFlag    0 M1 figure updates flag
   aoDemandx           tcs:drives:driveAOS.VALC   0 AO x demand
   aoDemandy           tcs:drives:driveAOS.VALB   0 AO y demand
   minSlitHeight       tcs:def:minSlitHeight      0 Min enclosure slit height
   instrPA             tcs:sad:instrPA            0 Instrument position angle
   aoXoffset           tcs:drives:aoXoffset       0 AO zero point X
   aoYoffset           tcs:drives:aoYoffset       0 AO zero point Y
   m2XPos              tcs:m2XPos                 0 M2 X position
   m2YPos              tcs:m2YPos                 0 M2 Y position
   tcsInPos            tcs:inPosition             0 Internal TCS in position
   outPosReason        tcs:drives:outPosReason    0 Out of position reason
# mbec sep18, 2006
   gacqIAA             tcs:hs:gacqIAA             0 gacq offset IAA
   gacqIPA             tcs:hs:gacqIPA             0 gacq offset IPA
   gacqP               tcs:hs:gacqP               0 gacq offset P
   gacqQ               tcs:hs:gacqQ               0 gacq offset Q
   gacqId              tcs:hs:gacqId              0 gacq offset Id
   
# Virtual guiders
	g1MapName			tcs:guiderConfig.VALA	0	Name of GeMS WFS for G1
	g2MapName			tcs:guiderConfig.VALB	0	Name of GeMS WFS for G2
	g3MapName			tcs:guiderConfig.VALC	0	Name of GeMS WFS for G3
	g4MapName			tcs:guiderConfig.VALD	0	Name of GeMS WFS for G4
}

status guideConfig
{
   p1state    tcs:drives:p1Integrating.VAL  0   P1 integrating
   p2state    tcs:drives:p2Integrating.VAL  0   P2 integrating
   oistate    tcs:drives:oiIntegrating.VAL  0   OI integrating
   aostate    tcs:aoLoopRunning             0   AO integrating
   m2state    tcs:om:m2GuideState.VAL       0   M2 guiding
   absorbtilt tcs:absorbTipTiltFlag.VAL     0   Absorb tilt errors
   m1state    tcs:im:m1GuideOn.VAL          0   M1 guiding
   m1source   tcs:m1GuideConfig.VALB        0   M1 guide source
   p1guide    tcs:ak:wfsguide:p1weight.VAL  0   WFS guiding
   p2guide    tcs:ak:wfsguide:p2weight.VAL  0   WFS guiding
   oiguide    tcs:ak:wfsguide:oiweight.VAL  0   WFS guiding
   p1mweight  tcs:mountGuideMode.VALC       0   Mount p1 wieght
   p2mweight  tcs:mountGuideMode.VALD       0   Mount p1 wieght
   m2p1guide  tcs:drives:p1GuideConfig      0   M2 P1 guide config
   m2p2guide  tcs:drives:p2GuideConfig      0   M2 P2 guide config
   m2oiguide  tcs:drives:oiGuideConfig      0   M2 OI guide config
   m2aoguide  tcs:drives:aoGuideConfig      0   M2 AO guide config
   coma       tcs:im:m2gm:comaCorrectFlag.VAL 0 Coma correction
   m1GuideSource       tcs:m1GuideConfig.VALB     0 M1 guide source
# mbec - sep09 2006 
# changed to be taken from altair directly
   useLwfs    ao:useLwfs.VALA	    0   GAOS using Laser WFS? (ON/OFF)
   oiblend    ao:oiwfsSource.VALA           0   Altair OI Blending on?
#   aoTTGS     ao:wfcs:strapGtCtl.VALA       0   GAOS Tip Tilt WFS ON/OFF (1/0)
   aoTTGS     ao:strapDevStatus.VALH        0   GAOS Tip Tilt WFS ON/OFF (0-100, 0== off)
   aoSFO      sfo:observing                 0   SFO integrating ON/OFF (1/0)
   aoBTO      bto:fsaLoop    		    0   BTO FSA loop state OPEN/CLOSED
   ttgsloop   ao:wfcs:strapCorrCtl.VALA     0   GAOS TTGS Correcting ON/OFF (1/0)
   sfoloop    ao:cc:lgszoomSfoLoop          0   SFO correcting loop ON/OFF (1/0)
   niciAOloop  nici:sad:AOLoopState         0   Correction Loop OPEN or CLOSED
   niciAPD    nici:ao:AO:APDC.VAL           0   NICI APD activity (IDLE or BUSY)
} 

