status ecssad
{
   domePos             ec:sad:domePos         0 Current dome azimuth
   topShtrPos          ec:sad:topShtrPos      0 Current top shutter el
   botShtrPos          ec:sad:botShtrPos      0 Current bottom shutter el
   eastVentGatePos     ec:sad:eastVentGatePos 0 East vent gate position
   westVentGatePos     ec:sad:westVentGatePos 0 West vent gate position
   domeInPos           ec:domeInPos           0 Dome in position
   topShtrInPos        ec:topShtrInPos        0 Top shutter in position
   botShtrInPos        ec:botShtrInPos       0 Bottom shutter in position
   domeFault           ec:domeState           0 Dome Fault
   evgFault            ec:eastVentGateState   0 East vent Gate Fault
   wvgFault            ec:westVentGateState   0 West vent Gate Fault
   tshFault            ec:topShtrState        0 Top Shutter Fault
   bshFault            ec:botShtrState        0 Bottom Shutter Fault
   ahu2		       ec:prahuproc.VALA      0 AHU 2 Status
   ahu3		       ec:prahuproc.VALB      0 AHU 3 Status
   ahu4		       ec:prahuproc.VALC      0 AHU 4 Status
   ahu5		       ec:prahuproc.VALD      0 AHU 5 Status
}

status shutterDriveCurrents
{
    t1x		ec:sh:t1x	0	Top 1X
    t1y		ec:sh:t1y	0	Top 1Y
    t1z		ec:sh:t1z	0	Top 1Z
    t1w		ec:sh:t1w	0	Top 1W

    b2x		ec:sh:b2x	0	Bottom 2X
    b2y		ec:sh:b2y	0	Bottom 2Y
    b2z		ec:sh:b2z	0	Bottom 2Z
    b2w		ec:sh:b2w	0	Bottom 2W
}
