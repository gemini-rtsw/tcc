#+
# pwfs1.ca
#
# Channel access configuration file for direct access to PWFS1
#
# J. Luhrs May 2008
#
#-


command pwfs1m2Gain tcsApply
{
   tipGain       pwfs1:dc:detSigInitFgGain.A
   tiltGain      pwfs1:dc:detSigInitFgGain.B
   focusGain     pwfs1:dc:detSigInitFgGain.C
   dir           pwfs1:dc:detSigInitFgGain.DIR
   resetDefaults pwfs1:dc:initSigInit.J
}

