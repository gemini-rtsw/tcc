command oiwfsSig tcsApply
{
   detSigModeSeqDark oiwfs:dc:detSigModeSeqDark.DIR
   seqDarkFilename   oiwfs:dc:detSigModeSeqDark.C
   detSigModeSeq     oiwfs:dc:detSigModeSeq.DIR
   z2m2              oiwfs:dc:detSigModeSeq.P
   detSigInit        oiwfs:dc:detSigInit.DIR
   darkFilename      oiwfs:dc:detSigInit.B
}

# command to configure OIWFS Guide Output for AO/OI Blending

command oiwfsOut tcsApply
{
   detSigOutput      oiwfs:dc:detSigOutput.A    0:SCS, 1:AO
   detSigOutputDir   oiwfs:dc:detSigOutput.DIR
}
