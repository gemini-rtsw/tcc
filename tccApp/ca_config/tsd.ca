    crcsov   tcs:crInPosOverride     0 CRCS override flag
    aoov     tcs:aoInPosOverride     0 AO override flag
    agov     tcs:agInPosOverride     0 AG override flag
    p1       tcs:configPwfs1.A       0 P1 chopnod source
    p2       tcs:configPwfs2.A       0 P2 chopnod source
    oi       tcs:configOiwfs.A       0 OI chopnod source
    ao       tcs:configureForAO.VALA 0 AO chopnod source
    on       tcs:om:m2GuideState.VAL 0 TTF correction on
}
