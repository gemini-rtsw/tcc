# Define the TCS apply record.

apply tcsApply tcs:apply tcs:applyC Primary TCS Apply Record

# TCS apply applyC and error message records

status apply TCS apply
{
  val tcs:apply.VAL 0 VAL field
  mess tcs:apply.MESS 0 Message
}

status applyC TCS status
{
  val tcs:applyC.VAL 0 Value
  clid tcs:applyC.CLID 0 Client ID
   applyC		tc1:applyC.VAL			0	Command Status
	message		tc12:applyC.OMSS		0	Command completion message
}

status errMessage TCS error message
{
  val tcs:errMessage 0 Message text
}
