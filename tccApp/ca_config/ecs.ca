#+
# ecs.ca
#
# Channel access configuration file for the ecs subsystem commands.
#
# D Terrett 6 June 2000
#
# Copyright CCLRC
#-

command encThermal tcsApply Set enclosure thermal control
{
   mode tcs:encThermal.A Mode
}

command carousel tcsApply Set enclosure mode
{
   domemode tcs:carouselMode.A Dome mode
   shuttermode tcs:carouselMode.B Shutter mode
   slit tcs:carouselMode.C Slit height
   dome tcs:carouselMode.D Dome enable
   shutter tcs:carouselMode.E Shutter enable
}

command enclosureStop tcsApply Stop enclosure
{
   dummy tcs:enclosureStop.A
}

command enclosurePark	tcsApply Park enclosure
{
   dummy tcs:enclosurePark.A
}

command enclosureDatum tcsApply Datum enclosure
{
   dummy tcs:enclosureDatum.A
}

command carouselStop tcsApply Stop carousel
{
   dummy tcs:carouselStop.A
}

command carouselPark	tcsApply Park carousel
{
   parkpos tcs:carouselPark.A Park position
   azimuth tcs:carouselPark.B Azimuth
}

command carouselMove tcsApply Move carousel
{
   azimuth tcs:carousel.A Azimuth
}

command shutterStop tcsApply Stop shutters
{
   dummy tcs:shutterStop.A
}

command shutterPark	tcsApply Park shutters
{
   dummy tcs:shutterPark.A
}

command shutterDatum tcsApply Datum shutters
{
   dummy tcs:shutterDatum.A
}

command shutters tcsApply Move shutters
{
   top tcs:shutter.A Top position
   bottom tcs:shutter.B Bottom position
}

command ventgatesStop tcsApply Stop vent gates
{
   dummy tcs:ventGatesStop.A
}

command ventgatesPark	tcsApply Park vent gates
{
   dummy tcs:ventGatesPark.A
}

command ventgates tcsApply Move vent gates
{
   east tcs:ventgates.A East gate opening
   west tcs:ventgates.B West gate opening
}

command enclosureInit tcsApply Init enclosure
{
   dummy tcs:enclosureInit.A
}

command autoClose tcsApply AutoClose triggers
{
   sh  ec:closeSH.PROC
   evg ec:closeEVG.PROC
   wvg ec:closeWVG.PROC
}
