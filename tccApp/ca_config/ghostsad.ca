status ghostsad
{
   offset_IFU1         ghost:sad:cc:cu:ifu1.focus_offset  0 IFU 1 Focus Offset
   offset_IFU2         ghost:sad:cc:cu:ifu2.focus_offset  0 IFU 2 Focus Offset
   offset_IFU          ghost:sad:cc:cu.focus_offset       0 IFU Focus Offset (Average)

   IFU1_moving         ghost:sad:cc:cu:ifu1.moving        0 IFU 1 moving
   IFU2_moving         ghost:sad:cc:cu:ifu2.moving        0 IFU 1 moving

#   IFU_in Use          ghost:sad:cc:cu:ifu_in_use         0 IFU in Use 

}
