status agssad
{
   inPosition          tcs:ag:inPosition          0 In position
   sfTilt              ag:sfTilt                  0 Science fold tilt
   sfRot               ag:sfRot                   0 Science fold rotation
   sfLin               ag:sfLin                   0 Science linear position
   sfName              tc1:ag:sfName          0 Science fold position name
   aoName              tcs:ag:aoName              0 AO fold position
   hwName              tcs:ag:hwName              0 HRWFS fold position
   p1Parked            tcs:ag:p1:probeParked      0 P1 probe parked
   p1FollowS           tcs:ag:p1:followS          0 P1 follow mode
   p1InPosition        tcs:ag:p1:inPosition       0 P1 in position
   p1TableAngle        tcs:ag:p1:RT34Pos      0 P2 Rotary table angle
   p1ArmAngle          tcs:ag:p1:PA34Pos      0 P2 Probe arm angle
   p1X                 tcs:ag:p1:x                0 P1 x position
   p1Y                 tcs:ag:p1:y                0 P1 y position
   p1TableOffset       ag:p1:probeCalParm.B   0 P1 table angle offset
   p1RadiusRT          ag:p1:probeCalParm.G   0 P1 Rotary table radius
   p1ArmOffset         ag:p1:probeCalParm.D   0 P1 probe arm offset
   p1XTranslation      ag:p1:probeCalParm.H   0 P1 X translation
   p1YTranslation      ag:p1:probeCalParm.I   0 P1 Y translation
   p1RadiusPA          ag:p1:probeCalParm.U   0 P1 Probe arm length
   p2Parked            tcs:ag:p2:probeParked      0 P2 probe parked
   p2FollowS           tcs:ag:p2:followS      0 P2 follow mode
   p2InPosition        tcs:ag:p2:inPosition   0 P2 in position
   p2TableAngle        tcs:ag:p2:RT34Pos      0 P2 Rotary table angle
   p2ArmAngle          tcs:ag:p2:PA34Pos      0 P2 Probe arm angle
   p2X                 tcs:ag:p2:x            0 P2 x position
   p2Y                 tcs:ag:p2:y            0 P2 y position
   p2TableOffset       ag:p2:probeCalParm.B   0 P2 table angle offset
   p2RadiusRT          ag:p2:probeCalParm.G   0 P2 Rotary table radius
   p2ArmOffset         ag:p2:probeCalParm.D   0 P2 probe arm offset
   p2XTranslation      ag:p2:probeCalParm.H   0 P2 X translation
   p2YTranslation      ag:p2:probeCalParm.I   0 P2 Y translation
   p2RadiusPA          ag:p2:probeCalParm.U   0 P2 Probe arm length
   oiInPosition        tcs:ag:oi:inPosition   0 OIWFS in position
   oiX                 tcs:ag:oi:x            0 OIWFS x position
   oiY                 tcs:ag:oi:y            0 OIWFS y position
   oiFollowS           tcs:ag:oi:followS          0 OIWFS follow mode
   p1guiding           tcs:pwfs1:dc:fgDiag1.VALB  0 P1 generating guide signal
   p2guiding           tcs:pwfs2:dc:fgDiag.VALL   0 P2 generating guide signal
   activeC             tcs:ag:activeC.VAL         0 A&G ActiveC
   port1Label          tcs:ag:port:port1          0 ISS port 1 label
   port2Label          tcs:ag:port:port2          0 ISS port 2 label
   port3Label          tcs:ag:port:port3          0 ISS port 3 label
   port4Label          tcs:ag:port:port4          0 ISS port 4 label
   port5Label          tcs:ag:port:port5          0 ISS port 5 label
   portGsaoi			ag:port:gsaoi		0	ISS port for GSAOI
   oiwfsName           tcs:ag:oiwfsSel.A          0 OIWFS name
   oiwfsCoeffs         tcs:ag:oi:oiwfsCoeffs.VALJ 0 OIWFS transformation
   p1seeing            pwfs1:dc:seeing        0 P1 seeing estimate
   p2seeing            pwfs2:dc:seeing        0 P2 seeing estimate
   oiseeing            oiwfs:dc:seeing        0 OI seeing estimate
}
