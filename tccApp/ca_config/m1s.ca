command m1Park tcsApply Park M1
{
   park tcs:m1Park.A Action
}

command m1FigUpdates tcsApply M1 open loop model
{
   state tcs:m1FigUpdates.A state
   dir  tcs:m1FigUpdates.DIR Directive
}

command m1ZeroSet tcsApply Zero M1 model
{
   mechanism tcs:m1ZeroSet.A Mechanism
}

command m1ModelRestore tcsApply Restore M1 model
{
   model tcs:m1ModelRestore.A Model to restore
}

command pcsaos tcsApply Turn on/off pcs aos
{
   setaos m1:aosOn switch
}

command m1ModelSave tcsApply Defines where to save M1 model
{
   model tcs:m1ModelSave.A Model to save
}
