# This file is for Mauna Kea
set site MK

# The name of the OCS session xml/rpc server.
set ocs_proxy http://gnodb.hi.gemini.edu:11000/wdba/exec

# Where the tcs is stored.
set tcs_root_dir /gemini/epics3.13.4/tcs/tcs

# The directory in which WFS images used for M1 tuning are are stored.
set m1_tune_dir /gemini/epics3.13.4/tcs/tcs

# The default directory for storing HRWFS images.
set default_wfs_dir /net/enif/export/home/wfs

# The directory in which HRWFS sky background images are stored.
set hrwfs_sky_dir /home/SSA/sky

# The name of the script that starts the HRWFS AO program.
set hrwfs_ao_prog /home/gemvx/bin/StartHrwfsAO

# the directory where the skycalc executable can be found
set skycalc_dir /gemsoft/bin

# The x/y/z position that corresponds to the A&G PWFS1 probeSel center
# command.

set pwfs1_center_x   2.324
set pwfs1_center_y -12.213
set pwfs1_center_z   0.0

# The x/y/z position that corresponds to the A&G PWFS2 probeSel center
# command.

set pwfs2_center_x -3.493
set pwfs2_center_y -2.480
set pwfs2_center_z  0.0

# The center position for the Acquisition camera window
set acqcam_x 518
set acqcam_y 519

# The wavelength cutoffs for automatic baffle configuration
set baffle_visible 1.05
set baffle_nearir 3.0

# AO: the SFO defocus offset 
set niri_sfo_defocus 10.0
set nifs_sfo_defocus 10.0

# The Current Limits for the Top and Bottom Shutter Alarms
set top_shutter_current_limit 30.0
set bottom_shutter_current_limit 32.0
