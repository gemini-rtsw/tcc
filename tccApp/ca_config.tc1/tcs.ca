# Define the TCS apply record.

apply tcsApply tc1:apply tc1:applyC Primary TCS Apply Record

# TCS apply applyC and error message records

status apply TCS apply
{
  val tc1:apply.VAL 0 VAL field
  mess tc1:apply.MESS 0 Message
}

status applyC TCS status
{
  val tc1:applyC.VAL 0 Value
  clid tc1:applyC.CLID 0 Client ID
}

status errMessage TCS error message
{
  val tc1:errMessage 0 Message text
}
