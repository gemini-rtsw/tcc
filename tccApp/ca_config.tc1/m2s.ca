command dtelFocus tcsApply Set focus
{
   focusOffset tc1:dtelFocus.A Offset (mm)
}

command m2Baffle tcsApply Position M2 baffles
{
   deployBaffle tc1:m2Baffle.A Deployable
   centralBaffle tc1:m2Baffle.B Central
}

command m2Park tcsApply Park M2
{
   dummy tc1:m2Park.A
}

command m2Init tcsApply Init M2
{
   dummy tc1:m2Init.A
}
