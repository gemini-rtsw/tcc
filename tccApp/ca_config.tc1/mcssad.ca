status mcssad
{
   inPosition          mc:inPosition          0 Mount in position
   inPositionAz        mc:inPositionAz        0 Azimuth in position
   inPositionEl        mc:inPositionEl        0 Elevation in position
   followS             mc:followS             0 Follow state
   azState             mc:azStateS	      0 Azimuth Axis State
   elState             mc:elStateS	      0 Elevation Axis State
   azPark              mc:azPark              0 Azimuth Park Position
   elPark              mc:elPark              0 Elevation Park Position
   azPos               mc:azCurrentPos        0 Current Azimuth Pos
   elPos               mc:elCurrentPos        0 Current Elevation Pos
   azCondition         mc:azDriveCondition    0 Azimuth Condition (Asserted or Disasserted)
   elCondition         mc:elDriveCondition    0 Elevation Condition (Asserted or Disasserted)
}
