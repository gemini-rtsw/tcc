#+
# crs.ca
#
# Channel access configuration file for GeMS subsystem commands.
#
# J Luhrs July 2009
#
#-

apply gems::aomApply    ao2:apply       ao2:activeC     Primary Canopus Apply Record
apply gems::aomAuxApply ao2:apply3      ao2:comCar3     Canopus aux. mechanisms Apply Record
apply gems::aomAdcApply ao2:apply61     ao2:comCar61    Canopus ADC Apply Record
apply gems::mystApply   mys2:apply      mys2:applyC     Primary Myst Apply Record
apply gems::rtcApply    rt2:apply       rt2:applyC      Primary RTC Apply Record
apply gems::sfsApply    sf2:apply       sf2:applyC      Primary SFS Apply Record
apply gems::odgwApply   gsaoi:dc:apply  gsaoi:dc:applyC GSAOI DC Apply Record
apply gems::lisApply    lis:apply       lis:applyC      LIS Apply Record

command gems::adcMech gems::aomAdcApply ADC Position Control
{
	pos	ao2:adcScCtrl.A		ADC unit position In/Out
}

command gems::adcLoop gems::aomAdcApply ADC Loop Control
{
	loop	ao2:adcScLpCtrl.A		ADC loop control On/Off
}

command gems::beamSplitter gems::aomAuxApply ADC Control
{
	pos	ao2:bsCtrl.A			Dichroic beamsplitter position 1|2
}

command gems::ngsPr1Ctrl	gems::aomApply	Canopus probe 1 control
{
	command ao2:ngsPr1Ctrl.A	Command Park|Datum
}

command gems::ngsPr2Ctrl	gems::aomApply	Canopus probe 2 control
{
	command ao2:ngsPr2Ctrl.A	Command Park|Datum
}

command gems::ngsPr3Ctrl	gems::aomApply	Canopus probe 3 control
{
	command ao2:ngsPr3Ctrl.A	Command Park|Datum
}

status gemssad
{
	applyC		mys2:applyC.VAL			0	Command Status
	message		mys2:applyC.OMSS			0	Command completion message

	lgsMatrix	mys2:lgsMatrixReady.VAL	0	LGS matrix calculation status (Not Ready|Ready)
	lgsLoop		mys2:lgsLoopStatus.VAL	0	LGS loop status (OPEN|CLOSED|PAUSED)
	ttLoop		mys2:ttLoopStatus.VAL	0	TT loop status (OPEN|CLOSED|PAUSED)
	focLoop		mys2:focLoopStatus.VAL	0	Focus loop status (OPEN|CLOSED|PAUSED)
	flexLoop		mys2:flexLoopStatus.VAL	0	Flexure loop status (OPEN|CLOSED|PAUSED)
	astromReady	mys2:astromModeReady.VAL	0	Astrometry calculation status (Not Ready|Ready)
	aniLoop		mys2:aniLoopStatus.VAL	0	ANI loop status (OPEN|CLOSED|PAUSED)
	sciReady		mys2:sciReady.VAL			0	Ready for science (Not Ready|Ready)
   laserProp	lis:lasPropProc.VALA		0	Is the Laser Propagating to the Sky
   rtcHealth	rtc:health.VALA			0	RTC health
   
   m1Offload    mys2:m1OffloadStatus.VAL    0   GeMS is offloading to M1 (OPEN|CLOSED|PAUSED)
   m2Offload    mys2:m2OffloadStatus.VAL    0   GeMS is offloading to M2 (OPEN|CLOSED|PAUSED)
   crOffload    mys2:crOffloadStatus.VAL    0   GeMS is offloading to Cass-rotator (OPEN|CLOSED|PAUSED)

   lgsLoopState     mys2:lgsLoopCtrl:state.VAL   0  LGS loop state
   lgsLoopStateMess mys2:lgsLoopCtrl:message.VAL 0  LGS loop state message
   ttLoopState      mys2:ttLoopCtrl:state.VAL    0  Tip/Tilt loop state
   ttLoopStateMess  mys2:ttLoopCtrl:message.VAL  0  Tip/Tilt loop state message
   taLoopState      mys2:taLoopCtrl:state.VAL    0  ANI loop state
   taLoopStateMess  mys2:taLoopCtrl:message.VAL  0  ANI loop state message
   focusLoopState   mys2:focusLoopCtrl:state.VAL 0  Focus loop state
   focusLoopStateMess mys2:focusLoopCtrl:message.VAL 0  Focus loop state message
   flexLoopState    mys2:flexLoopCtrl:state.VAL  0  Flexure loop state
   flexLoopStateMess mys2:flexLoopCtrl:message.VAL 0  Flexure loop state message
   crLoopState      mys2:crLoopCtrl:state.VAL    0  Cass-rotator loop state
   crLoopStateMess  mys2:crLoopCtrl:message.VAL  0  Cass-rotator loop state message
   
   astroMode   mys2:slewReset.VALA 0		Mode (None/Regular/Good/Best)
   
   lgsFlux     mys2:lgsFlux.VAL                  0 LGS Flux 
   lgsAvrg     mys2:lgsavgfluxperpix.VAL         0 Average flux/LGS frame 
   ngsFlux     mys2:ngsFlux.VAL                  0 Average flux/NGS frame 
   sfsFlux     mys2:sfsflux.VAL                  0 SFS flux
   
   ngs1     mys2:ngsConfig.VALA 0  NGS1 active (Used/NotUsed) 
	ngs2     mys2:ngsConfig.VALB 0  NGS2 active (Used/NotUsed)
	ngs3     mys2:ngsConfig.VALC 0  NGS3 active (Used/NotUsed)
	oigs     mys2:ngsConfig.VALD 0  OIGS active (Used/NotUsed)
	odgs1    mys2:ngsConfig.VALE 0  ODGS1 active (Used/NotUsed)
	odgs2    mys2:ngsConfig.VALF 0  ODGS2 active (Used/NotUsed)
	odgs3    mys2:ngsConfig.VALG 0  ODGS3 active (Used/NotUsed)
	odgs4    mys2:ngsConfig.VALH 0  ODGS4 active (Used/NotUsed)
	ngs1Mag  mys2:ngsConfig.VALI 0  NGS1 Magnitude
	ngs2Mag  mys2:ngsConfig.VALJ 0  NGS2 Magnitude
	ngs3Mag  mys2:ngsConfig.VALK 0  NGS3 Magnitude
	oigsMag  mys2:ngsConfig.VALL 0  OIGS Magnitude
	odgs1Mag mys2:ngsConfig.VALM 0  ODGS1 Magnitude
	odgs2Mag mys2:ngsConfig.VALN 0  ODGS2 Magnitude
	odgs3Mag mys2:ngsConfig.VALO 0  ODGS3 Magnitude
	odgs4Mag mys2:ngsConfig.VALP 0  ODGS4 Magnitude
}

status odgwsad
{	
	applyC		gsaoi:dc:seqODGWC.VAL		0	Command Status
	message		gsaoi:dc:seqODGWC.OMSS		0	Command completion message

	baseExpTime gsaoi:sad:dc:gdr_exposedRQ.VAL		0 ODGW base exposure time
	expMult1		gsaoi:sad:dc:gdr_expMult1.VAL 0 Exposure multiplier for ODGW1
	expMult2		gsaoi:sad:dc:gdr_expMult2.VAL 0 Exposure multiplier for ODGW2
	expMult3		gsaoi:sad:dc:gdr_expMult3.VAL 0 Exposure multiplier for ODGW3
	expMult4		gsaoi:sad:dc:gdr_expMult4.VAL 0 Exposure multiplier for ODGW4
	
	counts1		gsaoi:sad:dc:d_gdr_flux1.VAL 0 Counts for ODGW1
	counts2		gsaoi:sad:dc:d_gdr_flux2.VAL 0 Counts for ODGW2
	counts3		gsaoi:sad:dc:d_gdr_flux3.VAL 0 Counts for ODGW3
	counts4		gsaoi:sad:dc:d_gdr_flux4.VAL 0 Counts for ODGW4
	
	odgwSize	gsaoi:sad:dc:d_gdr_winSizeS.VAL 0 ODGW size
	numIdleRows	gsaoi:sad:dc:gdr_idleRows.VAL	0 Number of idle rows for interleaved guiding
	numSciRows	gsaoi:sad:dc:gdr_sciRows.VAL	0 Number of science rows for interleaved guiding
	notGuiding  gsaoi:sad:dc:guiding.VAL		0 ODGW (not) guiding 	
    odgwDisplayRate gsaoi:sad:dc:d_gdr_dispRate 0 ODGW display rate
}

status aomsad
{
	applyC		ao2:activeC.VAL			0	Command Status
	message		ao2:activeC.OMSS		0	Command completion message
	
	adcScState 	ao2:adcScState.VAL    0 Science ADC state (In|Out|Moving|Invalid)
	beamSplitterState ao2:bsState.VAL 0 Beam splitter state (In|Out|Moving|Invalid)
	adcScLoop	ao2:adcScLoop.VAL    0 Science ADC loop satus (OPEN|CLOSED)

	ngs1Follow	ao2:ngsPr1followS.VAL	0	Canopus 1 in follow mode
	ngs2Follow	ao2:ngsPr2followS.VAL	0	Canopus 2 in follow mode
	ngs3Follow	ao2:ngsPr3followS.VAL	0	Canopus 3 in follow mode
	
	inShutterState	ao2:inShState.VAL	0	Input shutter state
	outShutterState	ao2:outShState.VAL	0	Output shutter state
}

status aomauxsad
{
    applyC      ao2:comCar3.VAL         0   Command Status
    message     ao2:comCar3.OMSS        0   Command completion message
}

status rtcsad
{
	applyC		rt2:applyC.VAL			0	Command Status
	message		rt2:applyC.OMSS		0	Command completion message

	tt1Active rt2:ngs:apd1 0 Canopus 1 APD active (ENABLED/DISABLED)
	tt2Active rt2:ngs:apd2 0 Canopus 2 APD active (ENABLED/DISABLED)
	tt3Active rt2:ngs:apd3 0 Canopus 3 APD active (ENABLED/DISABLED)
	
	lgsExp	rt2:lgs:expTime.VALA		0	LGSWFS exposure time
	ngsExpMult rt2:ngs:expTime.VALA 	0	NGS exposure time multiplier
	sourceMask rt2:ngs:geometryState.VALA 0 Current NGS mask
}

status sfssad
{
	applyC		sf2:applyC.VAL			0	Command Status
	message		sf2:applyC.OMSS		0	Command completion message

	sfsActive	sf2:observing.VAL		0	SFS active (0/1)
	sfsCounts	sf2:dspGlobalIntensity	0	SFS counts
	sfsExp		sf2:expTime.VAL 		0	SFS exposure time
}

status lissad
{
    applyC      lis:applyC.VAL  0   Command Status
    message     lis:applyC.OMSS 0   Command completion message
}

command gems::slewReset gems::mystApply Reset ngs config, cmat optimization, astrometric mode, etc
{
	astroMode mys2:slewReset.A	Astrometric Mode (None/Regular/Good/Best)
}

command gems::lgsLoopCtrl gems::mystApply HO loop 
{
	cmd mys2:lgsLoopCtrl.A		Command (START/PAUSE/RESUME/STOP) 
}

command gems::ttLoopCtrl gems::mystApply TT loop 
{
	cmd mys2:ttLoopCtrl.A		Command (START/PAUSE/RESUME/STOP) 
}

command gems::taLoopCtrl  gems::mystApply TA loop 
{
	cmd mys2:taLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::astrometricCtrl  gems::mystApply  astrometric aquisition sequence 
{
	cmd mys2:astrometricCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
	mode mys2:astrometricCtrl.B 		Mode (None/Regular/Good/Best)
}

command gems::m1OffloadCtrl   gems::mystApply M1 offload
{
	cmd mys2:m1OffloadCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::m2OffloadCtrl   gems::mystApply M2 offload
{
	cmd mys2:m2OffloadCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::focLoopCtrl   gems::mystApply SFS/zoom loop 
{
	cmd mys2:focusLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::flexLoopCtrl    gems::mystApply Setup/TCC - OD/OI Flex loop 
{
	cmd mys2:flexLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::crLoopCtrl    gems::mystApply Cassegrain offload
{
	cmd mys2:crLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP) 
}

command gems::seqLoopCtrl     gems::mystApply SeqExec dither/filter/sky changes 
{
	cmd mys2:seqLoopCtrl.A 		Command (START/PAUSE/RESUME/STOP)
	reason  mys2:seqLoopCtrl.B  Reason (Dither/Filter/Sky)
}

command gems::ngsConfig    gems::mystApply Myst configuration
{
	ngs1  mys2:ngsConfig.A   NGS1 active (Used/NotUsed) 
	ngs2  mys2:ngsConfig.B   NGS2 active (Used/NotUsed)
	ngs3  mys2:ngsConfig.C   NGS3 active (Used/NotUsed)
	oigs  mys2:ngsConfig.D   OIGS active (Used/NotUsed)
	odgs1 mys2:ngsConfig.E   ODGS1 active (Used/NotUsed)
	odgs2 mys2:ngsConfig.F   ODGS2 active (Used/NotUsed)
	odgs3 mys2:ngsConfig.G   ODGS3 active (Used/NotUsed)
	odgs4 mys2:ngsConfig.H   ODGS4 active (Used/NotUsed)
	ngs1Mag  mys2:ngsConfig.I  NGS1 Magnitude
	ngs2Mag  mys2:ngsConfig.J  NGS2 Magnitude
	ngs3Mag  mys2:ngsConfig.K  NGS3 Magnitude
	oigsMag  mys2:ngsConfig.L  OIGS Magnitude
	odgs1Mag mys2:ngsConfig.M  ODGS1 Magnitude
	odgs2Mag mys2:ngsConfig.N  ODGS2 Magnitude
	odgs3Mag mys2:ngsConfig.O  ODGS3 Magnitude
	odgs4Mag mys2:ngsConfig.P  ODGS4 Magnitude
}


command gems::ttApdCtrl     gems::mystApply Canopus APD control
{
	apd1 mys2:ttApdCtrl.A	APD1 control (START/STOP)
	apd2 mys2:ttApdCtrl.B	APD2 control (START/STOP)
	apd3 mys2:ttApdCtrl.C	APD3 control (START/STOP)
}


command gems::ttExpCtrl	gems::rtcApply Canopus exposure control
{
	freqDiv	rt2:ngs:setExpTime.A Canopus WFS read frequency divisor (f = (LWFS Freq) / divisor)
}

command gems::sfsExpCtrl gems::sfsApply SFS exposure control
{
	expTime sf2:setExpTime.A SFS exposure time (s)
}

command gems::lgsExpCtrl	gems::rtcApply LGSWFS exposure control
{
	expTime	rt2:lgs:setExpTime.A LGSWFS exposure time (s)
}

command gems::sfsObserve gems::sfsApply SFS WFS start
{
	dir sf2:observe.DIR SFS start observe
}

command gems::sfsStopObserve gems::sfsApply SFS WFS start
{
	dir sf2:endObserve.DIR SFS start observe
}

command gems::odgwSetup tcsApply ODGW exposure setup
{
	baseExpTime tc1:gsaoiodgwSetup.D	ODGW base exposure time
	numSciRows	tc1:gsaoiodgwSetup.E	Number of science rows for interleaved guiding
	numIdleRows	tc1:gsaoiodgwSetup.F	Number of idle rows for interleaved guiding
	expMult1	tc1:gsaoiodgwSetup.G	Exposure multiplier for ODGW1
	expMult2	tc1:gsaoiodgwSetup.H	Exposure multiplier for ODGW2
	expMult3	tc1:gsaoiodgwSetup.I	Exposure multiplier for ODGW3
	expMult4	tc1:gsaoiodgwSetup.J	Exposure multiplier for ODGW4
   	odgwSize    tc1:gsaoiodgwSetup.K  	ODGW size
   	odgwDisplay tc1:gsaoiodgwSetup.N	ODGW Display
    odgwDisplayRate tc1:gsaoiodgwSetup.O    ODGW Display rate
}

command gems::odgwGuide gems::odgwApply ODGW start exposure
{
   command gsaoi:dc:guide.DIR ODGW start command
}

command gems::odgwEndGuide gems::odgwApply ODGW start exposure
{
   command gsaoi:dc:endGuide.DIR ODGW stop command
}

command gems::lisPause gems::lisApply Pause LIS
{
   command lis:pause.DIR LIS pause command
}
