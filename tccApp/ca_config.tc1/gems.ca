#+
# crs.ca
#
# Channel access configuration file for GeMS subsystem commands.
#
# J Luhrs July 2009
#
#-

apply gems::aomApply aom:apply aom:applyC Primary GeMS Apply Record
apply gems::mystApply myst:apply myst:applyC Primary Myst Apply Record

command gems::adcMech gems::aomApply ADC Control
{
	pos	aom:adcScCtrl.A		ADC unit position In/Out
}

command gems::adcLoop gems::aomApply ADC Control
{
	loop	aom:adcScLpCtrl.A		ADC loop control On/Off
}

command gems::beamSplitter gems::aomApply ADC Control
{
	pos	aom:bsCtrl.A			Dichroic beamsplitter position 1|2
}

command gems::astroMode gems::mystApply ADC Control
{
	mode	myst:astrometric.A 	Astrometric mode Off|Regular|Good|Best
}

command gems::ngsPr1Ctrl	gems::aomApply	Canopus probe 1 control
{
	command tc1:aom:ngsPr1Ctrl.A	Command Park|Datum
}

command gems::ngsPr2Ctrl	gems::aomApply	Canopus probe 2 control
{
	command tc1:aom:ngsPr2Ctrl.A	Command Park|Datum
}

command gems::ngsPr3Ctrl	gems::aomApply	Canopus probe 3 control
{
	command tc1:aom:ngsPr3Ctrl.A	Command Park|Datum
}

status gemssad
{
	ngs1Follow	tc1:aom:ngsPr1followS.VAL	0	Canopus 1 in follow mode
	ngs2Follow	tc1:aom:ngsPr2followS.VAL	0	Canopus 2 in follow mode
	ngs3Follow	tc1:aom:ngsPr3followS.VAL	0	Canopus 3 in follow mode
}
