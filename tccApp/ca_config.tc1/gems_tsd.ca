#+
# crs.ca
#
# Channel access configuration file for GeMS subsystem commands.
#
# J Luhrs July 2009
#
#-

status aomsad
{
	applyC		tc1:aom:activeC.VAL			0	Command Status
	message		tc1:aom:activeC.OMSS		0	Command completion message
	
	adcScState 	ao2:adcScState.VAL    0 Science ADC state (In|Out|Moving|Invalid)
	beamSplitterState ao2:bsState.VAL 0 Beam splitter state (In|Out|Moving|Invalid)
	adcScLoop	ao2:adcScLoop.VAL    0 Science ADC loop satus (OPEN|CLOSED)

	ngs1Follow	tc1:aom:ngsPr1followS.VAL	0	Canopus 1 in follow mode
	ngs2Follow	tc1:aom:ngsPr2followS.VAL	0	Canopus 2 in follow mode
	ngs3Follow	tc1:aom:ngsPr3followS.VAL	0	Canopus 3 in follow mode
	
	inPosition  tc1:aom:inPosition.VAL    0   Canopus in-position flag
	
	inShutterState	ao2:inShState.VAL	0	Input shutter state
	outShutterState	ao2:outShState.VAL	0	Output shutter state
}

status gemssad
{
	r0	myst:r0.VAL	0	Myst R0
}
