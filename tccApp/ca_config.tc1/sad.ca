   absorbtilt tc1:absorbTipTiltFlag.VAL     0   Absorb tilt errors
   m1state    tc1:im:m1GuideOn.VAL          0   M1 guiding
   m1source   tc1:m1GuideConfig.VALB        0   M1 guide source
   p1guide    tc1:ak:wfsguide:p1weight.VAL       0   WFS guiding
   p2guide    tc1:ak:wfsguide:p2weight.VAL 	    0   WFS guiding
   oiguide    tc1:ak:wfsguide:oiweight.VAL       0   WFS guiding
   p1guided     tc1:wfsGuideMode:p1.VAL 0   PWFS1 probe guided
   p2guided     tc1:wfsGuideMode:p2.VAL 0   PWFS2 probe guided
   oiguided     tc1:wfsGuideMode:oi.VAL 0   OIWFS probe guided
   p1mweight  tc1:mountGuideMode.VALC       0   Mount p1 wieght
   p2mweight  tc1:mountGuideMode.VALD       0   Mount p1 wieght
   m2p1guide  tc1:drives:p1GuideConfig      0   M2 P1 guide config
   m2p2guide  tc1:drives:p2GuideConfig      0   M2 P2 guide config
   m2oiguide  tc1:drives:oiGuideConfig      0   M2 OI guide config
   m2aoguide  tc1:drives:aoGuideConfig      0   M2 AO guide config
   coma       tc1:im:m2gm:comaCorrectFlag.VAL 0 Coma correction
   m1GuideSource       tc1:m1GuideConfig.VALB     0 M1 guide source
   crGuide 	  tc1:sad:rotatorGuideState           0   Cass-rotator guide mode
   useLwfs    tc1:aoUseLwfs.VALA	    0   GAOS using Laser WFS? (ON/OFF)
   oiblend    tc1:aoOiwfsSource.A            0 Altair OI Blending on?
   lgsp1source tc1:aoLgsttfSource.VALA           0   Altair LGS P1 Source on?
   lgsoisource tc1:aoLgsttfSource.VALB           0   Altair LGS OI Source on?

#   aoTTGS     ao:wfcs:strapGtCtl.VALA       0   GAOS Tip Tilt WFS ON/OFF (1/0)
   aoTTGS     ao:strapDevStatus.VALH        0   GAOS Tip Tilt WFS ON/OFF (0-100, 0== off)
   aoSFO      sfo:observing                 0   SFO integrating ON/OFF (1/0)
   aoBTO      bto:fsaLoop    		    0   BTO FSA loop state OPEN/CLOSED
   ttgsloop   tc1:ao:wfcs:strapCorrCtl.VALA     0   GAOS TTGS Correcting ON/OFF (1/0)
   sfoloop    tc1:ao:cc:lgszoomSfoLoop          0   SFO correcting loop disabled/enabled
   niciAOloop nici:sad:AOLoopState          0   Correction Loop OPEN or CLOSED
   niciAPD    nici:ao:AO:APDC.VAL           0   NICI APD activity (IDLE or BUSY)
}

