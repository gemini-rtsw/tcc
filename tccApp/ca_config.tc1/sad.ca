   agInPosition        tc1:agInPosCalc      0
   aoInPosition        tc1:aomInPosCalc     0
   mcsInposOverr       tc1:mcInPosOverride  0
   
# Virtual guiders
	g1MapName			tc1:guiderConfig.VALA	0	Name of GeMS WFS for G1
	g2MapName			tc1:guiderConfig.VALB	0	Name of GeMS WFS for G2
	g3MapName			tc1:guiderConfig.VALC	0	Name of GeMS WFS for G3
	g4MapName			tc1:guiderConfig.VALD	0	Name of GeMS WFS for G4
#Virtual guiders wavelengths
   g1Wavelength		tc1:sad:g1Wavelength		0	G1 Wavelength
   g2Wavelength		tc1:sad:g2Wavelength		0	G2 Wavelength
   g3Wavelength		tc1:sad:g3Wavelength		0	G3 Wavelength
   g4Wavelength		tc1:sad:g4Wavelength		0	G4 Wavelength
   
# M1/M2 saved model
   m1AOModelValid   tc1:drives:m1AOModelValid.VAL   0   Saved M1 model valid
   m1ModelValid   tc1:drives:m1ModelValid.VAL   0   Saved M1 model valid
   useAO    tc1:im:AOConfigFlag.VAL 0   Using AO flag
   m1ModelName      tc1:drives:m1ModelName.VAL      0   Identifies file where M1/M2 figure is saved
   m1RestoredFile   tc1:drives:m1RestoredFile.VAL   0   Last restored figure
   m1RestoredTime   tc1:drives:m1RestoredTime.VAL   0   Time of last figure restore
}

