status aossad
{
   gaosBusy	       ao:WfcsCcC.VAL		      0 Gaos Top Level Busy
   useLwfsBusy	       ao:useLwfs.BUSY		      0 UseLwfs Cmd Busy
   initWfsBusy	       ao:wfcs:wfsInit.BUSY	      0 wfsInit Cmd Busy
   useLwfsMess	       ao:useLwfs.MESS            0 UseLwfs Error Message
   initWfsMess         ao:wfcs:wfsInit.MESS       0 wfsInit Error Message
   prepareBusy	       ao:prepareCm.BUSY              0 PrepareCm Busy
   centerBusy	       ao:centreWfs.BUSY              0 Center Wfs Busy
   flattenBusy         ao:flatten.BUSY                0 Flatten Busy
   strapBusy           ao:wfcs:strapCorrCtl.BUSY      0 STRAP Busy
   strapExpTime      ao:wfcs:strapSEX.VALA	  		0	STARP Exposure Time
   strapSEXBusy      ao:wfcs:strapSEX.BUSY	  		0	STRAP SEX Busy
   strapSEXMess      ao:wfcs:strapSEX.MESS	  		0	STRAP SEX Mess
   strapSFXMode      ao:wfcs:strapSFX.VALA      	0	STRAP SFX Mode
   strapSFXBusy      ao:wfcs:strapSFX.BUSY	  		0	STRAP SFX Busy
   strapSFXMess      ao:wfcs:strapSFX.MESS	  		0	STRAP SFX Mess
   strapRTStat	      ao:strapDevStatus.VALO     	0	STRAP RT Ctl Status (1:OK, 0:not OK)
   strapTPStat	      ao:strapDevStatus.VALL     	0	STRAP Temp Ctl Status (1:OK, 0:not OK)
   strapHVStat       ao:strapDevStatus.VALI     	0	STRAP HVolt Status (1:OK, 0:not OK)
   strapTemp			ao:strapDevStatus.VALF			0	STRAP Temperature
   strapGTBusy       ao:wfcs:strapGtCtl.BUSY    	0	STRAP Gate Ctl Busy
   wfsposBusy	       ao:cc:wfsposAssembly.BUSY      0 Following Busy (includes FSM)
   useAO	       tc1:configureForAO.A	      0 Yes if we're using AO, else No
   followS             tc1:ao:followS                 0 Follow state
   prepareCmBusy       tc1:ao:prepareCm_BUSY          0 PrepareCm busy
   exitShutterOpen     tc1:ao:exitShutterOpen         0 Exit shutter open
   entShutterOpen      tc1:ao:entShutterOpen          0 Entrance shutter open
   wfsXPosition        tc1:ao:wfsXPosition            0 WFS X position
   wfsYPosition        tc1:ao:wfsYPosition            0 WFS Y position
   inPosition          tc1:ao:inPosition              0 In position
   oiblend             tc1:aoOiwfsSource.A            0 Altair OI Blending on?
   gsmag	       tc1:aoPrepareCm.D	      0 Altair Guide Star Magnitude
   oiblendBusy	       ao:oiwfsSource.BUSY	      0 Altair OI Blending Busy ?
   lgsttfSourceBusy    ao:lgsttSource.BUSY	      0	Altair LGS TTF Source Busy ?
   oiOutGuide	       oiwfs:dc:outGuide	      0 OIWFS Guide Output (SCS/AO)
   correctBusy	       ao:correctM.BUSY		      0 Correct Busy (loop closed)
   aoSettled	       ao:wfcs:settled		      0 Altair Loop is Settled
   ndFiltPos	       ao:cc:ndfiltAssembly.VALA      0 ND Filter Position
   flensPos	       ao:cc:astarPosition.VALD       0 FLens Position (actually ASTAR Named Pos)
   ttgsIrisPos	       ao:cc:lgsirisAssembly.VALA     0 TTGS Iris position
   laserProp           tc1:aoStats.A    	      0 Is the Laser Propogating to the Sky
   ustage    	       ao:cc:lgsustAssembly.VALA  0 UStage Position (IN/OUT)
   zoomMode	       ao:cc:lgszoomAssembly.MODE 0 lgsZoom Mode
   zoomBusy	       ao:cc:lgszoomAssembly.BUSY 0 lgsZoom Busy
   zoomInPos	       ao:cc:lgszoomPosition.VALA 0 lgsZoom inPosition
   
   parked            ao:sad:parked.VAL             0  Altair parked status
   ccParked          ao:cc:sad:parked.VAL          0  Altair CC parked status
   wfcsParked        ao:cc:wfcsParked.VAL          0  Altair Wfcs parked status
   dmVolt1           ao:dmVolt.VALA                0  DM Voltage level 1+
   dmVolt2           ao:dmVolt.VALB                0  DM Voltage level 2-
}
