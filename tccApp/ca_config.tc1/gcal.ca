# Define the GCAL apply record.

   apply gcal::Apply gc1:apply gc1:applyC Primary GCAL Apply Record
   status gcal::Apply Apply message
   {
   mess       gc1:applyC.OMSS                0     Command completion message
   }

   command gcal::filtSel gcal::Apply Filter selection
   {
      name  gc1:filtSel.A 0 Filter name
   }

   command gcal::lampSel gcal::Apply Lamp control
   {
      nameIR    gc1:lampSel.A 0 IR Lamp name
      stateIR   gc1:lampSel.B 0 IR lamp state (ON/OFF)
      nameQH    gc1:lampSel.C 0 QH Lamp name
      stateQH   gc1:lampSel.D 0 QH lamp state (ON/OFF)
      nameAr    gc1:lampSel.E 0 Ar Lamp name
      stateAr   gc1:lampSel.F 0 Ar lamp state (ON/OFF)
      nameXe    gc1:lampSel.G 0 Xe Lamp name
      stateXe   gc1:lampSel.H 0 Xe lamp state (ON/OFF)
      nameThAr  gc1:lampSel.I 0 ThAr Lamp name
      stateThAr gc1:lampSel.J 0 ThAr lamp state (ON/OFF)
      nameCuAr  gc1:lampSel.K 0 CuAr Lamp name
      stateCuAr gc1:lampSel.L 0 CuAr lamp state (ON/OFF)
   }

   command gcal::diffuseSel gcal::Apply Diffuser selection
   {
      name  gc1:diffuseSel.A 0 Diffuser name
   }

   command gcal::shutter gcal::Apply Shutter control
   {
      position  gc1:shutter.A 0 Shutter position (OPEN/CLOSE)
      dir       gc1:apply.DIR
   }

   status gcal::status
   {
      shutter             gc1:sad:shutterName  0 Shutter position
      filter              gc1:sad:filtName     0 Filter name
      diffuser            gc1:sad:diffuseName  0 Diffuser name
      IRLampState         gc1:IR_LampState     0 IR lamp state
      ArLampState         gc1:Ar_LampState     0 Argon lamp state
      XeLampState         gc1:Xe_LampState     0 Xenon lamp state
      CuArLampState       gc1:CuAr_LampState   0 CuAr lamp state
      ThArLampState       gc1:ThAr_LampState   0 ThAr lamp state
      QHLampState         gc1:QH_LampState     0 Quartz Halogen lamp state
   }
