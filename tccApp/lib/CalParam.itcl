itcl::body CalParam::odgwGetSciRows { size } {
   if { [array names odgwParamLUT -exact $size] == "" } {
      return 16
   } else {
      return [lindex $odgwParamLUT($size) 0]
   }
}

itcl::body CalParam::odgwGetIdleRows { size } {
   if { [array names odgwParamLUT -exact $size] == "" } {
      return 16
   } else {
      return [lindex $odgwParamLUT($size) 1]
   }
}

itcl::body CalParam::odgwGetDisplayRate { size } {
   if { [array names odgwParamLUT -exact $size] == "" } {
      return 2
   } else {
      return [lindex $odgwParamLUT($size) 2]
   }
}

itcl::body CalParam::centralBaffleOverride {instrument} {
   if { [array names centralBaffleOverride -exact $instrument] == "" } {
